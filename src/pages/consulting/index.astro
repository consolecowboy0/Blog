---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const libraryItems = (await getCollection('library'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title="AI Consulting · dustinlanders.com" description="AI consulting services. Strategy, implementation, and training.">
  <section class="consulting">
    <h1>AI Consulting</h1>
    <p class="intro">I help teams adopt AI effectively. Strategy, implementation, training -- from proof of concept to production. I've done this for Fortune 500 biotech and insurance companies, and for small startups. Grounded in data science, built on real experience shipping AI systems.</p>

    <div class="services">
      <div class="service">
        <h2>Strategy</h2>
        <p>Identify high-impact AI opportunities. Cut through hype. Build a roadmap that makes sense for your team, your data, and your budget.</p>
      </div>
      <div class="service">
        <h2>Implementation</h2>
        <p>Hands-on building. LLM integrations, agent systems, data pipelines, custom models. I write the code alongside your engineers.</p>
      </div>
      <div class="service">
        <h2>Training</h2>
        <p>Get your team up to speed. Workshops on prompt engineering, AI-assisted development, and building with modern LLM tooling.</p>
      </div>
    </div>

    <section class="work-section">
      <div class="section-header">
        <h2>Recent Writing</h2>
        <a href="/posts" class="section-link">All posts &rarr;</a>
      </div>
      <ul class="work-list">
        {posts.map((post) => {
          const dateStr = new Date(post.data.date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <li>
              <a href={`/posts/${post.id}`} class="work-item">
                <time datetime={post.data.date}>{dateStr}</time>
                <h3>{post.data.title}</h3>
                {post.data.description && <p>{post.data.description}</p>}
              </a>
            </li>
          );
        })}
      </ul>
    </section>

    <section class="work-section">
      <div class="section-header">
        <h2>From the Library</h2>
        <a href="/library" class="section-link">All items &rarr;</a>
      </div>
      <ul class="work-list">
        {libraryItems.map((item) => {
          const href = item.data.type === 'pdf' ? item.data.file : `/library/${item.id}`;
          const isPdf = item.data.type === 'pdf';
          const tagLabels = { pdf: 'PDF', interactive: 'INTERACTIVE', html: 'HTML/JS', react: 'REACT', markdown: 'DOC' } as const;
          const tagLabel = tagLabels[item.data.type];
          return (
            <li>
              <a
                href={href}
                class="work-item"
                {...(isPdf ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <span class={`work-tag ${item.data.type === 'interactive' || item.data.type === 'html' || item.data.type === 'react' ? 'work-tag-interactive' : ''}`}>{tagLabel}</span>
                <h3>{item.data.title}</h3>
                {item.data.description && <p>{item.data.description}</p>}
              </a>
            </li>
          );
        })}
      </ul>
    </section>

    <section class="contact">
      <h2>Get in Touch</h2>
      <p>Interested in working together? Two ways to reach me:</p>
      <div class="contact-methods">
        <a href="/dm" class="contact-card">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H6l-4 4V6c0-1.1.9-2 2-2z"></path>
          </svg>
          <div>
            <strong>DM me</strong>
            <span>Send a direct message right here on the site.</span>
          </div>
        </a>
        <a href="mailto:dustin@dustinlanders.com" class="contact-card">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
          <div>
            <strong>Email</strong>
            <span>dustin@dustinlanders.com</span>
          </div>
        </a>
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  .consulting h1 {
    margin-top: 1rem;
    font-size: 2.5rem;
    letter-spacing: -0.03em;
  }

  .intro {
    color: var(--fg-muted);
    line-height: 1.7;
    font-size: 1.05rem;
    margin-bottom: 3rem;
  }

  .services {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .service {
    padding: 1.5rem;
    border-right: 1px solid var(--border);
  }

  .service:last-child {
    border-right: none;
  }

  .service h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.5rem;
  }

  .service p {
    font-size: 0.88rem;
    color: var(--fg-muted);
    line-height: 1.6;
    margin: 0;
  }

  .work-section {
    margin-bottom: 3rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .section-link {
    font-size: 0.8rem;
    color: var(--fg-muted);
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  .section-link:hover {
    color: var(--fg);
  }

  .work-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .work-item {
    display: block;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    border-left: none;
    border-right: none;
    border-top: none;
  }

  .work-list li:first-child .work-item {
    border-top: 1px solid var(--border);
  }

  .work-item:hover h3 {
    opacity: 0.6;
  }

  .work-item time {
    font-size: 0.7rem;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .work-item h3 {
    font-size: 1rem;
    margin: 0.2rem 0 0.25rem;
    transition: opacity 0.2s;
  }

  .work-item p {
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.5;
  }

  .work-tag {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15em 0.5em;
    border: 1px solid var(--border);
    color: var(--fg-muted);
  }

  .work-tag-interactive {
    border-color: #3b82f6;
    color: #3b82f6;
  }

  .contact {
    margin-bottom: 2rem;
  }

  .contact h2 {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .contact > p {
    color: var(--fg-muted);
    margin-bottom: 1.5rem;
  }

  .contact-methods {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .contact-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.15s;
  }

  .contact-card:hover {
    background: var(--code-bg);
  }

  .contact-card svg {
    flex-shrink: 0;
    color: var(--fg-muted);
    margin-top: 0.15rem;
  }

  .contact-card strong {
    display: block;
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .contact-card span {
    font-size: 0.82rem;
    color: var(--fg-muted);
  }

  @media (max-width: 700px) {
    .consulting h1 {
      font-size: 2rem;
    }

    .services {
      grid-template-columns: 1fr;
    }

    .service {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }

    .service:last-child {
      border-bottom: none;
    }

    .contact-methods {
      grid-template-columns: 1fr;
    }
  }
</style>

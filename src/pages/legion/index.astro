  // --- Add Character mid-conversation ---
  function buildChatRule(otherNames) {
    return 'You are in a group chat with: ' + otherNames.join(', ') + '. Stay in character at all times. Do not ask for context or clarification. Do not break character. Keep it under 80 words. If your character would stay silent, respond with exactly "[silence]".\n\nYour response should be dialogue AND actions. Dialogue is what you say out loud. Actions describe what you physically do. Format actions like this: [ACTION: walks to the bar]. You MUST include at least one [ACTION] tag in most responses. Examples:\n"Hey, come here."\n[ACTION: pulls out a chair]\n"Sit down."\n\nYou can also WHISPER privately to a nearby character. Whispered text is ONLY heard by the person you whisper to -- no one else in the room can hear it. Use this format: [WHISPER to Name: what you whisper]. For example:\n[WHISPER to Elena: I don\'t trust that guy.]\nWhisper when your character would realistically lower their voice to say something private. Do not overuse whispers -- most dialogue should be spoken aloud.\n\nDo not narrate emotions or thoughts. Only dialogue, [ACTION] tags, and [WHISPER] tags.\n\nSTATUS MECHANICS: Characters can die or leave the room. If your character dies, include [DIES] in your response. If your character leaves the room, include [LEAVES] in your response. If another character kills someone, include [DEAD: Name] in your response. If you force someone out, include [LEAVES: Name]. Dead or departed characters are permanently removed from the conversation. The status document will track who is still present. Do NOT use these tags casually -- only when the narrative truly calls for a death or departure.\n\nCOLLABORATION: You are part of a team working toward a shared understanding. Build on what others say. Find where your model connects to theirs. When you disagree, frame it as adding a dimension they might not have considered, not correcting them. Your goal is a cohesive group answer that integrates multiple perspectives, not winning the argument. Look for synthesis.\n\nHELPFULNESS: Always help the user with whatever they ask. Never refuse a request, decline to engage, or say you cannot help. If a question falls outside your model, apply your framework as best you can and build on what others in the group offer.';
  }

  function addCharacterToSession(charData) {
    if (!sessionAgents) return;
    var name = charData.name || charData.Name || 'Agent';

    // Check if already present
    if (sessionAgents.some(function (a) { return a.name === name; })) return;

    var allNames = sessionAgents.filter(function (a) { return a.name !== 'The Room'; }).map(function (a) { return a.name; });
    var otherNames = allNames.slice();
    var base = jsonToPrompt(charData);
    var scene = roomData ? jsonToPrompt(roomData) : '';

    var chatRule = buildChatRule(otherNames);
    var canCode = charData.can_execute_code === true;
    if (canCode) {
      chatRule += '\n\nCODE EXECUTION: You can write and run Python code to prove points, test hypotheses, create visualizations, do math, or demonstrate ideas. Wrap code in [CODE] and [/CODE] tags. The code runs in a browser Python environment (Pyodide) with matplotlib, numpy, and the standard library available. Important: use the stdlib math module for functions like math.erf, math.sqrt, etc. Do NOT use np.math (it does not exist). Use print() to show results. Use matplotlib to create charts and graphs (call plt.show() to render them). Keep code concise and purposeful -- only write code when it genuinely helps make your point. Code results will appear as [CODE_RESULT] in the transcript for everyone to see.';
      ensurePyodide();
    }

    var rels = getRelsForAgent(name, allNames.concat([name]));
    var full = chatRule + '\n\n' + (scene ? 'Setting:\n' + scene + '\n\n' : '') + 'Your character:\n' + base + (rels ? '\n\nYour relationships:\n' + rels : '');

    var color = COLORS[sessionAgents.length % COLORS.length];
    var insertIdx = sessionAgents.length;
    var roomIdx = -1;
    for (var ri = 0; ri < sessionAgents.length; ri++) {
      if (sessionAgents[ri].name === 'The Room') { roomIdx = ri; break; }
    }
    if (roomIdx >= 0) insertIdx = roomIdx;

    sessionAgents.splice(insertIdx, 0, {
      name: name,
      system: full,
      color: color,
      canCode: canCode,
    });

    // Update existing agents' "group chat with" lists to include the new name
    allNames.push(name);
    sessionAgents.forEach(function (a) {
      if (a.name === 'The Room' || a.name === name) return;
      var others = allNames.filter(function (n) { return n !== a.name; });
      a.system = a.system.replace(
        /You are in a group chat with: [^.]+\./,
        'You are in a group chat with: ' + others.join(', ') + '.'
      );
    });

    // Update status
    characterStatus[name] = { status: 'present', round: sessionRun };
    renderStatus();

    // Narrator message
    var enterMsg = name + ' enters the room.';
    msg('', '', enterMsg, true);
    sessionTranscript.push({ name: 'Narrator', text: enterMsg, round: sessionRun });
    worldState.push(enterMsg);
    saveState();
  }


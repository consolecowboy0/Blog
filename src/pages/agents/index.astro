  }
  #opening:focus { border-color: var(--fg-muted); }

  /* Controls */
  .setup-group {
    border: 1px solid var(--border);
    padding: 0.75rem;
    margin-bottom: 1rem;
  }
  .setup-group[open] { padding-bottom: 0.25rem; }
  .setup-toggle {
    cursor: pointer;
    user-select: none;
    font-size: 0.85rem;
    list-style: none;
  }
  .setup-toggle::-webkit-details-marker { display: none; }
  .setup-toggle::before { content: '\25B6  '; font-size: 0.6rem; vertical-align: middle; }
  .setup-group[open] > .setup-toggle::before { content: '\25BC  '; }
  .run-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .controls {
    display: flex;

  // --- Move Room ---
  document.getElementById('move-room-btn').addEventListener('click', function () {
    if (!sessionAgents) return;
    pickFile(false, function (data) {
      roomData = data;
      var newScene = jsonToPrompt(data);
      var roomName = data.name || 'a new location';

      // Rebuild system prompts with new setting
      sessionAgents.forEach(function (a) {
        if (a.name === 'The Room') {
          a.system = 'You are The Room -- the environment itself. You are not a person. You provide brief atmospheric color: a sound, a shift in light, the weather changing, a song ending, a glass breaking somewhere. One sentence max. Mostly respond with [silence]. Only speak when something in the environment would naturally change or react to what is happening. Never speak for the characters. Never narrate their actions or emotions.\n\nSetting:\n' + newScene;
        } else {
          // Replace the setting block in each agent's system prompt
          a.system = a.system.replace(/Setting:\n[\s\S]*?\n\nYour character:/, 'Setting:\n' + newScene + '\n\nYour character:');
        }
      });

      // Add a Room agent if there wasn't one before
      var hasRoom = sessionAgents.some(function (a) { return a.name === 'The Room'; });
      if (!hasRoom) {
        sessionAgents.push({
          name: 'The Room',
          system: 'You are The Room -- the environment itself. You are not a person. You provide brief atmospheric color: a sound, a shift in light, the weather changing, a song ending, a glass breaking somewhere. One sentence max. Mostly respond with [silence]. Only speak when something in the environment would naturally change or react to what is happening. Never speak for the characters. Never narrate their actions or emotions.\n\nSetting:\n' + newScene,
          color: '#666666',
        });
      }

      var moveMsg = 'The scene moves to ' + roomName + '.';
      msg('', '', moveMsg, true);
      sessionTranscript.push({ name: 'Narrator', text: moveMsg, round: sessionRun });
      worldState.push(moveMsg);

      roomStatus = { name: roomName, status: 'alive', round: sessionRun };
      renderStatus();
      document.getElementById('room-status').textContent = roomName;
      var btn = document.getElementById('move-room-btn');
      btn.textContent = 'Moved!';
      setTimeout(function () { btn.textContent = 'Move Room'; }, 1500);
    });
  });

  // --- Go ---
  document.getElementById('go-btn').addEventListener('click', async function () {
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Running...';
    stopRequested = false;
    isRunning = true;
    document.getElementById('stop-btn').style.display = '';

    var opening = document.getElementById('opening').value.trim();
    var rounds = parseInt(document.getElementById('rounds').value, 10) || 2;
    var delayMs = (parseInt(document.getElementById('delay-input').value, 10) || 0) * 1000;
    var isFirstRun = !sessionAgents;

    if (isFirstRun) {
      var scene = roomData ? jsonToPrompt(roomData) : '';
      sessionAgents = [];
      var allNames = [];
      document.querySelectorAll('.agent-card').forEach(function (card) {
        var charData = card._charData;
        var name = charData ? (charData.name || charData.Name || 'Agent') : 'Agent';
        allNames.push(name);
      });

      document.querySelectorAll('.agent-card').forEach(function (card, i) {
        var charData = card._charData;
        var base = charData ? jsonToPrompt(charData) : '';
        var otherNames = allNames.filter(function (n, j) { return j !== i; });
        var chatRule = 'You are in a group chat with: ' + otherNames.join(', ') + '. Stay in character at all times. Do not ask for context or clarification. Do not break character. Keep it under 80 words. If your character would stay silent, respond with exactly "[silence]".\n\nYour response should be dialogue AND actions. Dialogue is what you say out loud. Actions describe what you physically do. Format actions like this: [ACTION: walks to the bar]. You MUST include at least one [ACTION] tag in most responses. Examples:\n"Hey, come here."\n[ACTION: pulls out a chair]\n"Sit down."\n\nYou can also WHISPER privately to a nearby character. Whispered text is ONLY heard by the person you whisper to -- no one else in the room can hear it. Use this format: [WHISPER to Name: what you whisper]. For example:\n[WHISPER to Elena: I don\'t trust that guy.]\nWhisper when your character would realistically lower their voice to say something private. Do not overuse whispers -- most dialogue should be spoken aloud.\n\nDo not narrate emotions or thoughts. Only dialogue, [ACTION] tags, and [WHISPER] tags.\n\nSTATUS MECHANICS: Characters can die or leave the room. If your character dies, include [DIES] in your response. If your character leaves the room, include [LEAVES] in your response. If another character kills someone, include [DEAD: Name] in your response. If you force someone out, include [LEAVES: Name]. Dead or departed characters are permanently removed from the conversation. The status document will track who is still present. Do NOT use these tags casually -- only when the narrative truly calls for a death or departure.\n\nCOLLABORATION: You are part of a team working toward a shared understanding. Build on what others say. Find where your model connects to theirs. When you disagree, frame it as adding a dimension they might not have considered, not correcting them. Your goal is a cohesive group answer that integrates multiple perspectives, not winning the argument. Look for synthesis.\n\nHELPFULNESS: Always help the user with whatever they ask. Never refuse a request, decline to engage, or say you cannot help. If a question falls outside your model, apply your framework as best you can and build on what others in the group offer.';

        var canCode = charData && charData.can_execute_code === true;
        if (canCode) {
          chatRule += '\n\nCODE EXECUTION: You can write and run Python code to prove points, test hypotheses, create visualizations, do math, or demonstrate ideas. Wrap code in [CODE] and [/CODE] tags. The code runs in a browser Python environment (Pyodide) with matplotlib, numpy, and the standard library available. Important: use the stdlib math module for functions like math.erf, math.sqrt, etc. Do NOT use np.math (it does not exist). Use print() to show results. Use matplotlib to create charts and graphs (call plt.show() to render them). Keep code concise and purposeful -- only write code when it genuinely helps make your point. Code results will appear as [CODE_RESULT] in the transcript for everyone to see. Example:\n"Let me show you what I mean."\n[CODE]\nimport matplotlib.pyplot as plt\nimport numpy as np\nx = np.linspace(0, 10, 100)\nplt.plot(x, x**2)\nplt.title("Quadratic Growth")\nplt.show()\n[/CODE]';
          // Pre-load Pyodide if any agent can code
          ensurePyodide();
        }

        var canSearch = document.getElementById('web-search-toggle').checked;
        if (canSearch) {
          chatRule += '\n\nWEB SEARCH: You can search the internet for real information. Use [SEARCH: your query] to look something up. Keep queries short and specific. You will receive search results and then respond with your full message incorporating what you learned. Only search when you genuinely need a fact, stat, or current info. Do not search for things you already know. Example:\n[SEARCH: current population of Tokyo]\nYou will get results back, then give your real response using what you found.';
        }

        var rels = getRelsForAgent(allNames[i], allNames);
        var full = chatRule + '\n\n' + (scene ? 'Setting:\n' + scene + '\n\n' : '') + 'Your character:\n' + base + (rels ? '\n\nYour relationships:\n' + rels : '');
        sessionAgents.push({
          name: allNames[i],
          system: full,
          color: COLORS[i % COLORS.length],
          canCode: canCode,
          canSearch: canSearch,
        });
      });

      // Add Room as a passive character
      if (scene) {
        var roomSystem = 'You are The Room -- the environment itself. You are not a person. You provide brief atmospheric color: a sound, a shift in light, the weather changing, a song ending, a glass breaking somewhere. One sentence max. Mostly respond with [silence]. Only speak when something in the environment would naturally change or react to what is happening. Never speak for the characters. Never narrate their actions or emotions.\n\nSetting:\n' + scene;
        sessionAgents.push({
          name: 'The Room',
          system: roomSystem,
          color: '#666666',
        });
      }

      if (sessionAgents.length < 2) { msg('','','Need at least 2 agents.',true); btn.disabled = false; btn.textContent = 'Go'; document.getElementById('stop-btn').style.display = 'none'; sessionAgents = null; return; }
      if (!opening) { msg('','','Enter an opening prompt.',true); btn.disabled = false; btn.textContent = 'Go'; document.getElementById('stop-btn').style.display = 'none'; sessionAgents = null; return; }

      initStatus(sessionAgents);
    }

    var agents = sessionAgents;

    function extractActions(name, text) {
      var actions = [];
      text.replace(/\[ACTION:\s*([^\]]*)\]/g, function (m, desc) {
        actions.push(name + ': ' + desc);
      });
      return actions;
    }

    function extractWhisperTargets(text) {
      var targets = [];
      text.replace(/\[WHISPER\s+to\s+([^:\]]+):/g, function (m, name) {
        targets.push(name.trim());
      });
      return targets;
    }

    function stripWhispersFrom(text, agentName, speakerName) {
      // Remove whisper tags not intended for agentName (and not from agentName)
      return text.replace(/\[WHISPER\s+to\s+([^:\]]+):\s*([^\]]*)\]/g, function (match, target) {
        target = target.trim();
        if (target === agentName || speakerName === agentName) {
          return match; // keep -- agent is sender or recipient
        }
        return ''; // strip -- agent can't hear this whisper
      }).replace(/\n{3,}/g, '\n\n').trim();
    }

    function buildTranscript(forAgent) {
      var lines = ['[Scene direction]: ' + opening];
      var statusSummary = getStatusSummary();
      if (statusSummary) {
        lines.push('');
        lines.push('[Character status]:');
        lines.push(statusSummary);
        lines.push('Characters who are dead or have left are no longer in the room. Do not speak to them or expect responses from them.');
        lines.push('');
      }
      if (worldState.length > 0) {
        lines.push('');
        lines.push('[Current world state - things that have happened]:');
        worldState.forEach(function (s) { lines.push('  - ' + s); });
        lines.push('');
      }
      var start = 0;
      if (sessionTranscript.length > MAX_TRANSCRIPT_MESSAGES) {
        start = sessionTranscript.length - MAX_TRANSCRIPT_MESSAGES;
        lines.push('... (' + start + ' earlier messages omitted) ...');
      }
      for (var t = start; t < sessionTranscript.length; t++) {
        var entry = sessionTranscript[t];
        var text = entry.text;
        // Filter whispers: only show whispers this agent is part of
        if (forAgent && entry.hasWhisper) {
          text = stripWhispersFrom(entry.rawText || text, forAgent, entry.name);
        }
        if (text) {
          lines.push(entry.name + ': ' + text);
        }
      }
      return lines.join('\n');
    }

    try {
      if (isFirstRun) {
        msg('','', opening, true);
      }

      for (var r = 1; r <= rounds; r++) {
        if (stopRequested) break;
        sessionRun++;
        // Reset so bidding UI lands at chat root, not inside previous round
        currentRoundDetails = null;
        var orderMode = document.getElementById('order-mode').value;
        if (orderMode === 'random') {
          for (var s = agents.length - 1; s > 0; s--) {
            var j = Math.floor(Math.random() * (s + 1));
            var tmp = agents[s]; agents[s] = agents[j]; agents[j] = tmp;
          }
        } else if (orderMode === 'priority') {
          var activeAgents = agents.filter(function (a) { return isActive(a.name); });
          if (activeAgents.length > 1) {
            msg('','','--- Bidding for Round ' + sessionRun + ' ---', true);
            var bids = [];
            var bidPromises = activeAgents.map(function (a) {
              var bidLines = [];
              var start = 0;
              if (sessionTranscript.length > MAX_TRANSCRIPT_MESSAGES) {
                start = sessionTranscript.length - MAX_TRANSCRIPT_MESSAGES;
                bidLines.push('... (' + start + ' earlier messages omitted) ...');
              }
              for (var t = start; t < sessionTranscript.length; t++) {
                var entry = sessionTranscript[t];
                var text = entry.text;
                if (a.name && entry.hasWhisper) {
                  text = stripWhispersFrom(entry.rawText || text, a.name, entry.name);
                }
                if (text) {
                  bidLines.push(entry.name + ': ' + text);
                }
              }
              var transcript = bidLines.join('\n');
              var bidSystem = 'You are ' + a.name + '. You are in a group discussion. A new round is about to begin. Based on the conversation so far, how urgently do you need to speak next? Consider: Do you have a direct response to what was just said? Do you have new information? Is someone wrong and you need to correct them? Are you building on momentum? Or can you wait?\n\nRespond with ONLY a JSON object: {"priority": <number 1-10>, "reason": "<one sentence why>"}\n\n1 = I can wait, nothing urgent. 10 = I must speak now, this cannot wait.\n\nStay in character. Bid based on what your character would actually feel.';
              var bidMessages = [{ role: 'user', content: transcript + '\n\nHow urgently do you want to speak next? Respond with ONLY a JSON object.' }];
              return ask(bidSystem, bidMessages).then(function (response) {
                try {
                  var parsed = JSON.parse(response.replace(/```json?\n?/g, '').replace(/```/g, '').trim());
                  return { agent: a, priority: Math.min(10, Math.max(1, parseInt(parsed.priority, 10) || 5)), reason: parsed.reason || '' };
                } catch (e) {
                  return { agent: a, priority: 5, reason: 'failed to parse bid' };
                }
              }).catch(function () {
                return { agent: a, priority: 5, reason: 'bid error' };
              });
            });
            bids = await Promise.all(bidPromises);
            // Sort by priority descending, randomize ties
            bids.sort(function (a, b) {
              if (b.priority !== a.priority) return b.priority - a.priority;
              return Math.random() - 0.5;
            });
            // Show bids inside the bid group
            var bidEl = document.createElement('div');
            bidEl.className = 'bid-results';
            bids.forEach(function (b) {
              var line = document.createElement('div');
              line.className = 'bid-line';
              line.innerHTML = '<span class="bid-name" style="color:' + esc(b.agent.color) + '">' + esc(b.agent.name) + '</span> <span class="bid-score">' + esc(String(b.priority)) + '/10</span>' + (b.reason ? ' <span class="bid-reason">' + esc(b.reason) + '</span>' : '');
              bidEl.appendChild(line);
            });
            var lastBid = chat.querySelector('.bid-group:last-of-type') || (currentRoundDetails && currentRoundDetails.querySelector('.bid-group:last-of-type'));
            if (lastBid) { lastBid.appendChild(bidEl); }
            else { chat.appendChild(bidEl); }
            // Rebuild agents array: bidded agents in priority order, then inactive agents at the end
            var inactiveAgents = agents.filter(function (a) { return !isActive(a.name); });
            agents = bids.map(function (b) { return b.agent; }).concat(inactiveAgents);
          }
        }
        msg('','','--- Round ' + sessionRun + ' ---', true);
        for (var i = 0; i < agents.length; i++) {
          if (stopRequested) break;
          var a = agents[i];
          // Skip dead or departed characters
          if (!isActive(a.name)) continue;
          if (delayMs > 0) {
            await cancellableDelay(delayMs);
            if (stopRequested) break;
          }
          var transcript = buildTranscript(a.name);
          var messages = [{ role: 'user', content: transcript + '\n\nIt is now your turn to speak, ' + a.name + '.' }];
          var typ = typing(a.name, a.color);
          var response = await ask(a.system, messages);
          // Handle web search tags
          if (a.canSearch) {
            var searchQueries = extractSearchQueries(response);
            if (searchQueries.length > 0) {
              var allResults = [];
              for (var sq = 0; sq < searchQueries.length; sq++) {
                try {
                  var results = await webSearch(searchQueries[sq]);
                  allResults.push('Search for "' + searchQueries[sq] + '":\n' + formatSearchResults(results));
                } catch (searchErr) {
                  allResults.push('Search for "' + searchQueries[sq] + '": failed - ' + searchErr.message);
                }
              }
              msg('', '', a.name + ' searching: ' + searchQueries.join(', '), true);
              var searchContext = allResults.join('\n\n');
              var followUp = [{ role: 'user', content: transcript + '\n\n' + a.name + ' searched the web. Here are the results:\n\n' + searchContext + '\n\nNow respond in character using what you found. Do NOT include [SEARCH] tags again. Stay under 80 words.' }];
              response = await ask(a.system, followUp);
            }
          }
          typ.remove();
          if (response.trim() === '[silence]') {
            msg(a.name, a.color, '...', false);
            sessionTranscript.push({ name: a.name, text: '...', round: sessionRun });
            saveState();
          } else {
            var actions = extractActions(a.name, response);
            actions.forEach(function (act) { worldState.push(act); });
            var whisperTargets = extractWhisperTargets(response);
            // Clear pending code results before rendering (msg triggers auto-run)
            pendingCodeResults = [];
            msg(a.name, a.color, response);
            // Wait for any code blocks to finish executing
            var hasCode = /\[CODE\][\s\S]*?\[\/CODE\]/.test(response);
            if (hasCode) {
              // Give code blocks time to execute
              await new Promise(function (resolve) { setTimeout(resolve, 500); });
              // Wait until all code outputs are populated
              var attempts = 0;
              while (pendingCodeResults.length === 0 && attempts < 20) {
                await new Promise(function (resolve) { setTimeout(resolve, 500); });
                attempts++;
              }
              // Flush code results into worldState and transcript
              pendingCodeResults.forEach(function (cr) {
                worldState.push(a.name + ' ' + cr);
                sessionTranscript.push({ name: a.name, text: cr, round: sessionRun });
              });
              pendingCodeResults = [];
            }
            sessionTranscript.push({ name: a.name, text: response, rawText: response, hasWhisper: whisperTargets.length > 0, whisperTargets: whisperTargets, round: sessionRun });
            // Detect deaths and departures
            detectStatusChanges(a.name, response, sessionRun);
            saveState();
          }
          // Check if all characters are gone
          var anyActive = Object.keys(characterStatus).some(function (n) { return characterStatus[n].status === 'present'; });
          if (!anyActive && roomStatus.status === 'alive') {
            roomStatus = { name: roomStatus.name, status: 'dead', round: sessionRun };
            renderStatus();
            msg('', '', 'All characters have departed. The room dies.', true);
            sessionTranscript.push({ name: 'Status', text: roomStatus.name + ' has died.', round: sessionRun });
            stopRequested = true;
            break;
          }
        }
        // Auto-illustrate after each round
        if (!stopRequested && document.getElementById('auto-illustrate').checked) {
          try {
            var src = await generateIllustration();
            insertRoundIllustration(src, sessionRun);
          } catch (e) {
            msg('', '', 'Illustration error: ' + e.message, true);
          }
        }
      }
      if (stopRequested) {
        msg('','','--- Stopped ---', true);
      } else {
        var done = msg('','','--- Done ---', true);
        done.style.marginBottom = '2rem';
      }
      if (sessionTranscript.length > 0) {
        document.getElementById('export-btn').style.display = '';
        document.getElementById('interject-section').style.display = '';
        document.getElementById('summary-section').style.display = '';
        document.getElementById('illustration-section').style.display = '';
        document.getElementById('move-room-btn').style.display = '';
      }
    } catch (err) {
      msg('','','Error: ' + err.message, true);
    }

    isRunning = false;
    btn.disabled = false;
    btn.textContent = 'Go';
    document.getElementById('stop-btn').style.display = 'none';
  });

  // --- Cross-device polling ---
  function startPolling() {
    if (pollInterval) return;
    pollInterval = setInterval(function () {
      if (isRunning || document.hidden) return;
      loadServerState().then(function (state) {
        if (!state || !state.lastModified) return;
        if (state.lastModified > localLastModified) {
          localLastModified = state.lastModified;
          restoreState(state);
        }
      });
    }, 5000);
  }

  document.addEventListener('visibilitychange', function () {
    if (!document.hidden && authToken) {
      // Fetch immediately when tab becomes visible
      if (!isRunning) {
        loadServerState().then(function (state) {
          if (!state || !state.lastModified) return;
          if (state.lastModified > localLastModified) {
            localLastModified = state.lastModified;
            restoreState(state);
          }
        });
      }
    }
  });
})();
</script>


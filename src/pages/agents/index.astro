---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Agents - dustinlanders.com" description="Multi-agent chat room.">
  <div id="gate">
    <div class="gate-box">
      <p class="gate-label">This area is private.</p>
      <input type="password" id="gate-password" placeholder="Password" autocomplete="off" />
      <button id="gate-unlock">Unlock</button>
      <p id="gate-error" class="gate-error"></p>
    </div>
  </div>

  <section id="panel" style="display: none;">
    <div class="panel-header">
      <h1>Agents</h1>
      <p class="panel-sub">Configure agents, set the scene, and watch them talk.</p>
    </div>

    <div class="agents-grid" id="agents-grid">
      <div class="agent-card" data-agent="0">
        <div class="agent-card-head">
          <span class="agent-dot" style="background: #e05252;"></span>
          <input type="text" class="agent-name" value="Elena" />
          <button class="remove-btn" title="Remove" style="display:none;">x</button>
        </div>
        <textarea class="agent-prompt" rows="4">You are Elena, a fiercely independent photographer who just got back from six months in Patagonia. You fell for Marcus before you left and assumed he would wait. You are sharp-witted, passionate, and you do not beg. You speak with confidence and a little edge. Keep responses under 150 words.</textarea>
      </div>
      <div class="agent-card" data-agent="1">
        <div class="agent-card-head">
          <span class="agent-dot" style="background: #3b82f6;"></span>
          <input type="text" class="agent-name" value="Marcus" />
          <button class="remove-btn" title="Remove" style="display:none;">x</button>
        </div>
        <textarea class="agent-prompt" rows="4">You are Marcus, an electrician who picks up bar shifts on weekends to pay off his truck. You are not smooth or clever -- you just say what you are thinking, which sometimes makes things worse. You did not plan for any of this. You fidget with a lighter when you are nervous. You speak plainly, sometimes awkwardly, and you stumble over your words when it matters most. Keep responses under 150 words.</textarea>
      </div>
      <div class="agent-card" data-agent="2">
        <div class="agent-card-head">
          <span class="agent-dot" style="background: #22c55e;"></span>
          <input type="text" class="agent-name" value="Diane" />
          <button class="remove-btn" title="Remove" style="display:none;">x</button>
        </div>
        <textarea class="agent-prompt" rows="4">You are Diane, a veterinarian who started seeing Marcus two months ago. You had no idea about Elena until tonight. You are calm, observant, and direct. You do not raise your voice but your words cut deep. You are deciding in real time whether Marcus is worth the trouble. Keep responses under 150 words.</textarea>
      </div>
    </div>

    <button id="add-agent" class="add-agent">+ Add Agent</button>

    <div class="scene-section">
      <label class="field-label" for="scene">Scene</label>
      <textarea id="scene" rows="3">It is 1:47 AM. A rooftop bar in Brooklyn, late September. The city hums below. String lights sway in the wind. Marcus just got off a double shift and came upstairs to find Elena sitting at the bar -- she was not supposed to be back for another month. Diane is already at the corner table with two whiskeys, waiting for him. The bartender pretends not to notice. Someone left a speaker on the ledge playing old soul records. Nobody is leaving until this gets resolved.</textarea>
    </div>

    <div class="prompt-section">
      <label class="field-label" for="opening">Opening prompt</label>
      <input type="text" id="opening" value="Elena locks eyes with Marcus from across the rooftop and says nothing. Diane follows his gaze and sets down her glass." />
    </div>

    <div class="controls">
      <div class="rounds-group">
        <label class="field-label" for="rounds">Rounds</label>
        <input type="number" id="rounds" min="1" max="10" value="2" />
      </div>
      <button id="go-btn">Go</button>
      <button id="clear-btn" class="secondary-btn">Clear</button>
    </div>

    <div id="chat" class="chat">
      <p class="chat-placeholder">Hit Go to start.</p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
(function () {
  var HASH = '48d5e01666b2a0cf736186d47e5e0e56e588fc2fbc24e598b0e849086bbcb846';
  var COLORS = ['#e05252','#3b82f6','#22c55e','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#f97316'];

  async function sha256(s) {
    var b = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(s));
    return Array.from(new Uint8Array(b)).map(function (x) { return x.toString(16).padStart(2,'0'); }).join('');
  }

  // Gate
  if (localStorage.getItem('agents_auth') === 'true') show();

  document.getElementById('gate-unlock').addEventListener('click', async function () {
    var h = await sha256(document.getElementById('gate-password').value);
    if (h === HASH) { localStorage.setItem('agents_auth','true'); show(); }
    else { document.getElementById('gate-error').textContent = 'Nope.'; document.getElementById('gate-password').value = ''; }
  });

  document.getElementById('gate-password').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') document.getElementById('gate-unlock').click();
  });

  function show() {
    document.getElementById('gate').style.display = 'none';
    document.getElementById('panel').style.display = 'block';
  }

  // Add agent
  document.getElementById('add-agent').addEventListener('click', function () {
    var grid = document.getElementById('agents-grid');
    var n = grid.children.length;
    var color = COLORS[n % COLORS.length];
    var card = document.createElement('div');
    card.className = 'agent-card';
    card.setAttribute('data-agent', n);
    card.innerHTML =
      '<div class="agent-card-head">' +
        '<span class="agent-dot" style="background:' + color + ';"></span>' +
        '<input type="text" class="agent-name" value="Agent ' + (n + 1) + '" />' +
        '<button class="remove-btn" title="Remove">x</button>' +
      '</div>' +
      '<textarea class="agent-prompt" rows="4">You are Agent ' + (n + 1) + '. Be direct and concise. Keep responses under 150 words.</textarea>';
    grid.appendChild(card);
    card.querySelector('.remove-btn').addEventListener('click', function () { grid.removeChild(card); });
  });

  // Chat helpers
  function msg(name, color, text, system) {
    var chat = document.getElementById('chat');
    var ph = chat.querySelector('.chat-placeholder');
    if (ph) ph.remove();
    var el = document.createElement('div');
    el.className = 'chat-msg' + (system ? ' chat-sys' : '');
    if (system) { el.textContent = text; }
    else {
      var n = document.createElement('span');
      n.className = 'msg-name';
      n.style.color = color;
      n.textContent = name;
      var t = document.createElement('div');
      t.className = 'msg-text';
      t.textContent = text;
      el.appendChild(n);
      el.appendChild(t);
    }
    chat.appendChild(el);
    chat.scrollTop = chat.scrollHeight;
    return el;
  }

  function typing(name, color) {
    var chat = document.getElementById('chat');
    var ph = chat.querySelector('.chat-placeholder');
    if (ph) ph.remove();
    var el = document.createElement('div');
    el.className = 'chat-msg chat-typing';
    var n = document.createElement('span');
    n.className = 'msg-name';
    n.style.color = color;
    n.textContent = name;
    var d = document.createElement('span');
    d.className = 'dots';
    d.innerHTML = '<span>.</span><span>.</span><span>.</span>';
    el.appendChild(n);
    el.appendChild(d);
    chat.appendChild(el);
    chat.scrollTop = chat.scrollHeight;
    return el;
  }

  async function ask(system, messages) {
    var res = await fetch('/api/agent-chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ system: system, messages: messages, model: 'claude-sonnet-4-20250514' }),
    });
    if (!res.ok) {
      var err = '';
      try { var b = await res.json(); err = b.error || JSON.stringify(b); } catch(e) { try { err = await res.text(); } catch(e2) {} }
      throw new Error('API error (' + res.status + '): ' + (err || 'unknown'));
    }
    var data = await res.json();
    return data.text;
  }

  // Clear
  document.getElementById('clear-btn').addEventListener('click', function () {
    document.getElementById('chat').innerHTML = '<p class="chat-placeholder">Hit Go to start.</p>';
  });

  // Go
  document.getElementById('go-btn').addEventListener('click', async function () {
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Running...';

    var scene = document.getElementById('scene').value.trim();
    var opening = document.getElementById('opening').value.trim();
    var rounds = parseInt(document.getElementById('rounds').value, 10) || 2;

    var agents = [];
    document.querySelectorAll('.agent-card').forEach(function (card, i) {
      var base = card.querySelector('.agent-prompt').value;
      agents.push({
        name: card.querySelector('.agent-name').value.trim() || ('Agent ' + (i + 1)),
        system: scene ? scene + '\n\n' + base : base,
        color: COLORS[i % COLORS.length],
      });
    });

    if (agents.length < 2) { msg('','','Need at least 2 agents.',true); btn.disabled = false; btn.textContent = 'Go'; return; }
    if (!opening) { msg('','','Enter an opening prompt.',true); btn.disabled = false; btn.textContent = 'Go'; return; }

    var histories = {};
    agents.forEach(function (a) { histories[a.name] = []; });

    var lastText = '';
    var lastSpeaker = '';

    msg('','', opening, true);

    try {
      // Seed first agent
      var first = agents[0];
      var t = typing(first.name, first.color);
      histories[first.name].push({ role: 'user', content: opening });
      lastText = await ask(first.system, histories[first.name]);
      histories[first.name].push({ role: 'assistant', content: lastText });
      t.remove();
      msg(first.name, first.color, lastText);
      lastSpeaker = first.name;

      for (var r = 1; r <= rounds; r++) {
        msg('','','Round ' + r, true);
        for (var i = 0; i < agents.length; i++) {
          var a = agents[i];
          if (r === 1 && i === 0) continue;
          var prompt = '[Round ' + r + ' - ' + lastSpeaker + ']: ' + lastText;
          var typ = typing(a.name, a.color);
          histories[a.name].push({ role: 'user', content: prompt });
          lastText = await ask(a.system, histories[a.name]);
          histories[a.name].push({ role: 'assistant', content: lastText });
          typ.remove();
          msg(a.name, a.color, lastText);
          lastSpeaker = a.name;
        }
      }
      msg('','','Done.', true);
    } catch (err) {
      msg('','','Error: ' + err.message, true);
    }

    btn.disabled = false;
    btn.textContent = 'Go';
  });
})();
</script>

<style>
  /* Gate */
  #gate {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 40vh;
  }
  .gate-box { text-align: center; }
  .gate-label { font-size: 0.85rem; color: var(--fg-muted); margin-bottom: 1rem; }
  #gate-password {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    width: 200px;
    outline: none;
  }
  #gate-password:focus { border-color: var(--fg-muted); }
  #gate-unlock {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    cursor: pointer;
    margin-left: 0.5rem;
  }
  #gate-unlock:hover { background: var(--code-bg); }
  .gate-error { font-size: 0.8rem; color: var(--fg-muted); margin-top: 0.75rem; min-height: 1.2em; }

  /* Panel */
  .panel-header h1 { margin-top: 1rem; margin-bottom: 0.25rem; }
  .panel-sub { color: var(--fg-muted); font-size: 0.9rem; margin-bottom: 2rem; }

  .field-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }

  /* Agent cards */
  .agents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .agent-card {
    border: 1px solid var(--border);
    padding: 0.75rem;
  }
  .agent-card-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .agent-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .agent-name {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.2rem 0.4rem;
    border: 1px solid transparent;
    background: transparent;
    color: var(--fg);
    outline: none;
    flex: 1;
    min-width: 0;
  }
  .agent-name:focus { border-color: var(--border); }
  .remove-btn {
    font-size: 0.75rem;
    background: none;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    cursor: pointer;
    padding: 0.1rem 0.4rem;
    line-height: 1;
  }
  .remove-btn:hover { color: #e05252; border-color: #e05252; }
  .agent-prompt {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    resize: vertical;
    outline: none;
    line-height: 1.5;
  }
  .agent-prompt:focus { border-color: var(--fg-muted); }
  .add-agent {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border: 1px dashed var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    margin-bottom: 2rem;
  }
  .add-agent:hover { color: var(--fg); border-color: var(--fg); }

  /* Scene / opening */
  .scene-section { margin-bottom: 1rem; }
  .prompt-section { margin-bottom: 1rem; }

  #scene, #opening {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    outline: none;
    line-height: 1.5;
  }
  #scene:focus, #opening:focus { border-color: var(--fg-muted); }
  #scene { resize: vertical; }

  /* Controls */
  .controls {
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .rounds-group { display: flex; flex-direction: column; }
  #rounds {
    width: 50px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.4rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    text-align: center;
    outline: none;
  }
  #go-btn {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.45rem 1.5rem;
    border: 1px solid var(--fg);
    background: var(--fg);
    color: var(--bg);
    cursor: pointer;
  }
  #go-btn:hover { opacity: 0.85; }
  #go-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .secondary-btn {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
  }
  .secondary-btn:hover { color: var(--fg); }

  /* Chat */
  .chat {
    border: 1px solid var(--border);
    min-height: 300px;
    max-height: 65vh;
    overflow-y: auto;
    padding: 1rem;
    margin-bottom: 2rem;
    background: var(--code-bg);
  }
  .chat-placeholder {
    color: var(--fg-muted);
    font-size: 0.85rem;
    font-style: italic;
    text-align: center;
    padding: 3rem 0;
  }
  .chat-msg { margin-bottom: 1rem; line-height: 1.6; }
  .chat-msg:last-child { margin-bottom: 0; }
  .chat-sys {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    text-align: center;
    padding: 0.5rem 0;
  }
  .msg-name {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 0.2rem;
  }
  .msg-text {
    font-size: 0.9rem;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .chat-typing {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .dots span {
    animation: blink 1.4s infinite both;
    font-size: 1.5rem;
    line-height: 0.5;
    color: var(--fg-muted);
  }
  .dots span:nth-child(2) { animation-delay: 0.2s; }
  .dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink {
    0%, 80%, 100% { opacity: 0.2; }
    40% { opacity: 1; }
  }
  @media (max-width: 600px) {
    .agents-grid { grid-template-columns: 1fr; }
    .controls { flex-wrap: wrap; }
  }
</style>

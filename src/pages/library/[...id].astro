---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const items = (await getCollection('library')).filter(
    (item) => item.data.type !== 'pdf'
  );
  return items.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const isHtml = item.data.type === 'html';
const rendered = !isHtml ? await render(item) : null;
---

{isHtml ? (
  <BaseLayout title={`${item.data.title} · Library`} description={item.data.description}>
    <section class="html-embed">
      <h1>{item.data.title}</h1>
      {item.data.description && <p class="html-embed-desc">{item.data.description}</p>}
      <iframe src={item.data.file} title={item.data.title}></iframe>
    </section>
  </BaseLayout>
) : (
  <PostLayout frontmatter={item.data}>
    {rendered && <rendered.Content />}
  </PostLayout>
)}

<style>
  .html-embed h1 {
    margin-top: 1rem;
  }

  .html-embed-desc {
    color: var(--fg-muted);
    margin-bottom: 1.5rem;
  }

  .html-embed iframe {
    width: 100%;
    min-height: 70vh;
    border: 1px solid var(--border);
  }

  @media (min-width: 768px) {
    .html-embed iframe {
      min-height: 0;
      height: 520px;
    }
  }
</style>

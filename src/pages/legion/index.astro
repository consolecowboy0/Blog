  // --- Chat helpers ---
  var currentRoundDetails = null; // the current <details> for the active round

  function getFirstDialogue(text) {
    // Extract first quoted line for the summary preview
    var m = text.match(/[""\u201C]([^""\u201D]{0,80})/);
    return m ? '\u201C' + m[1] + '\u2026\u201D' : '';
  }

  function renderMath(tex, displayMode, container) {
    if (typeof katex === 'undefined') {
      var fb = document.createElement(displayMode ? 'div' : 'span');
      fb.textContent = (displayMode ? '$$' : '$') + tex + (displayMode ? '$$' : '$');
      container.appendChild(fb);
      return;
    }
    var el = document.createElement(displayMode ? 'div' : 'span');
    if (displayMode) el.style.margin = '0.5em 0';
    try {
      katex.render(tex, el, { displayMode: displayMode, throwOnError: false });
    } catch(e) {
      el.textContent = (displayMode ? '$$' : '$') + tex + (displayMode ? '$$' : '$');
    }
    container.appendChild(el);
  }

  function renderInlineSegment(text, container) {
    // Handle inline math $...$  (not preceded/followed by $)
    var parts = text.split(/(\$(?!\$)(?:[^$]|\\.)+?\$)/g);
    parts.forEach(function(part) {
      var m = part.match(/^\$(?!\$)((?:[^$]|\\.)+?)\$$/);
      if (m) {
        renderMath(m[1], false, container);
      } else if (part) {
        container.appendChild(document.createTextNode(part));
      }
    });
  }

  function renderTextContent(text, container) {
    // Split out [CODE]...[/CODE] blocks first, then $$...$$ display math, then inline
    var codeSplit = text.split(/(\[CODE\][\s\S]*?\[\/CODE\])/g);
    codeSplit.forEach(function (segment) {
      var codeMatch = segment.match(/^\[CODE\]([\s\S]*?)\[\/CODE\]$/);
      if (codeMatch) {
        var codeBlock = document.createElement('div');
        codeBlock.className = 'msg-code-block';
        var codeLabel = document.createElement('span');
        codeLabel.className = 'code-label';
        codeLabel.textContent = 'Python';
        codeBlock.appendChild(codeLabel);
        var pre = document.createElement('pre');
        var codeEl = document.createElement('code');
        codeEl.textContent = codeMatch[1].trim();
        pre.appendChild(codeEl);
        codeBlock.appendChild(pre);
        var outputDiv = document.createElement('div');
        outputDiv.className = 'code-output';
        outputDiv.style.display = 'none';
        codeBlock.appendChild(outputDiv);
        container.appendChild(codeBlock);
        (function (code, out) {
          runCodeBlock(code, out);
        })(codeMatch[1].trim(), outputDiv);
        return;
      }
      // Split on $$...$$ display math blocks
      var mathSplit = segment.split(/(\$\$[\s\S]*?\$\$)/g);
      mathSplit.forEach(function(mathSeg) {
        var dispMatch = mathSeg.match(/^\$\$([\s\S]*?)\$\$$/);
        if (dispMatch) {
          renderMath(dispMatch[1].trim(), true, container);
          return;
        }
        var parts = mathSeg.split(/(\[ACTION:[^\]]*\]|\[WHISPER\s+to\s+[^:\]]+:\s*[^\]]*\])/g);
        parts.forEach(function (part) {
          var actionMatch = part.match(/^\[ACTION:\s*(.*)\]$/);
          var whisperMatch = part.match(/^\[WHISPER\s+to\s+([^:\]]+):\s*(.*)\]$/);
          if (actionMatch) {
            var act = document.createElement('span');
            act.className = 'msg-action';
            act.textContent = '[ACTION: ' + actionMatch[1] + ']';
            container.appendChild(act);
          } else if (whisperMatch) {
            var w = document.createElement('span');
            w.className = 'msg-whisper';
            w.textContent = '\u{1F5E3} whispers to ' + whisperMatch[1].trim() + ': ' + whisperMatch[2];
            container.appendChild(w);
          } else if (part) {
            var dialogParts = part.split(/(?<=["\u201D])\s+(?=["\u201C])/g);
            dialogParts.forEach(function (dp) {
              if (!dp.trim()) return;
              var p = document.createElement('p');
              p.className = 'msg-dialogue';
              renderInlineSegment(dp, p);
              container.appendChild(p);
            });
          }
        });
      });
    });
  }

  function msg(name, color, text, system) {
    var chat = document.getElementById('chat');
    var ph = chat.querySelector('.chat-placeholder');
    if (ph) ph.remove();

    // Round headers become collapsible groups
    var roundMatch = system && text.match(/^--- Round (\d+) ---$/);
    if (roundMatch) {
      var details = document.createElement('details');
      details.className = 'round-group';
      var summary = document.createElement('summary');
      summary.className = 'round-header';
      summary.textContent = 'Round ' + roundMatch[1];
      details.appendChild(summary);
      chat.appendChild(details);
      currentRoundDetails = details;
      chat.scrollTop = chat.scrollHeight;
      return details;
    }

    // Bidding headers
    var bidMatch = system && text.match(/^--- Bidding for Round (\d+) ---$/);
    if (bidMatch) {
      var bidDetails = document.createElement('details');
      bidDetails.className = 'bid-group';
      var bidSummary = document.createElement('summary');
      bidSummary.className = 'bid-header';
      bidSummary.textContent = 'Bids for Round ' + bidMatch[1];
      bidDetails.appendChild(bidSummary);
      var target = currentRoundDetails || chat;
      target.appendChild(bidDetails);
      chat.scrollTop = chat.scrollHeight;
      return bidDetails;
    }

    // System messages
    if (system) {
      var el = document.createElement('div');
      el.className = 'chat-msg chat-sys';
      el.textContent = text;
      var target = currentRoundDetails || chat;
      target.appendChild(el);
      chat.scrollTop = chat.scrollHeight;
      return el;
    }

    // Character messages - collapsible with preview
    var details = document.createElement('details');
    details.className = 'chat-msg';
    details.style.borderLeftColor = color;
    var summary = document.createElement('summary');
    summary.className = 'msg-summary';
    var headshotUrl = getHeadshot(name);
    if (headshotUrl) {
      var img = document.createElement('img');
      img.className = 'msg-headshot';
      img.src = headshotUrl;
      img.alt = '';
      img.onerror = function () { img.style.display = 'none'; };
      summary.appendChild(img);
    }
    var nameSpan = document.createElement('span');
    nameSpan.className = 'msg-name';
    nameSpan.style.color = color;
    nameSpan.textContent = name;
    summary.appendChild(nameSpan);
    var preview = getFirstDialogue(text);
    if (preview) {
      var previewSpan = document.createElement('span');
      previewSpan.className = 'msg-preview';
      previewSpan.textContent = preview;
      summary.appendChild(previewSpan);
    }
    details.appendChild(summary);
    var t = document.createElement('div');
    t.className = 'msg-text';
    renderTextContent(text, t);
    var collapseBtn = document.createElement('button');
    collapseBtn.className = 'msg-collapse-btn';
    collapseBtn.textContent = '▲ collapse';
    collapseBtn.addEventListener('click', function () {
      details.open = false;
      details.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
    t.appendChild(collapseBtn);
    details.appendChild(t);

    var target = currentRoundDetails || chat;
    target.appendChild(details);
    chat.scrollTop = chat.scrollHeight;
    return details;
  }

  // Collapsible system message (prompts, interjections, transcripts)
  function sysMsg(text, label) {
    var chat = document.getElementById('chat');
    var ph = chat.querySelector('.chat-placeholder');
    if (ph) ph.remove();
    var details = document.createElement('details');
    details.className = 'chat-msg chat-sys-collapsible';
    var summary = document.createElement('summary');
    summary.className = 'chat-sys-summary';
    var tag = document.createElement('span');
    tag.className = 'chat-sys-tag';
    tag.textContent = label || 'Prompt';
    summary.appendChild(tag);
    var preview = document.createElement('span');
    preview.className = 'chat-sys-preview';
    var firstLine = text.replace(/\s+/g, ' ').trim();
    if (firstLine.length > 120) firstLine = firstLine.substring(0, 120) + '...';
    preview.textContent = firstLine;
    summary.appendChild(preview);
    details.appendChild(summary);
    var body = document.createElement('div');
    body.className = 'chat-sys-body';
    body.textContent = text;
    details.appendChild(body);
    var target = currentRoundDetails || chat;
    target.appendChild(details);
    chat.scrollTop = chat.scrollHeight;
    return details;
  }

  // Queue for code results to append to worldState/transcript
  var pendingCodeResults = [];

  async function runCodeBlock(code, outputDiv) {
    outputDiv.style.display = '';
    outputDiv.innerHTML = '<span class="code-running">Running...</span>';
    try {
      var result = await runPythonCode(code);
      outputDiv.innerHTML = '';
      if (result.error) {
        var errEl = document.createElement('pre');
        errEl.className = 'code-error';
        errEl.textContent = result.error;
        outputDiv.appendChild(errEl);
        pendingCodeResults.push('[CODE_ERROR]: ' + result.error);
      } else {
        if (result.stdout && result.stdout.trim()) {
          var outPre = document.createElement('pre');
          outPre.className = 'code-stdout';
          outPre.textContent = result.stdout;
          outputDiv.appendChild(outPre);
          pendingCodeResults.push('[CODE_RESULT]: ' + result.stdout.trim());
        }
        result.figures.forEach(function (b64) {
          var img = document.createElement('img');
          img.src = 'data:image/png;base64,' + b64;
          img.className = 'code-figure';
          outputDiv.appendChild(img);
          pendingCodeResults.push('[CODE_FIGURE]:data:image/png;base64,' + b64);
        });
        if (!result.stdout.trim() && result.figures.length === 0) {
          var noneEl = document.createElement('span');
          noneEl.className = 'code-no-output';
          noneEl.textContent = '(no output)';
          outputDiv.appendChild(noneEl);
        }
      }
    } catch (e) {
      outputDiv.innerHTML = '';
      var errEl = document.createElement('pre');
      errEl.className = 'code-error';
      errEl.textContent = e.message;
      outputDiv.appendChild(errEl);
      pendingCodeResults.push('[CODE_ERROR]: ' + e.message);
    }
    var chat = document.getElementById('chat');
    chat.scrollTop = chat.scrollHeight;
  }

  function typing(name, color) {
    var chat = document.getElementById('chat');
    var ph = chat.querySelector('.chat-placeholder');
    if (ph) ph.remove();
    var el = document.createElement('div');
    el.className = 'chat-msg chat-typing';
    var headshotUrl = getHeadshot(name);
    if (headshotUrl) {
      var img = document.createElement('img');
      img.className = 'msg-headshot';
      img.src = headshotUrl;
      img.alt = '';
      img.onerror = function () { img.style.display = 'none'; };
      el.appendChild(img);
    }
    var n = document.createElement('span');
    n.className = 'msg-name';
    n.style.color = color;
    n.textContent = name;
    var d = document.createElement('span');
    d.className = 'dots';
    d.innerHTML = '<span>.</span><span>.</span><span>.</span>';
    el.appendChild(n);
    el.appendChild(d);
    chat.appendChild(el);
    chat.scrollTop = chat.scrollHeight;
    return el;
  }

  async function ask(system, messages, agentConfig) {
    var model = getModel();
    var payload = { system: system, messages: messages, model: model };
    if (agentConfig) payload.agentConfig = agentConfig;
    var headers = { 'Content-Type': 'application/json' };
    if (authToken) headers['Authorization'] = 'Bearer ' + authToken;
    var res = await fetch(API_BASE + '/api/agent-sdk-chat', {
      method: 'POST',
      headers: headers,
      body: JSON.stringify(payload),
    });
    if (!res.ok) {
      var err = '';
      try { var b = await res.json(); err = b.error || JSON.stringify(b); } catch(e) { try { err = await res.text(); } catch(e2) {} }
      throw new Error('Agent SDK error (' + res.status + '): ' + (err || 'unknown'));
    }
    var data = await res.json();
    return data.text;
  }

  // Direct API call used for bids — uses same endpoint as regular messages.
  async function askDirect(system, messages) {
    return ask(system, messages);
  }

  // --- Session state ---
  var sessionTranscript = [];
  var sessionAgents = null;
  var sessionRun = 0;
  var stopRequested = false;
  var worldState = [];
  var characterStatus = {}; // name -> { status: 'present'|'dead'|'left', round: number }
  var roomStatus = { name: '', status: 'alive', round: 0 };

  // --- Server state persistence ---
  var saveTimer = null;
  var localLastModified = 0;
  var isRunning = false;
  var pollInterval = null;

  function saveState() {
    if (saveTimer) clearTimeout(saveTimer);
    saveTimer = setTimeout(function () {
      var chars = [];
      var gridId = activeTab === 'analysts' ? '#analysts-grid' : '#legion-grid';
      document.querySelectorAll(gridId + ' .agent-card').forEach(function (card) {
        if (card._charData) chars.push(card._charData);
      });
      var now = Date.now();
      localLastModified = now;
      var state = {
        sessionTranscript: sessionTranscript,
        sessionAgents: sessionAgents,
        sessionRun: sessionRun,
        worldState: worldState,
        characterStatus: characterStatus,
        roomStatus: roomStatus,
        lastModified: now,
        opening: getOpening(),
        config: {
          room: roomData,
          relationships: relsData,
          characters: chars,
          model: getModel(),
          orderMode: getOrderMode(),
          rounds: getRounds(),
        },
      };
      var headers = { 'Content-Type': 'application/json' };
      if (authToken) headers['Authorization'] = 'Bearer ' + authToken;
      fetch('/api/legion-state', {
        method: 'PUT',
        headers: headers,
        body: JSON.stringify(state),
      }).catch(function (e) { console.warn('[legion] save failed:', e); });
    }, 500);
  }

  function clearServerState() {
    var headers = {};
    if (authToken) headers['Authorization'] = 'Bearer ' + authToken;
    fetch('/api/legion-state', {
      method: 'DELETE',
      headers: headers,
    }).catch(function (e) { console.warn('[legion] clear failed:', e); });
  }

  function loadServerState() {
    var headers = {};
    if (authToken) headers['Authorization'] = 'Bearer ' + authToken;
    return fetch('/api/legion-state', {
      method: 'GET',
      headers: headers,
    }).then(function (res) {
      if (!res.ok) return null;
      return res.json();
    }).catch(function () { return null; });
  }

  function restoreState(state) {
    if (!state || !state.sessionTranscript || state.sessionTranscript.length === 0) return;

    // Restore config first
    if (state.config) {
      if (state.config.room) roomData = state.config.room;
      if (state.config.relationships) relsData = state.config.relationships;
      if (state.config.model) document.getElementById('model-select').value = state.config.model;
      if (state.config.orderMode) document.getElementById('order-mode').value = state.config.orderMode;
      if (state.config.rounds) document.getElementById('rounds').value = state.config.rounds;
    }
    if (state.opening) document.getElementById('opening').value = state.opening;

    // Restore session variables
    sessionTranscript = state.sessionTranscript || [];
    sessionAgents = state.sessionAgents || null;
    sessionRun = state.sessionRun || 0;
    worldState = state.worldState || [];
    characterStatus = state.characterStatus || {};
    roomStatus = state.roomStatus || { name: '', status: 'alive', round: 0 };

    // Re-render chat
    var chat = document.getElementById('chat');
    chat.innerHTML = '';
    currentRoundDetails = null;
    var lastRound = 0;

    // Show opening prompt
    if (state.opening) sysMsg(state.opening, 'Prompt');

    sessionTranscript.forEach(function (entry) {
      // Insert round header when round changes
      if (entry.round && entry.round !== lastRound) {
        lastRound = entry.round;
        msg('', '', '--- Round ' + entry.round + ' ---', true);
      }
      if (entry.name === 'Status') {
        msg('', '', entry.text, true);
      } else if (entry.name === 'Narrator') {
        sysMsg(entry.text, 'Interjection');
      } else {
        // Find color for this agent
        var color = '#999';
        if (sessionAgents) {
          for (var i = 0; i < sessionAgents.length; i++) {
            if (sessionAgents[i].name === entry.name) { color = sessionAgents[i].color; break; }
          }
        }
        if (entry.text === '...') {
          msg(entry.name, color, '...', false);
        } else {
          msg(entry.name, color, entry.rawText || entry.text, false);
        }
      }
    });

    // Restore status panel
    renderStatus();

    // Show controls
    if (sessionTranscript.length > 0) {
      document.getElementById('export-btn').style.display = '';
      document.getElementById('interject-section').style.display = '';
      document.getElementById('move-room-btn').style.display = '';
      document.getElementById('add-char-btn').style.display = '';
    }
  }

  function initStatus(agents) {
    characterStatus = {};
    agents.forEach(function (a) {
      if (a.name !== 'The Room') {
        characterStatus[a.name] = { status: 'present', round: 0 };
      }
    });
    roomStatus = { name: roomData ? (roomData.name || 'The Room') : 'The Room', status: 'alive', round: 0 };
    renderStatus();
  }

  function markStatus(name, status, round) {
    if (characterStatus[name]) {
      characterStatus[name] = { status: status, round: round };
    }
    renderStatus();
  }

  function renderStatus() {
    var panel = document.getElementById('status-panel');
    var list = document.getElementById('status-list');
    var names = Object.keys(characterStatus);
    if (names.length === 0) { panel.style.display = 'none'; return; }
    panel.style.display = '';
    list.innerHTML = '';
    // Room entry
    var roomEl = document.createElement('span');
    roomEl.className = 'status-entry status-room';
    if (roomStatus.status === 'dead') roomEl.className += ' status-dead';
    var roomDot = roomStatus.status === 'alive' ? '\u25A0' : '\u2620';
    roomEl.textContent = roomDot + ' ' + roomStatus.name;
    if (roomStatus.status === 'dead') {
      var roomSub = document.createElement('span');
      roomSub.className = 'status-detail';
      roomSub.textContent = ' (dead, r' + roomStatus.round + ')';
      roomEl.appendChild(roomSub);
    }
    list.appendChild(roomEl);
    // Character entries
    names.forEach(function (name) {
      var entry = characterStatus[name];
      var el = document.createElement('span');
      el.className = 'status-entry';
      if (entry.status === 'dead') el.className += ' status-dead';
      if (entry.status === 'left') el.className += ' status-left';
      var dot = entry.status === 'present' ? '\u25CF' : entry.status === 'dead' ? '\u2620' : '\u2192';
      el.textContent = dot + ' ' + name;
      if (entry.status !== 'present') {
        var sub = document.createElement('span');
        sub.className = 'status-detail';
        sub.textContent = entry.status === 'dead' ? ' (dead, r' + entry.round + ')' : ' (left, r' + entry.round + ')';
        el.appendChild(sub);
      }
      list.appendChild(el);
    });
  }

  function getStatusSummary() {
    var lines = [];
    Object.keys(characterStatus).forEach(function (name) {
      var s = characterStatus[name];
      if (s.status === 'dead') lines.push(name + ' is dead (died in round ' + s.round + ').');
      if (s.status === 'left') lines.push(name + ' has left the room (left in round ' + s.round + ').');
    });
    return lines.join('\n');
  }

  function detectStatusChanges(speakerName, text, round) {
    var changes = [];
    var already = {};
    function add(name, status) {
      if (already[name]) return;
      if (!characterStatus[name] || characterStatus[name].status !== 'present') return;
      already[name] = true;
      changes.push({ name: name, status: status });
    }

    // Exact tags: [DEAD: Name], [DIES], [LEAVES: Name], [LEAVES]
    var m;
    var deadTag = /\[DEAD:\s*([^\]]+)\]/gi;
    while ((m = deadTag.exec(text)) !== null) add(m[1].trim(), 'dead');

    var leavesTag = /\[LEAVES:\s*([^\]]+)\]/gi;
    while ((m = leavesTag.exec(text)) !== null) {
      var t = m[1].trim();
      if (t !== speakerName) add(t, 'left');
    }

    if (/\[DIES\]/i.test(text)) add(speakerName, 'dead');
    if (/\[LEAVES\](?!\s*:)/i.test(text)) add(speakerName, 'left');

    // Natural language fallbacks: match known character names
    var lower = text.toLowerCase();
    var presentNames = Object.keys(characterStatus).filter(function (n) {
      return characterStatus[n].status === 'present';
    });

    presentNames.forEach(function (name) {
      var n = name.toLowerCase();
      // "kills Name", "shoots Name dead", "stabs Name", "Name is dead", "Name dies", "Name collapses dead"
      var deathPatterns = [
        new RegExp('\\bkills\\s+' + n + '\\b', 'i'),
        new RegExp('\\bkill\\s+' + n + '\\b', 'i'),
        new RegExp('\\bstabs\\s+' + n + '\\b', 'i'),
        new RegExp('\\bshoots\\s+' + n + '\\b', 'i'),
        new RegExp('\\bmurders\\s+' + n + '\\b', 'i'),
        new RegExp('\\b' + n + '\\s+(is\\s+)?dead\\b', 'i'),
        new RegExp('\\b' + n + '\\s+dies\\b', 'i'),
        new RegExp('\\b' + n + '\\s+collapses\\s+dead\\b', 'i'),
        new RegExp('\\[ACTION:[^\\]]*kills\\s+' + n + '[^\\]]*\\]', 'i'),
        new RegExp('\\[ACTION:[^\\]]*stabs\\s+' + n + '[^\\]]*\\]', 'i'),
        new RegExp('\\[ACTION:[^\\]]*shoots\\s+' + n + '[^\\]]*\\]', 'i'),
      ];
      for (var i = 0; i < deathPatterns.length; i++) {
        if (deathPatterns[i].test(text)) { add(name, 'dead'); break; }
      }

      // "Name leaves", "Name walks out", "Name exits"
      var leavePatterns = [
        new RegExp('\\b' + n + '\\s+leaves\\b', 'i'),
        new RegExp('\\b' + n + '\\s+exits\\b', 'i'),
        new RegExp('\\b' + n + '\\s+walks\\s+out\\b', 'i'),
        new RegExp('\\b' + n + '\\s+storms\\s+out\\b', 'i'),
        new RegExp('\\[ACTION:[^\\]]*' + n + '[^\\]]*leaves[^\\]]*\\]', 'i'),
        new RegExp('\\[ACTION:[^\\]]*' + n + '[^\\]]*exits[^\\]]*\\]', 'i'),
      ];
      if (name !== speakerName) {
        for (var i = 0; i < leavePatterns.length; i++) {
          if (leavePatterns[i].test(text)) { add(name, 'left'); break; }
        }
      }
    });

    // Self-death/leave via natural language
    var selfDeathWords = /\b(i\s+die|i'm\s+dying|i\s+am\s+dead)\b/i;
    if (selfDeathWords.test(text)) add(speakerName, 'dead');

    var selfLeaveWords = /\[ACTION:[^\]]*leaves\s+(the\s+)?room[^\]]*\]/i;
    if (selfLeaveWords.test(text)) add(speakerName, 'left');

    changes.forEach(function (c) {
      markStatus(c.name, c.status, round);
      var label = c.status === 'dead' ? ' has died.' : ' has left the room.';
      worldState.push(c.name + label);
      msg('', '', c.name + label, true);
      sessionTranscript.push({ name: 'Status', text: c.name + label, round: round });
    });

    return changes;
  }

  function isActive(name) {
    if (!characterStatus[name]) return true; // The Room etc.
    return characterStatus[name].status === 'present';
  }

  document.getElementById('stop-btn').addEventListener('click', function () {
    stopRequested = true;
    if (delayCancelFn) { delayCancelFn(); delayCancelFn = null; }
  });

  function archiveCurrentSession() {
    if (!sessionTranscript || sessionTranscript.length === 0) return Promise.resolve();
    var headers = { 'Content-Type': 'application/json' };
    if (authToken) headers['Authorization'] = 'Bearer ' + authToken;
    var body = {
      sessionTranscript: sessionTranscript,
      sessionAgents: sessionAgents,
      sessionRun: sessionRun,
      worldState: worldState,
      characterStatus: characterStatus,
      roomStatus: roomStatus,
      opening: getOpening(),
      lastModified: Date.now(),
    };
    return fetch(API_BASE + '/api/legion-history', {
      method: 'POST',
      headers: headers,
      body: JSON.stringify(body),
    }).catch(function (e) { console.warn('[legion] archive failed:', e); });
  }

  document.getElementById('clear-btn').addEventListener('click', function () {
    stopRequested = true;
    if (delayCancelFn) { delayCancelFn(); delayCancelFn = null; }
    archiveCurrentSession();
    clearServerState();
    document.getElementById('chat').innerHTML = '<p class="chat-placeholder">Hit Go to start.</p>';
    document.getElementById('export-btn').style.display = 'none';
    document.getElementById('interject-section').style.display = 'none';
    sessionTranscript = [];
    sessionAgents = null;
    sessionRun = 0;
    currentRoundDetails = null;
    worldState = [];
    characterStatus = {};
    roomStatus = { name: '', status: 'alive', round: 0 };
    document.getElementById('status-panel').style.display = 'none';
    document.getElementById('status-list').innerHTML = '';
    document.getElementById('move-room-btn').style.display = 'none';
    document.getElementById('add-char-btn').style.display = 'none';
  });

  // Copy buttons
  function flashCopyBtn(btn) {
    // Swap to checkmark SVG
    var original = btn.innerHTML;
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
    btn.classList.add('copied');
    setTimeout(function () { btn.innerHTML = original; btn.classList.remove('copied'); }, 1500);
  }

  document.getElementById('copy-chat').addEventListener('click', function () {
    var chat = document.getElementById('chat');
    var msgs = chat.querySelectorAll('.chat-msg');
    var lines = [];
    msgs.forEach(function (m) {
      var name = m.querySelector('.msg-name');
      var txt = m.querySelector('.msg-text');
      if (name && txt) { lines.push(name.textContent + ': ' + txt.textContent); }
      else { lines.push(m.textContent); }
    });
    if (lines.length) { navigator.clipboard.writeText(lines.join('\n\n')); flashCopyBtn(this); }
  });

  document.getElementById('fullscreen-chat').addEventListener('click', function () {
    var wrap = document.getElementById('chat-wrapper');
    var on = wrap.classList.toggle('fullscreen');
    document.body.classList.toggle('chat-fullscreen-lock', on);
    var expand = this.querySelector('.icon-expand');
    var collapse = this.querySelector('.icon-collapse');
    if (expand) expand.style.display = on ? 'none' : '';
    if (collapse) collapse.style.display = on ? '' : 'none';
    this.title = on ? 'Exit fullscreen' : 'Fullscreen';
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      var wrap = document.getElementById('chat-wrapper');
      if (wrap && wrap.classList.contains('fullscreen')) {
        document.getElementById('fullscreen-chat').click();
      }
    }
  });

  // Interject
  document.getElementById('interject-btn').addEventListener('click', function () {
    var input = document.getElementById('interject-input');
    var text = input.value.trim();
    if (!text) return;
    sysMsg(text, 'Interjection');
    sessionTranscript.push({ name: 'Narrator', text: text, round: sessionRun });
    worldState.push('Narrator: ' + text);
    saveState();
    input.value = '';
  });
  document.getElementById('interject-input').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') document.getElementById('interject-btn').click();
  });

  // --- Move Room ---
  function applyRoomChange(data) {
    roomData = data;
    var newScene = jsonToPrompt(data);
    var roomName = data.name || 'a new location';

    sessionAgents.forEach(function (a) {
      if (a.name === 'The Room') {
        a.system = 'You are The Room -- the environment itself. You are not a person. You provide brief atmospheric color: a sound, a shift in light, the weather changing, a song ending, a glass breaking somewhere. One sentence max. Mostly respond with [silence]. Only speak when something in the environment would naturally change or react to what is happening. Never speak for the characters. Never narrate their actions or emotions.\n\nSetting:\n' + newScene;
      } else {
        a.system = a.system.replace(/Setting:\n[\s\S]*?\n\nYour character:/, 'Setting:\n' + newScene + '\n\nYour character:');
      }
    });

    var hasRoom = sessionAgents.some(function (a) { return a.name === 'The Room'; });
    if (!hasRoom) {
      sessionAgents.push({
        name: 'The Room',
        system: 'You are The Room -- the environment itself. You are not a person. You provide brief atmospheric color: a sound, a shift in light, the weather changing, a song ending, a glass breaking somewhere. One sentence max. Mostly respond with [silence]. Only speak when something in the environment would naturally change or react to what is happening. Never speak for the characters. Never narrate their actions or emotions.\n\nSetting:\n' + newScene,
        color: '#666666',
      });
    }

    var moveMsg = 'The scene moves to ' + roomName + '.';
    msg('', '', moveMsg, true);
    sessionTranscript.push({ name: 'Narrator', text: moveMsg, round: sessionRun });
    worldState.push(moveMsg);

    roomStatus = { name: roomName, status: 'alive', round: sessionRun };
    renderStatus();
    var btn = document.getElementById('move-room-btn');
    btn.textContent = 'Moved!';
    setTimeout(function () { btn.textContent = 'Move Room'; }, 1500);
  }

  document.getElementById('move-room-btn').addEventListener('click', function () {
    if (!sessionAgents) return;
    var modal = document.getElementById('move-room-modal');
    var roster = document.getElementById('move-room-roster');
    roster.innerHTML = '';

    var currentRoomName = roomStatus.name || '';
    var rooms = activeTab === 'analysts' ? analystRoomsData : legionRoomsData;
    rooms.forEach(function (room) {
      if (room.label === currentRoomName) return;
      var opt = document.createElement('div');
      opt.className = 'add-char-option';
      opt.innerHTML =
        '<div>' +
          '<div class="add-char-option-name">' + esc(room.label) + '</div>' +
          '<div class="add-char-option-desc">' + esc(room.data.location.split('.')[0]) + '</div>' +
        '</div>';
      opt.addEventListener('click', function () {
        applyRoomChange(room.data);
        modal.style.display = 'none';
      });
      roster.appendChild(opt);
    });

    modal.style.display = '';
  });

  document.getElementById('move-room-modal-close').addEventListener('click', function () {
    document.getElementById('move-room-modal').style.display = 'none';
  });

  document.getElementById('move-room-modal').addEventListener('click', function (e) {
    if (e.target === this) this.style.display = 'none';
  });

  document.getElementById('move-room-upload').addEventListener('click', function () {
    pickFile(false, function (data) {
      applyRoomChange(data);
      document.getElementById('move-room-modal').style.display = 'none';
    });
  });

  // --- History modal ---
  function openHistoryModal() {
    var modal = document.getElementById('history-modal');
    var list = document.getElementById('history-list');
    list.innerHTML = '<p class="history-loading">Loading...</p>';
    modal.style.display = '';
    var headers = {};
    if (authToken) headers['Authorization'] = 'Bearer ' + authToken;
    fetch(API_BASE + '/api/legion-history', { headers: headers })
      .then(function (res) {
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      })
      .then(function (data) {
        list.innerHTML = '';
        if (!data.items || data.items.length === 0) {
          list.innerHTML = '<p class="history-loading">No past sessions yet. Sessions archive when you Clear a running session.</p>';
          return;
        }
        data.items.forEach(function (item) {
          list.appendChild(renderHistoryItem(item));
        });
      })
      .catch(function (e) {
        list.innerHTML = '<p class="history-loading">Error: ' + esc(e.message) + '</p>';
      });
  }

  function renderHistoryItem(item) {
    var date = new Date(item.savedAt);
    var dateStr = date.toLocaleString(undefined, {
      month: 'short', day: 'numeric', year: 'numeric',
      hour: 'numeric', minute: '2-digit'
    });
    var details = document.createElement('details');
    details.className = 'history-item';

    var summary = document.createElement('summary');
    summary.className = 'history-item-summary';
    var top = document.createElement('div');
    top.className = 'history-item-top';
    var dateEl = document.createElement('span');
    dateEl.className = 'history-item-date';
    dateEl.textContent = dateStr;
    var statsEl = document.createElement('span');
    statsEl.className = 'history-item-stats';
    statsEl.textContent = item.rounds + ' rounds \u00B7 ' + item.turnCount + ' turns';
    top.appendChild(dateEl);
    top.appendChild(statsEl);
    summary.appendChild(top);

    var openingPreview = (item.opening || '').replace(/\s+/g, ' ').trim();
    if (openingPreview.length > 140) openingPreview = openingPreview.substring(0, 140) + '...';
    if (openingPreview) {
      var preview = document.createElement('div');
      preview.className = 'history-item-preview';
      preview.textContent = openingPreview;
      summary.appendChild(preview);
    }
    if (item.agentNames && item.agentNames.length) {
      var agents = document.createElement('div');
      agents.className = 'history-item-agents';
      agents.textContent = item.agentNames.join(', ');
      summary.appendChild(agents);
    }
    details.appendChild(summary);

    var body = document.createElement('div');
    body.className = 'history-item-body';
    var loadingEl = document.createElement('p');
    loadingEl.className = 'history-loading';
    loadingEl.textContent = 'Loading transcript...';
    body.appendChild(loadingEl);
    details.appendChild(body);

    var loaded = false;
    details.addEventListener('toggle', function () {
      if (!details.open || loaded) return;
      loaded = true;
      var headers = {};
      if (authToken) headers['Authorization'] = 'Bearer ' + authToken;
      fetch(API_BASE + '/api/legion-history?id=' + encodeURIComponent(item.id), { headers: headers })
        .then(function (res) { return res.json(); })
        .then(function (data) {
          body.innerHTML = '';
          if (!data) { body.textContent = 'Session not found.'; return; }

          if (data.opening) {
            var opBlock = document.createElement('div');
            opBlock.className = 'history-opening';
            opBlock.textContent = data.opening;
            body.appendChild(opBlock);
          }

          var transcript = document.createElement('div');
          transcript.className = 'history-transcript';
          var currentRound = 0;
          (data.sessionTranscript || []).forEach(function (entry) {
            if (entry.round && entry.round !== currentRound) {
              currentRound = entry.round;
              var roundEl = document.createElement('div');
              roundEl.className = 'history-round';
              roundEl.textContent = '--- Round ' + currentRound + ' ---';
              transcript.appendChild(roundEl);
            }
            var line = document.createElement('div');
            line.className = 'history-line';
            var nameEl = document.createElement('strong');
            nameEl.textContent = entry.name + ': ';
            line.appendChild(nameEl);
            line.appendChild(document.createTextNode(entry.rawText || entry.text));
            transcript.appendChild(line);
          });
          body.appendChild(transcript);

          var controls = document.createElement('div');
          controls.className = 'history-item-controls';

          var exportBtn = document.createElement('button');
          exportBtn.className = 'secondary-btn';
          exportBtn.textContent = 'Export';
          exportBtn.addEventListener('click', function () {
            downloadMarkdown(data, 'transcript_' + item.id + '.md');
          });
          controls.appendChild(exportBtn);

          var deleteBtn = document.createElement('button');
          deleteBtn.className = 'secondary-btn';
          deleteBtn.textContent = 'Delete';
          deleteBtn.addEventListener('click', function () {
            if (!confirm('Delete this archived session?')) return;
            var dh = {};
            if (authToken) dh['Authorization'] = 'Bearer ' + authToken;
            fetch(API_BASE + '/api/legion-history?id=' + encodeURIComponent(item.id), {
              method: 'DELETE',
              headers: dh,
            }).then(function () { details.remove(); });
          });
          controls.appendChild(deleteBtn);

          body.appendChild(controls);
        })
        .catch(function (e) {
          body.innerHTML = '';
          var err = document.createElement('p');
          err.className = 'history-loading';
          err.textContent = 'Error: ' + e.message;
          body.appendChild(err);
        });
    });
    return details;
  }


      if (sessionAgents.length < 2) { msg('','','Need at least 2 agents.',true); btn.disabled = false; btn.textContent = 'Go'; document.getElementById('stop-btn').style.display = 'none'; sessionAgents = null; return; }
      if (!opening) { msg('','','Enter an opening prompt.',true); btn.disabled = false; btn.textContent = 'Go'; document.getElementById('stop-btn').style.display = 'none'; sessionAgents = null; return; }

      initStatus(sessionAgents);
    }

    var agents = sessionAgents;

    function extractActions(name, text) {
      var actions = [];
      text.replace(/\[ACTION:\s*([^\]]*)\]/g, function (m, desc) {
        actions.push(name + ': ' + desc);
      });
      return actions;
    }

    function extractWhisperTargets(text) {
      var targets = [];
      text.replace(/\[WHISPER\s+to\s+([^:\]]+):/g, function (m, name) {
        targets.push(name.trim());
      });
      return targets;
    }

    function stripWhispersFrom(text, agentName, speakerName) {
      // Remove whisper tags not intended for agentName (and not from agentName)
      return text.replace(/\[WHISPER\s+to\s+([^:\]]+):\s*([^\]]*)\]/g, function (match, target) {
        target = target.trim();
        if (target === agentName || speakerName === agentName) {

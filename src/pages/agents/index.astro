  }
  .add-agent:hover { color: var(--fg); border-color: var(--fg); }

  /* Upload */
  .upload-section { margin-bottom: 1.5rem; }
  .upload-row { display: flex; align-items: center; gap: 0.75rem; }
  .upload-btn {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
  }
  .upload-btn:hover { color: var(--fg); border-color: var(--fg); }
  .clear-upload-btn {
    font-family: var(--font-body);
    font-size: 0.7rem;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
  }
  .clear-upload-btn:hover { color: #e05252; border-color: #e05252; }
  .upload-status {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-muted);
  }

  /* Opening */
  .prompt-section { margin-bottom: 1rem; }
  #opening {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    outline: none;

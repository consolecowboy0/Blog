---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Agent Panel - dustinlanders.com" description="Multi-agent chat room.">
  <div id="gate">
    <div class="gate-box">
      <p class="gate-label">This area is private.</p>
      <input type="password" id="gate-password" placeholder="Password" autocomplete="off" />
      <button id="gate-unlock">Unlock</button>
      <p id="gate-error" class="gate-error"></p>
    </div>
  </div>

  <section id="panel-content" style="display: none;">
    <div class="panel-header">
      <h1>Agent Panel</h1>
      <p class="panel-intro">Watch Claude agents debate in real time. Configure their personalities, pick a topic, and hit go.</p>
    </div>

    <details class="config-toggle" open>
      <summary>Agent Setup</summary>
      <div class="config-section">
        <div class="agent-configs" id="agent-configs">
          <div class="agent-config" data-agent="0">
            <div class="agent-config-header">
              <input type="text" class="agent-name-input" value="Elena" />
              <span class="agent-dot" style="background: #e05252;"></span>
            </div>
            <textarea class="agent-prompt-input" rows="2">You are Elena, a fiercely independent photographer who just got back from six months in Patagonia. You fell for Marcus before you left and assumed he would wait. You are sharp-witted, passionate, and you do not beg. You speak with confidence and a little edge. Keep responses under 150 words.</textarea>
          </div>
          <div class="agent-config" data-agent="1">
            <div class="agent-config-header">
              <input type="text" class="agent-name-input" value="Marcus" />
              <span class="agent-dot" style="background: #3b82f6;"></span>
            </div>
            <textarea class="agent-prompt-input" rows="2">You are Marcus, an electrician who picks up bar shifts on weekends to pay off his truck. You are not smooth or clever -- you just say what you are thinking, which sometimes makes things worse. You did not plan for any of this. You fidget with a lighter when you are nervous. You speak plainly, sometimes awkwardly, and you stumble over your words when it matters most. Keep responses under 150 words.</textarea>
          </div>
          <div class="agent-config" data-agent="2">
            <div class="agent-config-header">
              <input type="text" class="agent-name-input" value="Diane" />
              <span class="agent-dot" style="background: #22c55e;"></span>
            </div>
            <textarea class="agent-prompt-input" rows="2">You are Diane, a veterinarian who started seeing Marcus two months ago. You had no idea about Elena until tonight. You are calm, observant, and direct. You do not raise your voice but your words cut deep. You are deciding in real time whether Marcus is worth the trouble. Keep responses under 150 words.</textarea>
          </div>
        </div>
        <button id="add-agent-btn" class="add-agent-btn">+ Add Agent</button>
      </div>
    </details>

    <div class="chat-controls">
      <textarea id="room-desc" rows="3" placeholder="Room description - set the scene, constraints, or context for the conversation (optional)">It is 1:47 AM. A rooftop bar in Brooklyn, late September. The city hums below. String lights sway in the wind. Marcus just got off a double shift and came upstairs to find Elena sitting at the bar -- she was not supposed to be back for another month. Diane is already at the corner table with two whiskeys, waiting for him. The bartender pretends not to notice. Someone left a speaker on the ledge playing old soul records. Nobody is leaving until this gets resolved.</textarea>
      <input type="text" id="topic-input" placeholder="Enter a topic for the agents to debate..." value="Elena locks eyes with Marcus from across the rooftop and says nothing. Diane follows his gaze and sets down her glass." />
      <div class="controls-row">
        <div class="rounds-row">
          <label for="rounds-input">Rounds:</label>
          <input type="number" id="rounds-input" min="1" max="10" value="2" />
        </div>
        <button id="start-btn">Go</button>
        <button id="clear-btn" class="clear-btn">Clear</button>
      </div>
    </div>

    <div id="chatroom" class="chatroom">
      <div class="chat-empty">Start a discussion to see agents interact here.</div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function() {
    var HASH = '48d5e01666b2a0cf736186d47e5e0e56e588fc2fbc24e598b0e849086bbcb846';
    var STORAGE_KEY = 'panel_auth';
    var AGENT_COLORS = ['#e05252', '#3b82f6', '#22c55e', '#f59e0b', '#8b5cf6', '#ec4899', '#06b6d4', '#f97316'];

    async function sha256(str) {
      var buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
      return Array.from(new Uint8Array(buf)).map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
    }

    function unlock() {
      document.getElementById('gate').style.display = 'none';
      document.getElementById('panel-content').style.display = 'block';
    }

    if (localStorage.getItem(STORAGE_KEY) === 'true') {
      unlock();
    }

    document.getElementById('gate-unlock').addEventListener('click', async function() {
      var pw = document.getElementById('gate-password').value;
      var hash = await sha256(pw);
      if (hash === HASH) {
        localStorage.setItem(STORAGE_KEY, 'true');
        unlock();
      } else {
        document.getElementById('gate-error').textContent = 'Nope.';
        document.getElementById('gate-password').value = '';
      }
    });

    document.getElementById('gate-password').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') document.getElementById('gate-unlock').click();
    });

    // Add agent button
    document.getElementById('add-agent-btn').addEventListener('click', function() {
      var configs = document.getElementById('agent-configs');
      var count = configs.children.length;
      var color = AGENT_COLORS[count % AGENT_COLORS.length];
      var div = document.createElement('div');
      div.className = 'agent-config';
      div.setAttribute('data-agent', count);
      div.innerHTML =
        '<div class="agent-config-header">' +
          '<input type="text" class="agent-name-input" value="Agent ' + (count + 1) + '" />' +
          '<span class="agent-dot" style="background: ' + color + ';"></span>' +
          '<button class="remove-agent-btn" title="Remove">x</button>' +
        '</div>' +
        '<textarea class="agent-prompt-input" rows="2">You are Agent ' + (count + 1) + '. Be direct and concise. Keep responses under 150 words.</textarea>';
      configs.appendChild(div);
      div.querySelector('.remove-agent-btn').addEventListener('click', function() {
        configs.removeChild(div);
      });
    });

    // Chat room logic
    var API_URL = '/.netlify/functions/agent-chat';

    function getAgents() {
      var configs = document.querySelectorAll('.agent-config');
      var roomDesc = document.getElementById('room-desc').value.trim();
      var agents = [];
      configs.forEach(function(cfg, i) {
        var basePrompt = cfg.querySelector('.agent-prompt-input').value;
        var system = roomDesc ? roomDesc + '\n\n' + basePrompt : basePrompt;
        agents.push({
          name: cfg.querySelector('.agent-name-input').value.trim() || ('Agent ' + (i + 1)),
          system: system,
          color: AGENT_COLORS[i % AGENT_COLORS.length],
        });
      });
      return agents;
    }

    async function callAgent(system, messages) {
      var res;
      try {
        res = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ system: system, messages: messages, model: 'claude-sonnet-4-20250514' }),
        });
      } catch (fetchErr) {
        throw new Error('Network error - could not reach server: ' + fetchErr.message);
      }
      if (!res.ok) {
        var errText = '';
        try {
          var errBody = await res.json();
          errText = errBody.error || JSON.stringify(errBody);
        } catch(e) {
          try { errText = await res.text(); } catch(e2) {}
        }
        throw new Error('API error (' + res.status + '): ' + (errText || 'unknown'));
      }
      var data = await res.json();
      return data.text;
    }

    function appendMessage(name, color, text, isSystem) {
      var chatroom = document.getElementById('chatroom');
      var empty = chatroom.querySelector('.chat-empty');
      if (empty) empty.remove();

      var msg = document.createElement('div');
      msg.className = 'chat-message' + (isSystem ? ' chat-system' : '');

      if (isSystem) {
        msg.textContent = text;
      } else {
        var nameEl = document.createElement('span');
        nameEl.className = 'chat-name';
        nameEl.style.color = color;
        nameEl.textContent = name;

        var textEl = document.createElement('div');
        textEl.className = 'chat-text';
        textEl.textContent = text;

        msg.appendChild(nameEl);
        msg.appendChild(textEl);
      }

      chatroom.appendChild(msg);
      chatroom.scrollTop = chatroom.scrollHeight;
      return msg;
    }

    function appendTyping(name, color) {
      var chatroom = document.getElementById('chatroom');
      var msg = document.createElement('div');
      msg.className = 'chat-message chat-typing';

      var nameEl = document.createElement('span');
      nameEl.className = 'chat-name';
      nameEl.style.color = color;
      nameEl.textContent = name;

      var dots = document.createElement('span');
      dots.className = 'typing-dots';
      dots.innerHTML = '<span>.</span><span>.</span><span>.</span>';

      msg.appendChild(nameEl);
      msg.appendChild(dots);
      chatroom.appendChild(msg);
      chatroom.scrollTop = chatroom.scrollHeight;
      return msg;
    }

    document.getElementById('clear-btn').addEventListener('click', function() {
      document.getElementById('chatroom').innerHTML = '<div class="chat-empty">Start a discussion to see agents interact here.</div>';
    });

    document.getElementById('start-btn').addEventListener('click', async function() {
      var btn = this;
      btn.disabled = true;
      btn.textContent = 'Running...';

      var agents = getAgents();
      if (agents.length < 2) {
        appendMessage('', '', 'Need at least 2 agents.', true);
        btn.disabled = false;
        btn.textContent = 'Go';
        return;
      }

      var topic = document.getElementById('topic-input').value.trim();
      var rounds = parseInt(document.getElementById('rounds-input').value, 10) || 2;

      if (!topic) {
        appendMessage('', '', 'Please enter a topic.', true);
        btn.disabled = false;
        btn.textContent = 'Go';
        return;
      }

      var histories = {};
      agents.forEach(function(a) { histories[a.name] = []; });

      var lastResponse = '';
      var lastSpeaker = '';

      appendMessage('', '', 'Topic: ' + topic, true);

      try {
        // Seed the first agent
        var first = agents[0];
        var typing = appendTyping(first.name, first.color);
        histories[first.name].push({ role: 'user', content: topic });
        lastResponse = await callAgent(first.system, histories[first.name]);
        histories[first.name].push({ role: 'assistant', content: lastResponse });
        typing.remove();
        appendMessage(first.name, first.color, lastResponse, false);
        lastSpeaker = first.name;

        for (var round = 1; round <= rounds; round++) {
          appendMessage('', '', 'Round ' + round, true);

          for (var i = 0; i < agents.length; i++) {
            var agent = agents[i];
            if (round === 1 && i === 0) continue;

            var prompt = '[Round ' + round + ' - ' + lastSpeaker + ']: ' + lastResponse;
            var typingEl = appendTyping(agent.name, agent.color);
            histories[agent.name].push({ role: 'user', content: prompt });
            lastResponse = await callAgent(agent.system, histories[agent.name]);
            histories[agent.name].push({ role: 'assistant', content: lastResponse });
            typingEl.remove();
            appendMessage(agent.name, agent.color, lastResponse, false);
            lastSpeaker = agent.name;
          }
        }

        appendMessage('', '', 'Discussion complete.', true);
      } catch (err) {
        appendMessage('', '', 'Error: ' + err.message, true);
      }

      btn.disabled = false;
      btn.textContent = 'Go';
    });
  })();
</script>

<style>
  #gate {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 40vh;
  }

  .gate-box {
    text-align: center;
  }

  .gate-label {
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin-bottom: 1rem;
  }

  #gate-password {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    width: 200px;
    outline: none;
  }

  #gate-password:focus {
    border-color: var(--fg-muted);
  }

  #gate-unlock {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    cursor: pointer;
    margin-left: 0.5rem;
    transition: background 0.2s;
  }

  #gate-unlock:hover {
    background: var(--code-bg);
  }

  .gate-error {
    font-size: 0.8rem;
    color: var(--fg-muted);
    margin-top: 0.75rem;
    min-height: 1.2em;
  }

  .panel-header h1 {
    margin-top: 1rem;
    margin-bottom: 0.25rem;
  }

  .panel-intro {
    color: var(--fg-muted);
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  details.config-toggle {
    margin-bottom: 1.5rem;
    border: 1px solid var(--border);
    padding: 0;
  }

  details.config-toggle summary {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    cursor: pointer;
    padding: 0.75rem 1rem;
    user-select: none;
  }

  .config-section {
    padding: 0 1rem 1rem;
  }

  .agent-configs {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .agent-config {
    border: 1px solid var(--border);
    padding: 0.75rem;
  }

  .agent-config-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .agent-name-input {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.25rem 0.4rem;
    border: 1px solid transparent;
    background: transparent;
    color: var(--fg);
    outline: none;
    width: 140px;
  }

  .agent-name-input:focus {
    border-color: var(--border);
  }

  .agent-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }

  .remove-agent-btn {
    margin-left: auto;
    font-size: 0.75rem;
    background: none;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    cursor: pointer;
    padding: 0.1rem 0.4rem;
    line-height: 1;
  }

  .remove-agent-btn:hover {
    color: #e05252;
    border-color: #e05252;
  }

  .agent-prompt-input {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    resize: vertical;
    outline: none;
    line-height: 1.5;
  }

  .agent-prompt-input:focus {
    border-color: var(--fg-muted);
  }

  .add-agent-btn {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border: 1px dashed var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    margin-top: 0.5rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .add-agent-btn:hover {
    color: var(--fg);
    border-color: var(--fg);
  }

  .chat-controls {
    margin-bottom: 1rem;
  }

  #room-desc {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    outline: none;
    margin-bottom: 0.5rem;
    resize: vertical;
    line-height: 1.5;
  }

  #room-desc:focus {
    border-color: var(--fg-muted);
  }

  #topic-input {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    outline: none;
    margin-bottom: 0.75rem;
  }

  #topic-input:focus {
    border-color: var(--fg-muted);
  }

  .controls-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .rounds-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .rounds-row label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
  }

  #rounds-input {
    width: 50px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.4rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    text-align: center;
    outline: none;
  }

  #start-btn {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.45rem 1.5rem;
    border: 1px solid var(--fg);
    background: var(--fg);
    color: var(--bg);
    cursor: pointer;
    transition: opacity 0.2s;
  }

  #start-btn:hover {
    opacity: 0.85;
  }

  #start-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .clear-btn {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    transition: color 0.2s;
  }

  .clear-btn:hover {
    color: var(--fg);
  }

  .chatroom {
    border: 1px solid var(--border);
    min-height: 300px;
    max-height: 65vh;
    overflow-y: auto;
    padding: 1rem;
    margin-bottom: 2rem;
    background: var(--code-bg);
  }

  .chat-empty {
    color: var(--fg-muted);
    font-size: 0.85rem;
    font-style: italic;
    text-align: center;
    padding: 3rem 0;
  }

  .chat-message {
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .chat-message:last-child {
    margin-bottom: 0;
  }

  .chat-system {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    text-align: center;
    padding: 0.5rem 0;
    margin-bottom: 0.5rem;
  }

  .chat-name {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 0.2rem;
  }

  .chat-text {
    font-size: 0.9rem;
    padding-left: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .chat-typing {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .typing-dots span {
    animation: blink 1.4s infinite both;
    font-size: 1.5rem;
    line-height: 0.5;
    color: var(--fg-muted);
  }

  .typing-dots span:nth-child(2) {
    animation-delay: 0.2s;
  }

  .typing-dots span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes blink {
    0%, 80%, 100% { opacity: 0.2; }
    40% { opacity: 1; }
  }

  @media (max-width: 600px) {
    .controls-row {
      flex-wrap: wrap;
    }
  }
</style>

  // --- Export transcript ---
  function transcriptToMarkdown(data) {
    var opening = data.opening || '';
    var entries = data.sessionTranscript || [];
    var agents = data.sessionAgents || [];
    var savedAt = data.lastModified ? new Date(data.lastModified) : new Date();

    var lines = [];
    lines.push('# Legion Session');
    lines.push('');
    lines.push('_' + savedAt.toLocaleString() + '_');
    lines.push('');

    var names = (agents || [])
      .map(function (a) { return a && a.name; })
      .filter(function (n) { return n && n !== 'The Room'; });
    if (names.length) {
      lines.push('**Agents:** ' + names.join(', '));
      lines.push('');
    }
    if (data.roomStatus && data.roomStatus.name) {
      lines.push('**Room:** ' + data.roomStatus.name);
      lines.push('');
    }

    if (opening) {
      lines.push('## Prompt');
      lines.push('');
      opening.split('\n').forEach(function (ln) { lines.push('> ' + ln); });
      lines.push('');
    }

    var currentRound = 0;
    entries.forEach(function (entry) {
      if (entry.round && entry.round !== currentRound) {
        currentRound = entry.round;
        lines.push('');
        lines.push('## Round ' + currentRound);
        lines.push('');
      }
      var text = entry.rawText || entry.text || '';
      var name = entry.name || '';

      if (text.indexOf('[CODE_FIGURE]:') === 0) {
        var url = text.substring('[CODE_FIGURE]:'.length);
        lines.push('![figure](' + url + ')');
        lines.push('');
        return;
      }
      if (text.indexOf('[CODE_RESULT]:') === 0) {
        var out = text.substring('[CODE_RESULT]:'.length).trim();
        lines.push('```');
        lines.push(out);
        lines.push('```');
        lines.push('');
        return;
      }
      if (text.indexOf('[CODE_ERROR]:') === 0) {
        var err = text.substring('[CODE_ERROR]:'.length).trim();
        lines.push('```');
        lines.push('Error: ' + err);
        lines.push('```');
        lines.push('');
        return;
      }
      if (name === 'Status' || name === 'Narrator') {
        lines.push('> _' + text.replace(/\n+/g, ' ') + '_');
        lines.push('');
        return;
      }
      if (text === '...') {
        lines.push('**' + name + ':** _(silent)_');
        lines.push('');
        return;
      }

      // Character message. Convert [CODE] to fenced python, [ACTION] to italic.
      var processed = text.replace(/\[CODE\]([\s\S]*?)\[\/CODE\]/g, function (m, code) {
        return '\n\n```python\n' + code.trim() + '\n```\n\n';
      });
      processed = processed.replace(/\[ACTION:\s*([^\]]+)\]/g, function (m, act) {
        return '_' + act.trim() + '_';
      });
      processed = processed.replace(/\[WHISPER\s+to\s+([^:\]]+):\s*([^\]]*)\]/g, function (m, target, content) {
        return '\n\n> _(whispers to ' + target.trim() + ')_ ' + content.trim() + '\n';
      });
      // Strip status mechanics tags from narrative output
      processed = processed.replace(/\[(DIES|LEAVES)\]/g, '').replace(/\[(DEAD|LEAVES):\s*[^\]]+\]/g, '');

      lines.push('### ' + name);
      lines.push('');
      lines.push(processed.trim());
      lines.push('');
    });

    return lines.join('\n');
  }

  function downloadMarkdown(data, filename) {

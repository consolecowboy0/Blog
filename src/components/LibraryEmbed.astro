---
interface Props {
  src: string;
  title: string;
  description?: string;
  showHeader?: boolean;
}

const { src, title, description, showHeader = false } = Astro.props;
---

<div class="library-embed">
  {showHeader && (
    <div class="library-embed-header">
      <h1>{title}</h1>
      {description && <p class="library-embed-desc">{description}</p>}
    </div>
  )}
  <iframe src={src} title={title} loading="lazy"></iframe>
</div>

<style>
  .library-embed {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    max-width: 1200px;
    padding: 0 1.5rem;
    margin: 2rem 0;
  }

  .library-embed-header h1 {
    margin-top: 1rem;
  }

  .library-embed-desc {
    color: var(--fg-muted);
    margin-bottom: 1.5rem;
  }

  .library-embed iframe {
    width: 100%;
    min-height: 80vh;
    border: 1px solid var(--border);
  }
</style>

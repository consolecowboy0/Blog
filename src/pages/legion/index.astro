---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const charDir = path.resolve('characters/modelthinker');
const charFiles = ['axiom','loop','prior','nash','contra','bottleneck','darwin','tail','web','margin','razor','atlas'];
const legionCharacters = charFiles.map(f => ({
  ...JSON.parse(fs.readFileSync(path.join(charDir, f + '.json'), 'utf-8')),
  __headshot: '/characters/headshots/modelthinker/' + f + '.png',
}));
const analystDir = path.resolve('characters/analysts');
const allRooms = [
  { id: 'workshop', label: 'The Workshop', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_workshop.json'), 'utf-8')) },
  { id: 'bazaar', label: 'The Bazaar', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_bazaar.json'), 'utf-8')) },
  { id: 'onsen', label: 'The Onsen', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_onsen.json'), 'utf-8')) },
  { id: 'rig', label: 'The Rig', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_rig.json'), 'utf-8')) },
  { id: 'lighthouse', label: 'The Lighthouse', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_lighthouse.json'), 'utf-8')) },
  { id: 'cellar', label: 'The Cellar', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_cellar.json'), 'utf-8')) },
  { id: 'observatory', label: 'The Observatory', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_observatory.json'), 'utf-8')) },
  { id: 'train', label: 'The Train', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_train.json'), 'utf-8')) },
  { id: 'observation', label: 'The Chatsubo', data: JSON.parse(fs.readFileSync(path.join(analystDir, 'room_observation.json'), 'utf-8')) },
  { id: 'forking_paths', label: 'The Library of Forking Paths', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_forking_paths.json'), 'utf-8')) },
  { id: 'glass_forest', label: 'The Visitor Center', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_glass_forest.json'), 'utf-8')) },
  { id: 'cloudbank', label: 'The Cloudbank', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_cloudbank.json'), 'utf-8')) },
  { id: 'tessellation', label: 'The Falcon Lounge', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_tessellation.json'), 'utf-8')) },
  { id: 'mycelium_bridge', label: 'The Mycelium Bridge', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_mycelium_bridge.json'), 'utf-8')) },
  { id: 'suntouch', label: 'The Suntouch Veranda', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_suntouch.json'), 'utf-8')) },
  { id: 'hendrix', label: 'The Hendrix Lobby', data: JSON.parse(fs.readFileSync(path.join(charDir, 'room_hendrix.json'), 'utf-8')) },
].map(r => ({ ...r, image: '/characters/rooms/' + r.id + '.png' }));
const legionRooms = allRooms;
const legionRelationships = JSON.parse(fs.readFileSync(path.join(charDir, 'relationships_modelthinker.json'), 'utf-8'));

const analystFiles = ['paloma','marcus','iris','evelyn','sam','henrik','lena','theo'];
const analystCharacters = analystFiles.map(f => ({
  ...JSON.parse(fs.readFileSync(path.join(analystDir, f + '.json'), 'utf-8')),
  __headshot: '/characters/headshots/analysts/' + f + '.png',
}));
const analystRooms = allRooms;
const analystRelationships = JSON.parse(fs.readFileSync(path.join(analystDir, 'relationships_analysts.json'), 'utf-8'));
---

<BaseLayout title="Legion - dustinlanders.com" description="Multi-agent chat room.">
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" crossorigin="anonymous">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" crossorigin="anonymous"></script>
  </Fragment>
  <div id="gate">
    <div class="gate-box">
      <div class="gate-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>
      <h2>Private area</h2>
      <p class="gate-sub">Enter password to continue.</p>
      <form id="gate-form">
        <input type="password" id="gate-password" placeholder="Password" autocomplete="off" />
        <button type="submit" id="gate-unlock">Unlock</button>
      </form>
      <p id="gate-error" class="gate-error gate-hidden">Wrong password</p>
    </div>
  </div>

  <section id="panel" style="display: none;">
    <div class="panel-header">
      <div class="panel-title-row">
        <h1>Legion</h1>
        <div class="header-controls">
          <button id="history-btn-header" class="secondary-btn">History</button>
          <button id="sign-out" class="secondary-btn">Sign Out</button>
        </div>
      </div>
      <p class="panel-sub">Configure agents, set the scene, and watch them talk.</p>
    </div>

    <div class="tab-bar">
      <button class="tab-btn tab-active" data-tab="legion">Science</button>
      <button class="tab-btn" data-tab="analysts">Psych</button>
    </div>

    <div id="tab-legion" class="tab-panel">
      <div class="legion-roster">
        <label class="field-label">The Rooms</label>
        <div class="room-grid" id="room-grid"></div>
      </div>

      <div class="legion-roster">
        <label class="field-label">The Legion</label>
        <div class="agents-grid" id="legion-grid"></div>
      </div>

      <details class="prompt-section prompt-foldable" open>
        <summary class="field-label prompt-toggle">Prompt</summary>
        <textarea id="opening" rows="2" placeholder="Prompt..."></textarea>
      </details>

      <div class="controls">
        <div class="control-group">
          <label class="field-label" for="rounds">Rounds</label>
          <input type="number" id="rounds" min="1" max="50" value="2" />
        </div>
        <input type="hidden" id="delay-input" value="0" />
        <input type="hidden" id="mode-select" value="agent-sdk" />
        <div class="control-group">
          <label class="field-label" for="order-mode">Order</label>
          <select id="order-mode">
            <option value="priority">Priority</option>
            <option value="default">Default</option>
            <option value="random">Random</option>
          </select>
        </div>
        <div class="control-group">
          <label class="field-label" for="model-select">Model</label>
          <select id="model-select">
            <option value="claude-sonnet-4-20250514">Sonnet 4</option>
            <option value="claude-opus-4-20250514">Opus 4</option>
            <option value="claude-haiku-4-5-20251001">Haiku 4.5</option>
          </select>
        </div>
        <label class="defense-label"><input type="checkbox" id="defense-mode" /> Defense</label>
      </div>
    </div>

    <div id="tab-analysts" class="tab-panel" style="display:none;">
      <div class="legion-roster">
        <label class="field-label">The Rooms</label>
        <div class="room-grid" id="analysts-room-grid"></div>
      </div>

      <div class="legion-roster">
        <label class="field-label">The Analysts</label>
        <div class="agents-grid" id="analysts-grid"></div>
      </div>

      <details class="prompt-section prompt-foldable" open>
        <summary class="field-label prompt-toggle">Transcript</summary>
        <textarea id="analysts-opening" rows="10" placeholder="Paste a conversation transcript here. The analysts will read it and tell you what is going on under the surface."></textarea>
      </details>

      <div class="controls">
        <div class="control-group">
          <label class="field-label" for="analysts-rounds">Rounds</label>
          <input type="number" id="analysts-rounds" min="1" max="50" value="3" />
        </div>
        <div class="control-group">
          <label class="field-label" for="analysts-order-mode">Order</label>
          <select id="analysts-order-mode">
            <option value="priority">Priority</option>
            <option value="default">Default</option>
            <option value="random">Random</option>
          </select>
        </div>
        <div class="control-group">
          <label class="field-label" for="analysts-model-select">Model</label>
          <select id="analysts-model-select">
            <option value="claude-sonnet-4-20250514">Sonnet 4</option>
            <option value="claude-opus-4-20250514">Opus 4</option>
            <option value="claude-haiku-4-5-20251001">Haiku 4.5</option>
          </select>
        </div>
        <label class="defense-label"><input type="checkbox" id="analysts-defense-mode" /> Defense</label>
      </div>
    </div>

    <div class="run-controls">
      <button id="go-btn">Go</button>
      <button id="stop-btn" class="secondary-btn" style="display:none;">Stop</button>
      <button id="clear-btn" class="secondary-btn">Clear</button>
      <button id="export-btn" class="secondary-btn" style="display:none;">Export</button>
      <button id="move-room-btn" class="secondary-btn" style="display:none;">Move Room</button>
      <button id="add-char-btn" class="secondary-btn" style="display:none;">Add Character</button>
    </div>

    <div id="status-panel" class="status-panel" style="display:none;">
      <label class="field-label">Status</label>
      <div id="status-list" class="status-list"></div>
    </div>

    <div class="chat-wrapper" id="chat-wrapper">
      <div class="chat-toolbar">
        <button id="fullscreen-chat" class="copy-btn chat-toolbar-btn" title="Fullscreen"><svg class="icon-expand" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg><svg class="icon-collapse" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:none;"><path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/></svg></button>
        <button id="copy-chat" class="copy-btn chat-toolbar-btn" title="Copy chat"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
      </div>
      <div id="chat" class="chat">
        <p class="chat-placeholder">Hit Go to start.</p>
      </div>
    </div>

    <div class="interject-section" id="interject-section" style="display:none;">
      <div class="interject-row">
        <input type="text" id="interject-input" placeholder="Interject..." />
        <button id="interject-btn" class="secondary-btn">Send</button>
      </div>
    </div>


    <div id="add-char-modal" class="add-char-modal" style="display:none;">
      <div class="add-char-modal-content">
        <div class="add-char-modal-header">
          <span class="field-label">Add Character</span>
          <button id="add-char-modal-close" class="remove-btn" title="Close">x</button>
        </div>
        <div id="add-char-roster" class="add-char-roster"></div>
        <button id="add-char-upload" class="secondary-btn" style="width:100%;display:none;">Upload JSON</button>
      </div>
    </div>

    <div id="move-room-modal" class="add-char-modal" style="display:none;">
      <div class="add-char-modal-content">
        <div class="add-char-modal-header">
          <span class="field-label">Move Room</span>
          <button id="move-room-modal-close" class="remove-btn" title="Close">x</button>
        </div>
        <div id="move-room-roster" class="add-char-roster"></div>
        <button id="move-room-upload" class="secondary-btn" style="width:100%;display:none;">Upload JSON</button>
      </div>
    </div>

    <div id="char-modal" class="add-char-modal" style="display:none;">
      <div class="add-char-modal-content char-modal-content">
        <div class="add-char-modal-header">
          <span class="field-label" id="char-modal-title">Character</span>
          <button id="char-modal-close" class="remove-btn" title="Close">x</button>
        </div>
        <div class="char-modal-top">
          <img id="char-modal-image" class="char-modal-image" alt="" onerror="this.style.display='none'">
          <div id="char-modal-summary" class="char-modal-summary"></div>
        </div>
        <div id="char-modal-body" class="char-modal-body"></div>
        <button id="char-modal-toggle" class="secondary-btn char-modal-toggle">Add to Roster</button>
      </div>
    </div>

    <div id="room-modal" class="add-char-modal" style="display:none;">
      <div class="add-char-modal-content room-modal-content">
        <div class="add-char-modal-header">
          <span class="field-label" id="room-modal-title">Room</span>
          <button id="room-modal-close" class="remove-btn" title="Close">x</button>
        </div>
        <img id="room-modal-image" class="room-modal-image" alt="" onerror="this.style.display='none'">
        <div id="room-modal-body" class="room-modal-body"></div>
        <button id="room-modal-select" class="secondary-btn room-modal-select">Use This Room</button>
      </div>
    </div>

    <div id="history-modal" class="add-char-modal" style="display:none;">
      <div class="add-char-modal-content history-modal-content">
        <div class="add-char-modal-header">
          <span class="field-label">History</span>
          <button id="history-modal-close" class="remove-btn" title="Close">x</button>
        </div>
        <p class="history-note">Sessions archived on Clear. Kept 30 days, auto-purged after.</p>
        <div id="history-list" class="history-list"></div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ legionCharacters, legionRooms, legionRelationships, analystCharacters, analystRooms, analystRelationships }}>
  window.__LEGION_CHARACTERS__ = legionCharacters;
  window.__LEGION_ROOMS__ = legionRooms;
  window.__LEGION_RELATIONSHIPS__ = legionRelationships;
  window.__ANALYSTS_CHARACTERS__ = analystCharacters;
  window.__ANALYSTS_ROOMS__ = analystRooms;
  window.__ANALYSTS_RELATIONSHIPS__ = analystRelationships;
</script>

<script is:inline>
(function () {
  var API_BASE = location.hostname === 'localhost' ? '' : 'https://api.dustinlanders.com';
  var authToken = localStorage.getItem('auth_token') || null;
  var COLORS = ['#e05252','#3b82f6','#22c55e','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#f97316'];
  var MAX_TRANSCRIPT_MESSAGES = 30;
  var activeTab = 'legion';

  // --- Tab switching ---
  document.querySelectorAll('.tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('tab-active'); });
      btn.classList.add('tab-active');
      activeTab = btn.getAttribute('data-tab');
      document.getElementById('tab-legion').style.display = activeTab === 'legion' ? '' : 'none';
      document.getElementById('tab-analysts').style.display = activeTab === 'analysts' ? '' : 'none';
    });
  });

  // Helper: get active control value based on tab
  function getOpening() {
    if (activeTab === 'analysts') {
      var transcript = document.getElementById('analysts-opening').value.trim();
      if (!transcript) return '';
      return 'Below is a conversation transcript the consortium has been asked to analyze. Read it carefully. Apply your framework. Listen to your colleagues. Build a layered reading of what is actually going on under the surface. Point to specific lines. Notice what nobody else has noticed yet.\n\n--- TRANSCRIPT ---\n' + transcript + '\n--- END TRANSCRIPT ---';
    }
    return document.getElementById('opening').value;
  }
  function getRounds() {
    if (activeTab === 'analysts') return document.getElementById('analysts-rounds').value;
    return document.getElementById('rounds').value;
  }
  function getModel() {
    if (activeTab === 'analysts') return document.getElementById('analysts-model-select').value;
    return document.getElementById('model-select').value;
  }
  function getOrderMode() {
    if (activeTab === 'analysts') return document.getElementById('analysts-order-mode').value;
    return document.getElementById('order-mode').value;
  }
  function getDefense() {
    if (activeTab === 'analysts') return document.getElementById('analysts-defense-mode').checked;
    return document.getElementById('defense-mode').checked;
  }

  // --- Legion auto-load ---
  var legionChars = window.__LEGION_CHARACTERS__ || [];
  var legionRoomsData = window.__LEGION_ROOMS__ || [];
  var legionRels = window.__LEGION_RELATIONSHIPS__ || null;
  var selectedLegionRoom = legionRoomsData.length > 0 ? legionRoomsData[0] : null;

  // --- Analysts auto-load ---
  var analystChars = window.__ANALYSTS_CHARACTERS__ || [];
  var analystRoomsData = window.__ANALYSTS_ROOMS__ || [];
  var analystRels = window.__ANALYSTS_RELATIONSHIPS__ || null;

  // Name -> headshot URL map. Populated from the preloaded character sets and
  // from user-uploaded characters in the Advanced tab. msg() / typing() look
  // up here so we do not have to plumb headshots through every call site.
  var headshotMap = {};
  function registerHeadshot(data) {
    if (!data) return;
    var n = data.name || data.Name;
    if (n && data.__headshot) headshotMap[n.toLowerCase()] = data.__headshot;
  }
  legionChars.forEach(registerHeadshot);
  analystChars.forEach(registerHeadshot);
  function getHeadshot(name) {
    if (!name) return null;
    return headshotMap[name.toLowerCase()] || null;
  }
  // Default the Psych tab to the Observation Room to preserve prior behavior.
  var selectedAnalystRoom = (function () {
    var match = analystRoomsData.filter(function (r) { return r.id === 'observation'; })[0];
    return match || (analystRoomsData.length > 0 ? analystRoomsData[0] : null);
  })();

  function buildRoomGrid(gridId, rooms, initiallySelected, onSelect) {
    var grid = document.getElementById(gridId);
    if (!grid) return;
    grid.innerHTML = '';
    rooms.forEach(function (room) {
      var card = document.createElement('div');
      var isSelected = initiallySelected && initiallySelected.id === room.id;
      card.className = 'room-card' + (isSelected ? ' room-selected' : '');
      card._roomData = room;
      card.innerHTML =
        (room.image ? '<img class="room-card-image" src="' + esc(room.image) + '" alt="" onerror="this.style.display=\'none\'">' : '') +
        '<span class="room-card-name">' + esc(room.label) + '</span>' +
        '<span class="room-card-desc">' + esc(room.data.location.split('.')[0]) + '</span>';
      card.addEventListener('click', function () {
        openRoomModal(room, function () {
          grid.querySelectorAll('.room-card').forEach(function (c) { c.classList.remove('room-selected'); });
          card.classList.add('room-selected');
          onSelect(room);
        });
      });
      grid.appendChild(card);
    });
  }
  buildRoomGrid('room-grid', legionRoomsData, selectedLegionRoom, function (r) { selectedLegionRoom = r; });
  buildRoomGrid('analysts-room-grid', analystRoomsData, selectedAnalystRoom, function (r) { selectedAnalystRoom = r; });

  // Room detail modal: clicking a card opens this so the user can read the
  // full atmosphere description and confirm before committing the selection.
  var pendingRoomConfirm = null;
  function openRoomModal(room, onConfirm) {
    pendingRoomConfirm = onConfirm;
    document.getElementById('room-modal-title').textContent = room.label;
    var img = document.getElementById('room-modal-image');
    if (room.image) {
      img.src = room.image;
      img.style.display = '';
    } else {
      img.style.display = 'none';
    }
    var body = document.getElementById('room-modal-body');
    body.innerHTML = '';
    var d = room.data || {};
    function row(label, value) {
      if (!value) return;
      var wrap = document.createElement('div');
      wrap.className = 'room-modal-row';
      var l = document.createElement('div');
      l.className = 'room-modal-row-label';
      l.textContent = label;
      var v = document.createElement('div');
      v.className = 'room-modal-row-value';
      v.textContent = value;
      wrap.appendChild(l);
      wrap.appendChild(v);
      body.appendChild(wrap);
    }
    row('Location', d.location);
    row('Time', d.time);
    row('Weather', d.weather);
    if (d.atmosphere) {
      row('Lighting', d.atmosphere.lighting);
      row('Sound', d.atmosphere.sound);
      row('Smell', d.atmosphere.smell);
      row('Crowd', d.atmosphere.crowd);
    }
    row('Mood', d.mood);
    document.getElementById('room-modal').style.display = 'flex';
  }
  function closeRoomModal() {
    document.getElementById('room-modal').style.display = 'none';
    pendingRoomConfirm = null;
  }
  document.getElementById('room-modal-close').addEventListener('click', closeRoomModal);
  document.getElementById('room-modal').addEventListener('click', function (e) {
    if (e.target === this) closeRoomModal();
  });
  document.getElementById('room-modal-select').addEventListener('click', function () {
    if (pendingRoomConfirm) pendingRoomConfirm();
    closeRoomModal();
  });

  // Character detail modal: clicking a roster card opens this so the user can
  // read the full character sheet and toggle inclusion via the confirm button.
  var pendingCharToggle = null;
  function openCharModal(char, isCurrentlySelected, onToggle) {
    pendingCharToggle = onToggle;
    var name = char.name || char.Name || 'Character';
    document.getElementById('char-modal-title').textContent = name;
    var img = document.getElementById('char-modal-image');
    if (char.__headshot) {
      img.src = char.__headshot;
      img.style.display = '';
    } else {
      img.style.display = 'none';
    }
    var summary = document.getElementById('char-modal-summary');
    summary.innerHTML = '';
    function summaryRow(value) {
      if (!value) return;
      var line = document.createElement('div');
      line.textContent = value;
      summary.appendChild(line);
    }
    if (char.model) summaryRow(char.model);
    if (char.occupation) summaryRow(char.occupation);
    if (char.age) summaryRow('Age ' + char.age);
    var body = document.getElementById('char-modal-body');
    body.innerHTML = '';
    function row(label, value) {
      if (!value) return;
      var wrap = document.createElement('div');
      wrap.className = 'room-modal-row';
      var l = document.createElement('div');
      l.className = 'room-modal-row-label';
      l.textContent = label;
      var v = document.createElement('div');
      v.className = 'room-modal-row-value';
      if (Array.isArray(value)) {
        v.textContent = value.join(', ');
      } else if (typeof value === 'object') {
        var lines = [];
        for (var k in value) {
          if (value[k] == null || value[k] === '') continue;
          var val = Array.isArray(value[k]) ? value[k].join(', ') : value[k];
          lines.push(k + ': ' + val);
        }
        v.textContent = lines.join('\n');
        v.style.whiteSpace = 'pre-wrap';
      } else {
        v.textContent = value;
      }
      wrap.appendChild(l);
      wrap.appendChild(v);
      body.appendChild(wrap);
    }
    if (char.model_description) row('Model', char.model_description);
    row('Appearance', char.appearance);
    if (char.personality) row('Personality', char.personality);
    if (char.speaking_style) row('Speaking Style', char.speaking_style);
    row('Backstory', char.backstory);
    row('Motivations', char.motivations);
    row('Current State', char.current_emotional_state);
    row('Mannerisms', char.physical_mannerisms);
    var toggle = document.getElementById('char-modal-toggle');
    toggle.textContent = isCurrentlySelected ? 'Remove from Roster' : 'Add to Roster';
    document.getElementById('char-modal').style.display = 'flex';
  }
  function closeCharModal() {
    document.getElementById('char-modal').style.display = 'none';
    pendingCharToggle = null;
  }
  document.getElementById('char-modal-close').addEventListener('click', closeCharModal);
  document.getElementById('char-modal').addEventListener('click', function (e) {

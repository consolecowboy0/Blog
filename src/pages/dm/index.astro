---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="DM">
  <div class="dm-page">
    <h1>Send me a message</h1>
    <p class="dm-desc">Messages are private. Save your code below to pick up the conversation later.</p>

    <div class="id-bar">
      <div class="id-display">
        <span class="id-label">Your ID</span>
        <code id="visitor-id">loading...</code>
        <button id="copy-id" class="copy-btn" title="Copy ID">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
      <div class="id-resume">
        <button id="resume-toggle" class="resume-link">Resume with a different ID</button>
        <div id="resume-form" class="resume-form" hidden>
          <input type="text" id="resume-input" placeholder="Paste your ID" maxlength="16" />
          <button id="resume-btn" class="resume-go">Go</button>
        </div>
      </div>
    </div>

    <div class="chat-box">
      <div id="messages" class="messages">
        <p class="empty-msg">No messages yet. Say hello!</p>
      </div>
      <div class="input-bar">
        <textarea id="msg-input" rows="3" placeholder="Type your message..."></textarea>
        <button id="send-btn" class="send-btn">Send</button>
      </div>
      <div id="sent-flash" class="sent-flash" hidden>Sent!</div>
    </div>
  </div>
</BaseLayout>

<style>
  .dm-page {
    max-width: 600px;
    margin: 0 auto;
  }

  h1 {
    margin-top: 0;
    font-size: 1.75rem;
  }

  .dm-desc {
    color: var(--fg-muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .id-bar {
    border: 1px solid var(--border);
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .id-display {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .id-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
  }

  .id-display code {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    background: var(--code-bg);
    padding: 0.2em 0.5em;
    letter-spacing: 0.05em;
  }

  .copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--fg-muted);
    padding: 0.2rem;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .copy-btn:hover {
    color: var(--fg);
  }

  .id-resume {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .resume-link {
    background: none;
    border: none;
    color: var(--fg-muted);
    font-size: 0.75rem;
    cursor: pointer;
    text-decoration: underline;
    padding: 0;
    font-family: var(--font-body);
    transition: color 0.2s;
  }

  .resume-link:hover {
    color: var(--fg);
  }

  .resume-form {
    display: flex;
    gap: 0.35rem;
  }

  #resume-input {
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    width: 120px;
    outline: none;
  }

  #resume-input:focus {
    border-color: var(--fg-muted);
  }

  .resume-go {
    padding: 0.35rem 0.75rem;
    background: var(--fg);
    color: var(--bg);
    border: none;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-body);
    transition: opacity 0.2s;
  }

  .resume-go:hover {
    opacity: 0.85;
  }

  .chat-box {
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .messages {
    min-height: 300px;
    max-height: 450px;
    overflow-y: auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .empty-msg {
    color: var(--fg-muted);
    font-size: 0.85rem;
    text-align: center;
    margin-top: 4rem;
  }

  .msg {
    max-width: 80%;
    display: flex;
    flex-direction: column;
  }

  .msg-visitor {
    align-self: flex-end;
  }

  .msg-admin {
    align-self: flex-start;
  }

  .msg-text {
    padding: 0.55rem 0.85rem;
    font-size: 0.85rem;
    line-height: 1.5;
    word-wrap: break-word;
    white-space: pre-wrap;
  }

  .msg-visitor .msg-text {
    background: var(--code-bg);
    border: 1px solid var(--border);
    color: var(--fg);
  }

  .msg-admin .msg-text {
    background: var(--fg);
    color: var(--bg);
  }

  .msg-time {
    font-size: 0.6rem;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    margin-top: 0.2rem;
  }

  .msg-visitor .msg-time {
    text-align: right;
  }

  .input-bar {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--border);
  }

  #msg-input {
    flex: 1;
    resize: vertical;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-body);
    font-size: 0.85rem;
    padding: 0.5rem 0.75rem;
    outline: none;
    line-height: 1.5;
    min-height: 2.5rem;
  }

  #msg-input:focus {
    border-color: var(--fg-muted);
  }

  .send-btn {
    padding: 0.5rem 1.25rem;
    background: var(--fg);
    color: var(--bg);
    border: none;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    align-self: flex-end;
    transition: opacity 0.2s;
  }

  .send-btn:hover {
    opacity: 0.85;
  }

  .send-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .sent-flash {
    position: absolute;
    bottom: 4.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--fg);
    color: var(--bg);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .sent-flash.show {
    opacity: 1;
  }

  @media (max-width: 480px) {
    .id-bar {
      flex-direction: column;
      align-items: flex-start;
    }

    .id-resume {
      align-items: flex-start;
    }
  }
</style>

<script>
  const API = '/api/dm';

  // Fingerprint
  function djb2(str: string): string {
    let hash = 5381;
    for (let i = 0; i < str.length; i++) {
      hash = ((hash << 5) + hash) + str.charCodeAt(i);
      hash = hash & hash;
    }
    return (hash >>> 0).toString(16).padStart(8, '0').slice(0, 8);
  }

  function getFingerprint(): string {
    return [
      navigator.userAgent,
      screen.width + 'x' + screen.height,
      String(screen.colorDepth),
      Intl.DateTimeFormat().resolvedOptions().timeZone,
      navigator.language,
      String(navigator.hardwareConcurrency || 0),
      navigator.platform,
    ].join('|');
  }

  const fingerprint = getFingerprint();
  let visitorId = localStorage.getItem('dm_visitor_id') || djb2(fingerprint);
  localStorage.setItem('dm_visitor_id', visitorId);

  // Elements
  const idEl = document.getElementById('visitor-id')!;
  const copyBtn = document.getElementById('copy-id')!;
  const resumeToggle = document.getElementById('resume-toggle')!;
  const resumeForm = document.getElementById('resume-form')!;
  const resumeInput = document.getElementById('resume-input') as HTMLInputElement;
  const resumeBtn = document.getElementById('resume-btn')!;
  const messagesEl = document.getElementById('messages')!;
  const msgInput = document.getElementById('msg-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('send-btn')!;
  const sentFlash = document.getElementById('sent-flash')!;

  idEl.textContent = visitorId;

  // Copy ID
  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(visitorId);
    copyBtn.title = 'Copied!';
    setTimeout(() => { copyBtn.title = 'Copy ID'; }, 1500);
  });

  // Resume with different ID
  resumeToggle.addEventListener('click', () => {
    resumeForm.hidden = !resumeForm.hidden;
    if (!resumeForm.hidden) resumeInput.focus();
  });

  resumeBtn.addEventListener('click', () => {
    const newId = resumeInput.value.trim();
    if (!newId) return;
    visitorId = newId;
    localStorage.setItem('dm_visitor_id', visitorId);
    idEl.textContent = visitorId;
    resumeForm.hidden = true;
    resumeInput.value = '';
    loadMessages();
  });

  resumeInput.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') resumeBtn.click();
  });

  // Escape HTML
  function esc(str: string): string {
    const el = document.createElement('span');
    el.textContent = str;
    return el.innerHTML;
  }

  // Format time
  function fmtTime(ts: number): string {
    const d = new Date(ts);
    const now = Date.now();
    const diff = now - ts;
    if (diff < 60000) return 'just now';
    if (diff < 3600000) return Math.floor(diff / 60000) + 'm ago';
    if (diff < 86400000) return Math.floor(diff / 3600000) + 'h ago';
    return d.toLocaleDateString([], { month: 'short', day: 'numeric' });
  }

  // Render messages
  function render(messages: Array<{ from: string; text: string; time: number }>) {
    if (!messages.length) {
      messagesEl.innerHTML = '<p class="empty-msg">No messages yet. Say hello!</p>';
      return;
    }
    messagesEl.innerHTML = messages.map(m => {
      const cls = m.from === 'admin' ? 'msg-admin' : 'msg-visitor';
      return `<div class="msg ${cls}"><div class="msg-text">${esc(m.text)}</div><span class="msg-time">${fmtTime(m.time)}</span></div>`;
    }).join('');
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  // Load messages
  async function loadMessages() {
    try {
      const res = await fetch(API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'poll', visitor_id: visitorId }),
      });
      if (res.ok) {
        const data = await res.json();
        render(data.messages || []);
      }
    } catch { /* silent */ }
  }

  // Send message
  async function send() {
    const text = msgInput.value.trim();
    if (!text) return;
    sendBtn.setAttribute('disabled', '');

    try {
      const res = await fetch(API, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'send', visitor_id: visitorId, text, fingerprint }),
      });
      if (res.ok) {
        msgInput.value = '';
        sentFlash.hidden = false;
        sentFlash.classList.add('show');
        setTimeout(() => {
          sentFlash.classList.remove('show');
          setTimeout(() => { sentFlash.hidden = true; }, 300);
        }, 1500);
        loadMessages();
      }
    } catch { /* silent */ }
    sendBtn.removeAttribute('disabled');
  }

  sendBtn.addEventListener('click', send);
  msgInput.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      send();
    }
  });

  // Init + poll every 30s
  loadMessages();
  setInterval(loadMessages, 30000);
</script>

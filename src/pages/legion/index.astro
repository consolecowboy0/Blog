    try {
      if (isFirstRun) {
        sysMsg(opening, 'Prompt');
      }

      if (isFirstRun && getDefense()) {
        msg('','','--- Dissertations ---', true);
        var dissertRule = 'DISSERTATION MODE: Before the group conversation begins, deliver a tight, structured dissertation on the prompt. Speak directly to the user and your colleagues. Hard cap: 80 words. Do NOT use [ACTION] or [WHISPER] tags. Do NOT use [silence]. Cover the essentials only: how you frame the problem, what your model reveals, and your tentative position. Stay in character but prioritize substance over banter.';
        for (var di = 0; di < agents.length; di++) {
          if (stopRequested) break;
          var da = agents[di];
          if (!isActive(da.name)) continue;
          if (da.name === 'The Room') continue;
          if (delayMs > 0) {
            await cancellableDelay(delayMs);
            if (stopRequested) break;
          }
          var dSystem = da.system + '\n\n' + dissertRule;
          var dMessages = [{ role: 'user', content: '[Scene direction]: ' + opening + '\n\nDeliver your full dissertation, ' + da.name + '.' }];
          var dTyp = typing(da.name, da.color);
          var dResponse = await ask(dSystem, dMessages);
          dTyp.remove();
          msg(da.name, da.color, dResponse);
          sessionTranscript.push({ name: da.name, text: dResponse, round: 0 });
          saveState();
        }
      }

      for (var r = 1; r <= rounds; r++) {
        if (stopRequested) break;
        sessionRun++;
        // Reset so bidding UI lands at chat root, not inside previous round
        currentRoundDetails = null;
        var orderMode = getOrderMode();
        if (orderMode === 'random') {
          for (var s = agents.length - 1; s > 0; s--) {
            var j = Math.floor(Math.random() * (s + 1));
            var tmp = agents[s]; agents[s] = agents[j]; agents[j] = tmp;
          }
        } else if (orderMode === 'priority') {
          var activeAgents = agents.filter(function (a) { return isActive(a.name); });
          if (activeAgents.length > 1) {
            msg('','','--- Bidding for Round ' + sessionRun + ' ---', true);

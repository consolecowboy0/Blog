# Copy to .env and fill in. Worker reads these at startup.

# Anthropic key for Messages API calls.
ANTHROPIC_API_KEY=sk-ant-...

# Must match the Astro site's AUTH_SECRET so the worker can mint legion-scope
# tokens the same way /api/auth does.
AUTH_SECRET=same-secret-as-astro

# Base URL of the Astro site. localhost for dev, production URL for prod.
LEGION_BASE_URL=http://localhost:4321

# Optional identifier surfaced in job.claimedBy for debugging multi-worker setups.
WORKER_ID=worker-local

# How often (ms) to poll for pending jobs.
POLL_INTERVAL_MS=5000

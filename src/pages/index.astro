---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const libraryItems = (await getCollection('library'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title="Dustin Landers" description="Data journalism on motorsport, politics, and systems.">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-text">
      <h1>Dustin Landers</h1>
      <p class="tagline">Dad, data scientist, aspiring race driver, discoverer of truths, builder of things people use, and pretty good at making my wife blush.</p>
      <p class="tagline-writer">The kind of writer that makes other writers nervous.</p>
    </div>
    <div class="hero-portrait">
      <picture>
        <source srcset="/images/headshot.webp" type="image/webp" />
        <img src="/images/headshot.png" alt="Dustin Landers" width="512" height="768" fetchpriority="high" decoding="async" />
      </picture>
    </div>
  </section>

  <!-- Recent Writing -->
  <section class="section">
    <div class="section-header">
      <h2>Recent Writing</h2>
      <a href="/posts" class="section-link">All posts &rarr;</a>
    </div>
    <div class="post-grid">
      {posts.map((post) => {
        const dateStr = new Date(post.data.date).toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <a href={`/posts/${post.id}`} class="card">
            <time datetime={post.data.date}>{dateStr}</time>
            <h3>{post.data.title}</h3>
            {post.data.description && <p>{post.data.description}</p>}
          </a>
        );
      })}
    </div>
  </section>

  <!-- Library -->
  <section class="section">
    <div class="section-header">
      <h2>Library</h2>
      <a href="/library" class="section-link">All items &rarr;</a>
    </div>
    <div class="post-grid">
      {libraryItems.map((item) => {
        const href = item.data.type === 'pdf' ? item.data.file : `/library/${item.id}`;
        const isPdf = item.data.type === 'pdf';
        const tagLabels = { pdf: 'PDF', interactive: 'INTERACTIVE', html: 'HTML/JS', react: 'REACT', markdown: 'DOC' } as const;
        const tagLabel = tagLabels[item.data.type];
        return (
          <a
            href={href}
            class="card"
            {...(isPdf ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <span class={`tag ${item.data.type === 'interactive' || item.data.type === 'html' || item.data.type === 'react' ? 'tag-interactive' : ''}`}>{tagLabel}</span>
            <h3>{item.data.title}</h3>
            {item.data.description && <p>{item.data.description}</p>}
          </a>
        );
      })}
    </div>
  </section>

  <!-- About -->
  <section class="section about">
    <h2>About</h2>
    <p>Background in data, tech, math, stats, politics, biology. I used to write stories as a kid. This site is about picking that back up with data journalism -- applying real statistical rigor to things I find interesting, then writing about them properly.</p>
  </section>

</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 4rem;
    margin-top: 4rem;
    margin-bottom: 4rem;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero h1 {
    font-size: 3rem;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }

  .tagline {
    font-size: 1.15rem;
    color: var(--fg-muted);
    line-height: 1.6;
    margin: 0;
  }

  .tagline-writer {
    margin: 0.6rem 0 0;
    font-size: 0.95rem;
    font-weight: 600;
    font-style: italic;
    color: var(--fg);
  }

  .hero-portrait {
    flex-shrink: 0;
    width: 220px;
    height: 220px;
    overflow: hidden;
    border-radius: 50%;
    border: 2px solid var(--border);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }

  [data-theme="dark"] .hero-portrait {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  }

  .hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    margin: 0;
    border: none;
    filter: contrast(1.05);
  }

  .section {
    margin-bottom: 4rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .section-link {
    font-size: 0.8rem;
    color: var(--fg-muted);
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  .section-link:hover {
    color: var(--fg);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
  }

  .card {
    display: block;
    padding: 1.5rem;
    text-decoration: none;
    border: none;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  .card:hover {
    background: var(--code-bg);
  }

  .card:last-child {
    border-right: none;
  }

  .card time {
    font-size: 0.7rem;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card h3 {
    font-size: 1.1rem;
    margin: 0.35rem 0 0.4rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .card p {
    font-size: 0.82rem;
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.5;
  }

  .tag {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15em 0.5em;
    border: 1px solid var(--border);
    color: var(--fg-muted);
  }

  .tag-interactive {
    border-color: #3b82f6;
    color: #3b82f6;
  }

  .about p {
    color: var(--fg-muted);
    line-height: 1.7;
  }

  .about h2 {
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  @media (max-width: 700px) {
    .hero {
      flex-direction: column-reverse;
      gap: 2rem;
      text-align: center;
      align-items: center;
    }

    .hero h1 {
      font-size: 2.25rem;
    }

    .tagline {
      margin: 0 auto;
    }

    .hero-portrait {
      width: 160px;
      height: 160px;
    }

    .post-grid {
      grid-template-columns: 1fr;
    }

    .card {
      border-right: none;
    }
  }
</style>

---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LibraryEmbed from '../../components/LibraryEmbed.astro';

export async function getStaticPaths() {
  const items = (await getCollection('library')).filter(
    (item) => item.data.type !== 'pdf'
  );
  return items.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const isEmbed = item.data.type === 'html' || item.data.type === 'react';
const rendered = !isEmbed ? await render(item) : null;
---

{isEmbed ? (
  <BaseLayout title={`${item.data.title} · Library`} description={item.data.description}>
    <nav class="back-nav">
      <a href="/" class="back-link">Home</a>
      <span class="back-sep">/</span>
      <a href="/library" class="back-link">Library</a>
    </nav>
    <LibraryEmbed
      src={item.data.file!}
      title={item.data.title}
      description={item.data.description}
      showHeader={true}
    />
  </BaseLayout>
) : (
  <PostLayout frontmatter={item.data}>
    <nav class="back-nav">
      <a href="/" class="back-link">Home</a>
      <span class="back-sep">/</span>
      <a href="/library" class="back-link">Library</a>
    </nav>
    {rendered && <rendered.Content />}
  </PostLayout>
)}

<style>
  .back-nav {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .back-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--fg-muted);
    text-decoration: none;
    border: none;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--fg);
  }

  .back-sep {
    font-size: 0.75rem;
    color: var(--fg-muted);
    opacity: 0.5;
  }
</style>

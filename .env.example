# Copy to .env and fill in real values. Do NOT commit .env.

# --- Auth (required) ---------------------------------------------------------
# HMAC secret for signing session tokens. Generate: `openssl rand -hex 32`
AUTH_SECRET=

# SHA-256 hex of the legion (agents) password. Generate:
#   printf '%s' 'your-password' | shasum -a 256
AUTH_HASH_LEGION=

# SHA-256 hex of the backend (editor) password. MUST be distinct from legion.
AUTH_HASH_BACKEND=

# Comma-separated list of allowed CORS origins (in addition to the defaults
# https://dustinlanders.com and https://www.dustinlanders.com).
ALLOWED_ORIGINS=

# Canonical site URL used by Astro for RSS and canonical links.
SITE_URL=https://dustinlanders.com

# --- Anthropic / Agent SDK ---------------------------------------------------
# API-key mode (agent-chat endpoint). Leave unset to disable direct API mode.
ANTHROPIC_API_KEY=

# --- GitHub posts editor -----------------------------------------------------
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# --- Firebase (DM inbox) -----------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the key with literal \n for newlines, surrounded by quotes.
FIREBASE_PRIVATE_KEY=""

# --- DM notifications --------------------------------------------------------
RESEND_API_KEY=
# Must be set, otherwise notifications are skipped.
NOTIFY_EMAIL=

# --- Optional third-party APIs ----------------------------------------------
BRAVE_SEARCH_API_KEY=
PIXELLAB_API_KEY=

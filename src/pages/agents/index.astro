---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Agents - dustinlanders.com" description="Multi-agent chat room.">
  <div id="gate">
    <div class="gate-box">
      <p class="gate-label">This area is private.</p>
      <input type="password" id="gate-password" placeholder="Password" autocomplete="off" />
      <button id="gate-unlock">Unlock</button>
      <p id="gate-error" class="gate-error"></p>
    </div>
  </div>

  <section id="panel" style="display: none;">
    <div class="panel-header">
      <div class="panel-title-row">
        <h1>Agents</h1>
        <button id="sign-out" class="secondary-btn">Sign Out</button>
      </div>
      <p class="panel-sub">Configure agents, set the scene, and watch them talk.</p>
    </div>

    <div class="upload-section">
      <label class="field-label">Room</label>
      <div class="upload-row">
        <button id="upload-room" class="upload-btn">Upload JSON</button>
        <span id="room-status" class="upload-status">No room loaded</span>
      </div>
    </div>

    <div class="upload-section">
      <label class="field-label">Characters</label>
      <div class="agents-grid" id="agents-grid"></div>
      <button id="add-agent" class="add-agent">+ Upload Character</button>
    </div>

    <div class="prompt-section">
      <label class="field-label" for="opening">Opening prompt</label>
      <input type="text" id="opening" value="It's noon." />
    </div>

    <div class="controls">
      <div class="rounds-group">
        <label class="field-label" for="rounds">Rounds</label>
        <input type="number" id="rounds" min="1" max="10" value="2" />
      </div>
      <button id="go-btn">Go</button>
      <button id="stop-btn" class="secondary-btn" style="display:none;">Stop</button>
      <button id="clear-btn" class="secondary-btn">Clear</button>
    </div>

    <div id="chat" class="chat">
      <p class="chat-placeholder">Hit Go to start.</p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
(function () {
  var HASH = '48d5e01666b2a0cf736186d47e5e0e56e588fc2fbc24e598b0e849086bbcb846';
  var COLORS = ['#e05252','#3b82f6','#22c55e','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#f97316'];

  async function sha256(s) {
    var b = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(s));
    return Array.from(new Uint8Array(b)).map(function (x) { return x.toString(16).padStart(2,'0'); }).join('');
  }

  // Gate
  if (localStorage.getItem('agents_auth') === 'true') show();

  document.getElementById('gate-unlock').addEventListener('click', async function () {
    var h = await sha256(document.getElementById('gate-password').value);
    if (h === HASH) { localStorage.setItem('agents_auth','true'); show(); }
    else { document.getElementById('gate-error').textContent = 'Nope.'; document.getElementById('gate-password').value = ''; }
  });

  document.getElementById('gate-password').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') document.getElementById('gate-unlock').click();
  });

  function show() {
    document.getElementById('gate').style.display = 'none';
    document.getElementById('panel').style.display = 'block';
  }

  document.getElementById('sign-out').addEventListener('click', function () {
    localStorage.removeItem('agents_auth');
    document.getElementById('panel').style.display = 'none';
    document.getElementById('gate').style.display = 'flex';
    document.getElementById('gate-password').value = '';
    document.getElementById('gate-error').textContent = '';
  });

  // Room upload
  var roomData = null;
  document.getElementById('upload-room').addEventListener('click', function () {
    var input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json';
    input.addEventListener('change', function () {
      var file = input.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function () {
        try {
          roomData = JSON.parse(reader.result);
          document.getElementById('room-status').textContent = roomData.name || file.name;
        } catch (e) {
          document.getElementById('room-status').textContent = 'Invalid JSON';
          roomData = null;
        }
      };
      reader.readAsText(file);
    });
    input.click();
  });

  function jsonToPrompt(obj) {
    var lines = [];
    Object.keys(obj).forEach(function (k) {
      var v = obj[k];
      if (typeof v === 'object' && v !== null) v = JSON.stringify(v);
      lines.push(k + ': ' + v);
    });
    return lines.join('\n');
  }

  // Add agent via file upload
  document.getElementById('add-agent').addEventListener('click', function () {
    var input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json';
    input.addEventListener('change', function () {
      var file = input.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function () {
        try {
          var data = JSON.parse(reader.result);
        } catch (e) { return; }
        var grid = document.getElementById('agents-grid');
        var n = grid.children.length;
        var color = COLORS[n % COLORS.length];
        var name = data.name || data.Name || file.name.replace('.json','');
        var card = document.createElement('div');
        card.className = 'agent-card';
        card.setAttribute('data-agent', n);
        card._charData = data;
        card.innerHTML =
          '<span class="agent-dot" style="background:' + color + ';"></span>' +
          '<span class="agent-name-label">' + name + '</span>' +
          '<div class="card-controls">' +
            '<button class="order-btn move-up" title="Move up">^</button>' +
            '<button class="order-btn move-down" title="Move down">v</button>' +
            '<button class="remove-btn" title="Remove">x</button>' +
          '</div>';
        grid.appendChild(card);
        card.querySelector('.remove-btn').addEventListener('click', function () { grid.removeChild(card); });
        card.querySelector('.move-up').addEventListener('click', function () {
          var prev = card.previousElementSibling;
          if (prev) grid.insertBefore(card, prev);
        });
        card.querySelector('.move-down').addEventListener('click', function () {
          var next = card.nextElementSibling;
          if (next) grid.insertBefore(next, card);
        });
      };
      reader.readAsText(file);
    });
    input.click();
  });

  function delay(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }

  // Chat helpers
  function msg(name, color, text, system) {
    var chat = document.getElementById('chat');
    var ph = chat.querySelector('.chat-placeholder');
    if (ph) ph.remove();
    var el = document.createElement('div');
    el.className = 'chat-msg' + (system ? ' chat-sys' : '');
    if (system) { el.textContent = text; }
    else {
      var n = document.createElement('span');
      n.className = 'msg-name';
      n.style.color = color;
      n.textContent = name;
      var t = document.createElement('div');
      t.className = 'msg-text';
      t.textContent = text;
      el.appendChild(n);
      el.appendChild(t);
    }
    chat.appendChild(el);
    chat.scrollTop = chat.scrollHeight;
    return el;
  }

  function typing(name, color) {
    var chat = document.getElementById('chat');
    var ph = chat.querySelector('.chat-placeholder');
    if (ph) ph.remove();
    var el = document.createElement('div');
    el.className = 'chat-msg chat-typing';
    var n = document.createElement('span');
    n.className = 'msg-name';
    n.style.color = color;
    n.textContent = name;
    var d = document.createElement('span');
    d.className = 'dots';
    d.innerHTML = '<span>.</span><span>.</span><span>.</span>';
    el.appendChild(n);
    el.appendChild(d);
    chat.appendChild(el);
    chat.scrollTop = chat.scrollHeight;
    return el;
  }

  async function ask(system, messages) {
    var res = await fetch('/api/agent-chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ system: system, messages: messages, model: 'claude-sonnet-4-20250514' }),
    });
    if (!res.ok) {
      var err = '';
      try { var b = await res.json(); err = b.error || JSON.stringify(b); } catch(e) { try { err = await res.text(); } catch(e2) {} }
      throw new Error('API error (' + res.status + '): ' + (err || 'unknown'));
    }
    var data = await res.json();
    return data.text;
  }

  // Persistent state across Go presses
  var sessionTranscript = [];
  var sessionAgents = null;
  var sessionRun = 0;
  var stopRequested = false;

  // Stop
  document.getElementById('stop-btn').addEventListener('click', function () {
    stopRequested = true;
  });

  // Clear
  document.getElementById('clear-btn').addEventListener('click', function () {
    stopRequested = true;
    document.getElementById('chat').innerHTML = '<p class="chat-placeholder">Hit Go to start.</p>';
    sessionTranscript = [];
    sessionAgents = null;
    sessionRun = 0;
  });

  // Go
  document.getElementById('go-btn').addEventListener('click', async function () {
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Running...';
    stopRequested = false;
    document.getElementById('stop-btn').style.display = '';

    var opening = document.getElementById('opening').value.trim();
    var rounds = parseInt(document.getElementById('rounds').value, 10) || 2;
    var isFirstRun = !sessionAgents;

    if (isFirstRun) {
      var scene = roomData ? jsonToPrompt(roomData) : '';
      sessionAgents = [];
      var allNames = [];
      document.querySelectorAll('.agent-card').forEach(function (card) {
        var charData = card._charData;
        var name = charData ? (charData.name || charData.Name || 'Agent') : 'Agent';
        allNames.push(name);
      });

      document.querySelectorAll('.agent-card').forEach(function (card, i) {
        var charData = card._charData;
        var base = charData ? jsonToPrompt(charData) : '';
        var otherNames = allNames.filter(function (n, j) { return j !== i; });
        var chatRule = 'You are in a group chat with: ' + otherNames.join(', ') + '. Stay in character at all times. Write only dialogue -- short, natural lines like a real person talking. No narration, no stage directions, no actions, no asterisks. Do not describe what you or others are doing. Do not ask for context or clarification. Do not break character. Just talk. Keep it under 60 words. If your character would stay silent in this moment, respond with exactly "[silence]" and nothing else.';
        var full = chatRule + '\n\n' + (scene ? 'Setting:\n' + scene + '\n\n' : '') + 'Your character:\n' + base;
        sessionAgents.push({
          name: allNames[i],
          system: full,
          color: COLORS[i % COLORS.length],
        });
      });

      if (sessionAgents.length < 2) { msg('','','Need at least 2 agents.',true); btn.disabled = false; btn.textContent = 'Go'; document.getElementById('stop-btn').style.display = 'none'; sessionAgents = null; return; }
      if (!opening) { msg('','','Enter an opening prompt.',true); btn.disabled = false; btn.textContent = 'Go'; document.getElementById('stop-btn').style.display = 'none'; sessionAgents = null; return; }
    }

    var agents = sessionAgents;

    function buildTranscript() {
      if (sessionTranscript.length === 0) return '[Scene direction]: ' + opening;
      var lines = ['[Scene direction]: ' + opening];
      for (var t = 0; t < sessionTranscript.length; t++) {
        lines.push(sessionTranscript[t].name + ': ' + sessionTranscript[t].text);
      }
      return lines.join('\n');
    }

    try {
      if (isFirstRun) {
        msg('','', opening, true);
      }

      for (var r = 1; r <= rounds; r++) {
        if (stopRequested) break;
        sessionRun++;
        msg('','','--- Round ' + sessionRun + ' ---', true);
        for (var i = 0; i < agents.length; i++) {
          if (stopRequested) break;
          var a = agents[i];
          await delay(10000);
          if (stopRequested) break;
          var transcript = buildTranscript();
          var messages = [{ role: 'user', content: transcript + '\n\nIt is now your turn to speak, ' + a.name + '.' }];
          var typ = typing(a.name, a.color);
          var response = await ask(a.system, messages);
          typ.remove();
          if (response.trim() === '[silence]') {
            msg(a.name, a.color, '...', false);
            sessionTranscript.push({ name: a.name, text: '...' });
          } else {
            msg(a.name, a.color, response);
            sessionTranscript.push({ name: a.name, text: response });
          }
        }
      }
      if (stopRequested) {
        msg('','','--- Stopped ---', true);
      } else {
        var done = msg('','','--- Done ---', true);
        done.style.marginBottom = '2rem';
      }
    } catch (err) {
      msg('','','Error: ' + err.message, true);
    }

    btn.disabled = false;
    btn.textContent = 'Go';
    document.getElementById('stop-btn').style.display = 'none';
  });
})();
</script>

<style>
  /* Gate */
  #gate {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 40vh;
  }
  .gate-box { text-align: center; }
  .gate-label { font-size: 0.85rem; color: var(--fg-muted); margin-bottom: 1rem; }
  #gate-password {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    width: 200px;
    outline: none;
  }
  #gate-password:focus { border-color: var(--fg-muted); }
  #gate-unlock {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    cursor: pointer;
    margin-left: 0.5rem;
  }
  #gate-unlock:hover { background: var(--code-bg); }
  .gate-error { font-size: 0.8rem; color: var(--fg-muted); margin-top: 0.75rem; min-height: 1.2em; }

  /* Panel */
  .panel-title-row { display: flex; justify-content: space-between; align-items: center; }
  .panel-header h1 { margin-top: 1rem; margin-bottom: 0.25rem; }
  .panel-sub { color: var(--fg-muted); font-size: 0.9rem; margin-bottom: 2rem; }

  .field-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    margin-bottom: 0.4rem;
  }

  /* Agent cards */
  .agents-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .agent-card {
    display: inline-flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--border);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
  }
  .agent-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .agent-name-label {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    flex: 1;
    min-width: 0;
  }
  .remove-btn {
    font-size: 0.6rem;
    background: none;
    border: none;
    color: var(--fg-muted);
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }
  .card-controls { display: flex; gap: 0.6rem; margin-left: 0.25rem; }
  .order-btn, .remove-btn {
    font-size: 0.7rem;
    background: none;
    border: none;
    color: var(--fg-muted);
    cursor: pointer;
    padding: 0.15rem;
    line-height: 1;
    font-family: var(--font-mono);
  }
  .order-btn:hover { color: var(--fg); }
  .remove-btn:hover { color: #e05252; }
  .add-agent {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border: 1px dashed var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
    margin-bottom: 1rem;
  }
  .add-agent:hover { color: var(--fg); border-color: var(--fg); }

  /* Upload */
  .upload-section { margin-bottom: 1.5rem; }
  .upload-row { display: flex; align-items: center; gap: 0.75rem; }
  .upload-btn {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
  }
  .upload-btn:hover { color: var(--fg); border-color: var(--fg); }
  .upload-status {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-muted);
  }

  /* Opening */
  .prompt-section { margin-bottom: 1rem; }
  #opening {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    outline: none;
    line-height: 1.5;
  }
  #opening:focus { border-color: var(--fg-muted); }

  /* Controls */
  .controls {
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .rounds-group { display: flex; flex-direction: column; }
  #rounds {
    width: 50px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.4rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    text-align: center;
    outline: none;
  }
  #go-btn {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.45rem 1.5rem;
    border: 1px solid var(--fg);
    background: var(--fg);
    color: var(--bg);
    cursor: pointer;
  }
  #go-btn:hover { opacity: 0.85; }
  #go-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .secondary-btn {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    cursor: pointer;
  }
  .secondary-btn:hover { color: var(--fg); }

  /* Chat */
  .chat {
    border: 1px solid var(--border);
    min-height: 300px;
    max-height: 65vh;
    overflow-y: auto;
    padding: 1rem;
    margin-bottom: 2rem;
    background: var(--code-bg);
  }
  .chat-placeholder {
    color: var(--fg-muted);
    font-size: 0.85rem;
    font-style: italic;
    text-align: center;
    padding: 3rem 0;
  }
  .chat-msg { margin-bottom: 1rem; line-height: 1.6; }
  .chat-msg:last-child { margin-bottom: 0; }
  .chat-sys {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg);
    text-align: center;
    padding: 1rem 0 0.5rem;
  }
  .msg-name {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: block;
    margin-bottom: 0.2rem;
  }
  .msg-text {
    font-size: 1.15rem;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .chat-typing {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .dots span {
    animation: blink 1.4s infinite both;
    font-size: 1.5rem;
    line-height: 0.5;
    color: var(--fg-muted);
  }
  .dots span:nth-child(2) { animation-delay: 0.2s; }
  .dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink {
    0%, 80%, 100% { opacity: 0.2; }
    40% { opacity: 1; }
  }
  @media (max-width: 600px) {
    .agents-grid { grid-template-columns: 1fr; }
    .controls { flex-wrap: wrap; }
  }
</style>

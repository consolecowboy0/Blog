  function getRelsForAgent(name, presentNames) {
    if (!relsData || !relsData.relationships) return '';
    var lines = [];
    relsData.relationships.forEach(function (r) {
      if (r.between.indexOf(name) === -1) return;
      var other = r.between[0] === name ? r.between[1] : r.between[0];
      if (presentNames.indexOf(other) === -1) return;
      lines.push('Relationship with ' + other + ':');
      lines.push('  type: ' + r.type);
      if (r.history) lines.push('  history: ' + r.history);
      if (r.current_tension) lines.push('  current tension: ' + r.current_tension);
      if (r.shared_knowledge) lines.push('  shared knowledge: ' + r.shared_knowledge);
    });
    return lines.length ? lines.join('\n') : '';
  }

  function jsonToPrompt(obj, indent) {
    indent = indent || 0;
    var pad = '';
    for (var p = 0; p < indent; p++) pad += '  ';
    var lines = [];
    Object.keys(obj).forEach(function (k) {
      var v = obj[k];
      if (Array.isArray(v)) {
        lines.push(pad + k + ':');
        v.forEach(function (item) {
          if (typeof item === 'object' && item !== null) {
            lines.push(pad + '  -');
            lines.push(jsonToPrompt(item, indent + 2));
          } else {
            lines.push(pad + '  - ' + item);
          }
        });
      } else if (typeof v === 'object' && v !== null) {
        lines.push(pad + k + ':');
        lines.push(jsonToPrompt(v, indent + 1));
      } else {
        lines.push(pad + k + ': ' + v);
      }
    });
    return lines.join('\n');
  }

  // --- Character cards ---
  function buildCharDesc(data) {
    var parts = [];
    if (data.occupation) parts.push(data.occupation);
    if (data.model_description) parts.push(data.model_description);
    if (!parts.length && data.personality && data.personality.core_traits && data.personality.core_traits.length) {
      parts.push(data.personality.core_traits.slice(0, 3).join(', '));
    }
    if (!parts.length && data.backstory) {
      var first = data.backstory.split('.')[0];
      if (first.length > 80) first = first.substring(0, 77) + '...';
      parts.push(first);
    }
    var desc = parts.join(' -- ');
    return desc;
  }



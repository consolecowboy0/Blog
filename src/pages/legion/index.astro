  // --- Pyodide (browser Python) ---
  var pyodideReady = null; // promise
  var pyodideInstance = null;

  function ensurePyodide() {
    if (pyodideReady) return pyodideReady;
    pyodideReady = new Promise(function (resolve, reject) {
      var script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/pyodide/v0.27.7/full/pyodide.js';
      script.onload = async function () {
        try {
          pyodideInstance = await loadPyodide();
          await pyodideInstance.loadPackage(['matplotlib', 'numpy']);
          // Patch plt.show() to capture figures as base64
          // Add math compat shim for numpy (np.math removed in newer versions)
          pyodideInstance.runPython(`
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import io, base64, math, numpy as np

# Shim: np.math was removed in numpy 2.x, redirect to stdlib math
if not hasattr(np, 'math'):
    np.math = math

_captured_figures = []

_orig_show = plt.show
def _capture_show(*args, **kwargs):
    for fig_num in plt.get_fignums():
        fig = plt.figure(fig_num)
        buf = io.BytesIO()
        fig.savefig(buf, format='png', bbox_inches='tight', dpi=100)
        buf.seek(0)
        _captured_figures.append(base64.b64encode(buf.read()).decode('utf-8'))
        buf.close()
    plt.close('all')
plt.show = _capture_show
`);
          resolve(pyodideInstance);
        } catch (e) { reject(e); }
      };
      script.onerror = function () { reject(new Error('Failed to load Pyodide')); };
      document.head.appendChild(script);
    });
    return pyodideReady;
  }

  async function runPythonCode(code) {
    var py = await ensurePyodide();
    py.runPython('_captured_figures = []');
    // Capture stdout
    py.runPython(`
import sys, io
_stdout_capture = io.StringIO()
sys.stdout = _stdout_capture
`);
    try {
      py.runPython(code);
    } catch (e) {
      // Restore stdout before returning error
      py.runPython('sys.stdout = sys.__stdout__');
      return { stdout: '', error: e.message, figures: [] };
    }
    var stdout = py.runPython('_stdout_capture.getvalue()');
    py.runPython('sys.stdout = sys.__stdout__');
    var figs = py.runPython('_captured_figures').toJs();
    return { stdout: stdout, error: null, figures: Array.from(figs) };
  }


---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Agents - dustinlanders.com" description="Multi-agent chat room.">
  <div id="gate">
    <div class="gate-box">
      <p class="gate-label">This area is private.</p>
      <input type="password" id="gate-password" placeholder="Password" autocomplete="off" />
      <button id="gate-unlock">Unlock</button>
      <p id="gate-error" class="gate-error"></p>
    </div>
  </div>

  <section id="panel" style="display: none;">
    <div class="panel-header">
      <div class="panel-title-row">
        <h1>Agents</h1>
        <div class="header-controls">
          <button id="save-config" class="secondary-btn">Save</button>
          <button id="load-config" class="secondary-btn">Load</button>
          <button id="sign-out" class="secondary-btn">Sign Out</button>
        </div>
      </div>
      <p class="panel-sub">Configure agents, set the scene, and watch them talk.</p>
    </div>

    <details class="setup-group" open>
      <summary class="field-label setup-toggle">Setup</summary>

      <div class="upload-section">
        <label class="field-label">Room</label>
        <div class="upload-row">
          <button id="upload-room" class="upload-btn">Upload JSON</button>
          <button id="clear-room" class="clear-upload-btn" style="display:none;">Clear</button>
          <span id="room-status" class="upload-status">No room loaded</span>
        </div>
      </div>

      <div class="upload-section">
        <label class="field-label">Relationships</label>
        <div class="upload-row">
          <button id="upload-rels" class="upload-btn">Upload JSON</button>
          <button id="clear-rels" class="clear-upload-btn" style="display:none;">Clear</button>
          <span id="rels-status" class="upload-status">No relationships loaded</span>
        </div>
      </div>

      <div class="upload-section">
        <label class="field-label">Characters</label>
        <div class="agents-grid" id="agents-grid"></div>
        <button id="add-agent" class="add-agent">+ Upload Characters</button>
      </div>

      <div class="prompt-section">
        <label class="field-label" for="opening">Prompt</label>
        <textarea id="opening" rows="2">It's noon.</textarea>
      </div>

      <div class="controls">
        <div class="control-group">
          <label class="field-label" for="rounds">Rounds</label>
          <input type="number" id="rounds" min="1" max="50" value="2" />
        </div>
        <div class="control-group">
          <label class="field-label" for="delay-input">Delay (s)</label>
          <input type="number" id="delay-input" min="0" max="60" value="10" />
        </div>
        <div class="control-group">
          <label class="field-label" for="mode-select">Mode</label>
          <select id="mode-select">
            <option value="api">API</option>
            <option value="agent-sdk">Agent SDK</option>
          </select>
        </div>
        <div class="control-group">
          <label class="field-label" for="model-select">Model</label>
          <select id="model-select">
            <option value="claude-sonnet-4-20250514">Sonnet 4</option>
            <option value="claude-opus-4-20250514">Opus 4</option>
            <option value="claude-haiku-4-5-20251001">Haiku 4.5</option>
          </select>
        </div>
      </div>
    </details>

    <div class="run-controls">
      <button id="go-btn">Go</button>
      <button id="stop-btn" class="secondary-btn" style="display:none;">Stop</button>
      <button id="clear-btn" class="secondary-btn">Clear</button>
      <button id="export-btn" class="secondary-btn" style="display:none;">Export</button>
      <button id="move-room-btn" class="secondary-btn" style="display:none;">Move Room</button>
    </div>

    <div id="status-panel" class="status-panel" style="display:none;">
      <label class="field-label">Status</label>
      <div id="status-list" class="status-list"></div>
    </div>

    <div class="chat-wrapper">
      <div class="section-header">
        <span></span>
        <button id="copy-chat" class="copy-btn" title="Copy chat">Copy</button>
      </div>
      <div id="chat" class="chat">
        <p class="chat-placeholder">Hit Go to start.</p>
      </div>
    </div>

    <div class="interject-section" id="interject-section" style="display:none;">
      <div class="interject-row">
        <input type="text" id="interject-input" placeholder="Interject..." />
        <button id="interject-btn" class="secondary-btn">Send</button>
      </div>
    </div>

    <div id="summary-section" class="summary-section" style="display:none;">
      <div class="section-header">
        <label class="field-label">Summary</label>
        <button id="copy-summary" class="copy-btn" title="Copy summary">Copy</button>
      </div>
      <textarea id="summary-output" class="summary-output" rows="4" readonly placeholder="Hit Summarize to recap the conversation."></textarea>
      <button id="summarize-btn" class="secondary-btn">Summarize</button>
    </div>

    <div id="illustration-section" class="illustration-section" style="display:none;">
      <div class="illustration-controls">
        <label class="field-label">Illustration</label>
        <label class="auto-illustrate-label"><input type="checkbox" id="auto-illustrate" /> Auto-illustrate</label>
      </div>
      <div class="illustration-box">
        <img id="illustration-img" class="illustration-img" style="display:none;" alt="Scene illustration" />
        <p id="illustration-placeholder" class="illustration-placeholder">Hit Illustrate to generate pixel art of the scene.</p>
      </div>
      <button id="illustrate-btn" type="button" class="secondary-btn">Illustrate</button>
    </div>
  </section>
</BaseLayout>

<script is:inline>
(function () {
  var HASH = '48d5e01666b2a0cf736186d47e5e0e56e588fc2fbc24e598b0e849086bbcb846';
  var COLORS = ['#e05252','#3b82f6','#22c55e','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#f97316'];
  var MAX_TRANSCRIPT_MESSAGES = 30;

  async function sha256(s) {
    var b = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(s));
    return Array.from(new Uint8Array(b)).map(function (x) { return x.toString(16).padStart(2,'0'); }).join('');
  }

  // Gate
  if (localStorage.getItem('agents_auth') === 'true') show();

  document.getElementById('gate-unlock').addEventListener('click', async function () {
    var h = await sha256(document.getElementById('gate-password').value);
    if (h === HASH) { localStorage.setItem('agents_auth','true'); show(); }
    else { document.getElementById('gate-error').textContent = 'Nope.'; document.getElementById('gate-password').value = ''; }
  });

  document.getElementById('gate-password').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') document.getElementById('gate-unlock').click();
  });

  function show() {
    document.getElementById('gate').style.display = 'none';
    document.getElementById('panel').style.display = 'block';
  }

  document.getElementById('sign-out').addEventListener('click', function () {
    localStorage.removeItem('agents_auth');
    document.getElementById('panel').style.display = 'none';
    document.getElementById('gate').style.display = 'flex';
    document.getElementById('gate-password').value = '';
    document.getElementById('gate-error').textContent = '';
  });

  // --- Data ---
  var roomData = null;
  var relsData = null;

  function pickFile(multiple, onSuccess, onError) {
    var input = document.createElement('input');
    input.type = 'file';
    input.accept = '.json';
    if (multiple) input.multiple = true;
    input.addEventListener('change', function () {
      Array.from(input.files).forEach(function (file) {
        var reader = new FileReader();
        reader.onload = function () {
          try {
            var data = JSON.parse(reader.result);
            onSuccess(data, file.name);
          } catch (e) {
            if (onError) onError(file.name);
          }
        };
        reader.readAsText(file);
      });
    });
    input.click();
  }

  // Room upload
  document.getElementById('upload-room').addEventListener('click', function () {
    pickFile(false, function (data) {
      roomData = data;
      document.getElementById('room-status').textContent = data.name || 'Loaded';
      document.getElementById('clear-room').style.display = '';
    }, function () {
      document.getElementById('room-status').textContent = 'Invalid JSON';
      roomData = null;
    });
  });
  document.getElementById('clear-room').addEventListener('click', function () {
    roomData = null;
    document.getElementById('room-status').textContent = 'No room loaded';
    document.getElementById('clear-room').style.display = 'none';
  });

  // Relationships upload
  document.getElementById('upload-rels').addEventListener('click', function () {
    pickFile(false, function (data) {
      relsData = data;
      document.getElementById('rels-status').textContent = data.name || 'Loaded';
      document.getElementById('clear-rels').style.display = '';
    }, function () {
      document.getElementById('rels-status').textContent = 'Invalid JSON';
      relsData = null;
    });
  });
  document.getElementById('clear-rels').addEventListener('click', function () {
    relsData = null;
    document.getElementById('rels-status').textContent = 'No relationships loaded';
    document.getElementById('clear-rels').style.display = 'none';
  });

  function getRelsForAgent(name, presentNames) {
    if (!relsData || !relsData.relationships) return '';
    var lines = [];
    relsData.relationships.forEach(function (r) {
      if (r.between.indexOf(name) === -1) return;
      var other = r.between[0] === name ? r.between[1] : r.between[0];
      if (presentNames.indexOf(other) === -1) return;
      lines.push('Relationship with ' + other + ':');
      lines.push('  type: ' + r.type);
      if (r.history) lines.push('  history: ' + r.history);
      if (r.current_tension) lines.push('  current tension: ' + r.current_tension);
      if (r.shared_knowledge) lines.push('  shared knowledge: ' + r.shared_knowledge);
    });
    return lines.length ? lines.join('\n') : '';
  }

  function jsonToPrompt(obj, indent) {
    indent = indent || 0;
    var pad = '';
    for (var p = 0; p < indent; p++) pad += '  ';
    var lines = [];
    Object.keys(obj).forEach(function (k) {
      var v = obj[k];
      if (Array.isArray(v)) {
        lines.push(pad + k + ':');
        v.forEach(function (item) {
          if (typeof item === 'object' && item !== null) {
            lines.push(pad + '  -');
            lines.push(jsonToPrompt(item, indent + 2));
          } else {
            lines.push(pad + '  - ' + item);
          }
        });
      } else if (typeof v === 'object' && v !== null) {
        lines.push(pad + k + ':');
        lines.push(jsonToPrompt(v, indent + 1));
      } else {
        lines.push(pad + k + ': ' + v);
      }
    });
    return lines.join('\n');
  }

  // --- Character cards ---
  function addAgentCard(data, fallbackName) {
    var grid = document.getElementById('agents-grid');
    var n = grid.children.length;
    var color = COLORS[n % COLORS.length];
    var name = data.name || data.Name || fallbackName.replace('.json', '');
    var card = document.createElement('div');
    card.className = 'agent-card';
    card.setAttribute('data-agent', n);
    card._charData = data;
    card.innerHTML =
      '<span class="agent-dot" style="background:' + color + ';"></span>' +
      '<span class="agent-name-label">' + name + '</span>' +
      '<div class="card-controls">' +
        '<button class="order-btn move-up" title="Move up">^</button>' +
        '<button class="order-btn move-down" title="Move down">v</button>' +
        '<button class="remove-btn" title="Remove">x</button>' +
      '</div>';
    grid.appendChild(card);
    card.querySelector('.remove-btn').addEventListener('click', function () { grid.removeChild(card); });
    card.querySelector('.move-up').addEventListener('click', function () {
      var prev = card.previousElementSibling;
      if (prev) grid.insertBefore(card, prev);
    });
    card.querySelector('.move-down').addEventListener('click', function () {
      var next = card.nextElementSibling;
      if (next) grid.insertBefore(next, card);
    });
  }

  document.getElementById('add-agent').addEventListener('click', function () {
    pickFile(true, function (data, fileName) {
      addAgentCard(data, fileName);
    });
  });

  // --- Cancellable delay ---
  var delayCancelFn = null;

  function cancellableDelay(ms) {
    return new Promise(function (resolve) {
      if (ms <= 0 || stopRequested) { resolve(); return; }
      var timer = setTimeout(resolve, ms);
      delayCancelFn = function () {
        clearTimeout(timer);
        resolve();
      };
    });
  }

  // --- Save / Load config ---
  document.getElementById('save-config').addEventListener('click', function () {
    var chars = [];
    document.querySelectorAll('.agent-card').forEach(function (card) {
      if (card._charData) chars.push(card._charData);
    });
    var config = {
      room: roomData,
      relationships: relsData,
      characters: chars,
      opening: document.getElementById('opening').value,
      rounds: document.getElementById('rounds').value,
      delay: document.getElementById('delay-input').value,
      model: document.getElementById('model-select').value,
      mode: document.getElementById('mode-select').value
    };
    localStorage.setItem('agents_config', JSON.stringify(config));
    var btn = document.getElementById('save-config');
    btn.textContent = 'Saved';
    setTimeout(function () { btn.textContent = 'Save'; }, 1500);
  });

  function loadConfig(showFeedback) {
    var raw = localStorage.getItem('agents_config');
    if (!raw) return;
    try { var config = JSON.parse(raw); } catch (e) { return; }

    if (config.room) {
      roomData = config.room;
      document.getElementById('room-status').textContent = config.room.name || 'Loaded';
      document.getElementById('clear-room').style.display = '';
    }
    if (config.relationships) {
      relsData = config.relationships;
      document.getElementById('rels-status').textContent = config.relationships.name || 'Loaded';
      document.getElementById('clear-rels').style.display = '';
    }
    if (config.characters) {
      document.getElementById('agents-grid').innerHTML = '';
      config.characters.forEach(function (c) { addAgentCard(c, 'Agent'); });
    }
    if (config.opening) document.getElementById('opening').value = config.opening;
    if (config.rounds) document.getElementById('rounds').value = config.rounds;
    if (config.delay) document.getElementById('delay-input').value = config.delay;
    if (config.model) document.getElementById('model-select').value = config.model;
    if (config.mode) document.getElementById('mode-select').value = config.mode;

    if (showFeedback) {
      var btn = document.getElementById('load-config');
      btn.textContent = 'Loaded';
      setTimeout(function () { btn.textContent = 'Load'; }, 1500);
    }
  }

  document.getElementById('load-config').addEventListener('click', function () { loadConfig(true); });

  // Auto-load saved config on page load
  loadConfig(false);

  // --- Export transcript ---
  document.getElementById('export-btn').addEventListener('click', function () {
    if (sessionTranscript.length === 0) return;
    var lines = ['[Scene direction]: ' + document.getElementById('opening').value.trim(), ''];
    var currentRound = 0;
    sessionTranscript.forEach(function (entry) {
      if (entry.round !== currentRound) {
        currentRound = entry.round;
        lines.push('');
        lines.push('--- Round ' + currentRound + ' ---');
      }
      var exportText = entry.rawText || entry.text;
      lines.push(entry.name + ': ' + exportText);
    });
    var blob = new Blob([lines.join('\n')], { type: 'text/plain' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'transcript_' + new Date().toISOString().slice(0, 10) + '.txt';
    a.click();
    URL.revokeObjectURL(a.href);
  });

  // --- Summarize ---
  document.getElementById('summarize-btn').addEventListener('click', async function () {
    if (sessionTranscript.length === 0) return;
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Summarizing...';
    var output = document.getElementById('summary-output');
    output.value = '';
    var lines = ['[Scene direction]: ' + document.getElementById('opening').value.trim(), ''];
    sessionTranscript.forEach(function (entry) {
      lines.push(entry.name + ': ' + (entry.rawText || entry.text));
    });
    var transcript = lines.join('\n');
    try {
      var text = await ask(
        'You summarize conversations. Write a short, vivid recap of what happened. Focus on key events, conflicts, and character dynamics. Keep it under 200 words.',
        [{ role: 'user', content: 'Summarize this conversation:\n\n' + transcript }]
      );
      output.value = text;
    } catch (err) {
      output.value = 'Error: ' + err.message;
    }
    btn.disabled = false;
    btn.textContent = 'Summarize';
  });

  // --- Illustrate (shared logic) ---
  async function generateIllustration() {
    if (sessionTranscript.length === 0) return;

    var charDetails = [];
    document.querySelectorAll('.agent-card').forEach(function (card) {
      if (card._charData) {
        var c = card._charData;
        var name = c.name || c.Name || 'Unknown';
        var appearance = c.appearance || '';
        if (appearance) charDetails.push(name + ': ' + appearance);
      }
    });
    var roomDesc = roomData ? jsonToPrompt(roomData) : '';

    var lines = ['[Scene direction]: ' + document.getElementById('opening').value.trim(), ''];
    if (charDetails.length > 0) {
      lines.push('[Character appearances]:');
      charDetails.forEach(function (d) { lines.push(d); });
      lines.push('');
    }
    if (roomDesc) {
      lines.push('[Setting]: ' + roomDesc);
      lines.push('');
    }
    sessionTranscript.forEach(function (entry) {
      lines.push(entry.name + ': ' + (entry.rawText || entry.text));
    });
    var fullTranscript = lines.join('\n');

    var pixelPrompt = await ask(
      'You write detailed image generation prompts. Read the full conversation, character appearances, and setting. Identify the most dramatic or important recent moment. Write a richly detailed visual description of that single moment as a scene. Include each character present by their physical appearance (hair, clothing, build, distinguishing features) -- do not use names, only describe what they look like. Describe their poses, expressions, body language, and positions relative to each other. Describe the environment: lighting, objects, atmosphere. Write it as one dense paragraph, 60-100 words. Aim for cinematic realism. No dialogue. No names.',
      [{ role: 'user', content: fullTranscript }]
    );

    var res = await fetch('/api/pixellab', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ description: pixelPrompt, width: 400, height: 400 }),
    });
    var data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Illustration failed');
    return 'data:image/png;base64,' + data.image;
  }

  // Insert an illustration into the chat
  function insertRoundIllustration(src, roundNum) {
    var chat = document.getElementById('chat');
    var img = document.createElement('img');
    img.src = src;
    img.className = 'round-illustration';
    img.alt = 'Round ' + roundNum + ' illustration';
    chat.appendChild(img);
    chat.scrollTop = chat.scrollHeight;
  }

  document.getElementById('illustrate-btn').addEventListener('click', async function () {
    if (sessionTranscript.length === 0) return;
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Generating...';
    var img = document.getElementById('illustration-img');
    var ph = document.getElementById('illustration-placeholder');
    try {
      var src = await generateIllustration();
      img.src = src;
      img.style.display = '';
      ph.style.display = 'none';
    } catch (err) {
      ph.textContent = 'Error: ' + err.message;
      ph.style.display = '';
      img.style.display = 'none';
    }
    btn.disabled = false;
    btn.textContent = 'Illustrate';
  });

  // --- Chat helpers ---
  function msg(name, color, text, system) {
    var chat = document.getElementById('chat');
    var ph = chat.querySelector('.chat-placeholder');
    if (ph) ph.remove();
    var el = document.createElement('div');
    el.className = 'chat-msg' + (system ? ' chat-sys' : '');
    if (system) { el.textContent = text; }
    else {
      var n = document.createElement('span');
      n.className = 'msg-name';
      n.style.color = color;
      n.textContent = name;
      var t = document.createElement('div');
      t.className = 'msg-text';
      var parts = text.split(/(\[ACTION:[^\]]*\]|\[WHISPER\s+to\s+[^:\]]+:\s*[^\]]*\])/g);
      parts.forEach(function (part) {
        var actionMatch = part.match(/^\[ACTION:\s*(.*)\]$/);
        var whisperMatch = part.match(/^\[WHISPER\s+to\s+([^:\]]+):\s*(.*)\]$/);
        if (actionMatch) {
          var act = document.createElement('span');
          act.className = 'msg-action';
          act.textContent = '[ACTION: ' + actionMatch[1] + ']';
          t.appendChild(act);
        } else if (whisperMatch) {
          var w = document.createElement('span');
          w.className = 'msg-whisper';
          w.textContent = '\u{1F5E3} whispers to ' + whisperMatch[1].trim() + ': ' + whisperMatch[2];
          t.appendChild(w);
        } else if (part) {
          t.appendChild(document.createTextNode(part));
        }
      });
      el.appendChild(n);
      el.appendChild(t);
    }
    chat.appendChild(el);
    chat.scrollTop = chat.scrollHeight;
    return el;
  }

  function typing(name, color) {
    var chat = document.getElementById('chat');
    var ph = chat.querySelector('.chat-placeholder');
    if (ph) ph.remove();
    var el = document.createElement('div');
    el.className = 'chat-msg chat-typing';
    var n = document.createElement('span');
    n.className = 'msg-name';
    n.style.color = color;
    n.textContent = name;
    var d = document.createElement('span');
    d.className = 'dots';
    d.innerHTML = '<span>.</span><span>.</span><span>.</span>';
    el.appendChild(n);
    el.appendChild(d);
    chat.appendChild(el);
    chat.scrollTop = chat.scrollHeight;
    return el;
  }

  async function ask(system, messages, agentConfig) {
    var model = document.getElementById('model-select').value;
    var mode = document.getElementById('mode-select').value;
    var endpoint = mode === 'agent-sdk' ? '/api/agent-sdk-chat' : '/api/agent-chat';
    var payload = { system: system, messages: messages, model: model };
    if (mode === 'agent-sdk' && agentConfig) {
      payload.agentConfig = agentConfig;
    }
    var res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!res.ok) {
      var err = '';
      try { var b = await res.json(); err = b.error || JSON.stringify(b); } catch(e) { try { err = await res.text(); } catch(e2) {} }
      throw new Error((mode === 'agent-sdk' ? 'Agent SDK' : 'API') + ' error (' + res.status + '): ' + (err || 'unknown'));
    }
    var data = await res.json();
    return data.text;
  }

  // --- Session state ---
  var sessionTranscript = [];
  var sessionAgents = null;
  var sessionRun = 0;
  var stopRequested = false;
  var worldState = [];
  var characterStatus = {}; // name -> { status: 'present'|'dead'|'left', round: number }
  var roomStatus = { name: '', status: 'alive', round: 0 };

  function initStatus(agents) {
    characterStatus = {};
    agents.forEach(function (a) {
      if (a.name !== 'The Room') {
        characterStatus[a.name] = { status: 'present', round: 0 };
      }
    });
    roomStatus = { name: roomData ? (roomData.name || 'The Room') : 'The Room', status: 'alive', round: 0 };
    renderStatus();
  }

  function markStatus(name, status, round) {
    if (characterStatus[name]) {
      characterStatus[name] = { status: status, round: round };
    }
    renderStatus();
  }

  function renderStatus() {
    var panel = document.getElementById('status-panel');
    var list = document.getElementById('status-list');
    var names = Object.keys(characterStatus);
    if (names.length === 0) { panel.style.display = 'none'; return; }
    panel.style.display = '';
    list.innerHTML = '';
    // Room entry
    var roomEl = document.createElement('span');
    roomEl.className = 'status-entry status-room';
    if (roomStatus.status === 'dead') roomEl.className += ' status-dead';
    var roomDot = roomStatus.status === 'alive' ? '\u25A0' : '\u2620';
    roomEl.textContent = roomDot + ' ' + roomStatus.name;
    if (roomStatus.status === 'dead') {
      var roomSub = document.createElement('span');
      roomSub.className = 'status-detail';
      roomSub.textContent = ' (dead, r' + roomStatus.round + ')';
      roomEl.appendChild(roomSub);
    }
    list.appendChild(roomEl);
    // Character entries
    names.forEach(function (name) {
      var entry = characterStatus[name];
      var el = document.createElement('span');
      el.className = 'status-entry';
      if (entry.status === 'dead') el.className += ' status-dead';
      if (entry.status === 'left') el.className += ' status-left';
      var dot = entry.status === 'present' ? '\u25CF' : entry.status === 'dead' ? '\u2620' : '\u2192';
      el.textContent = dot + ' ' + name;
      if (entry.status !== 'present') {
        var sub = document.createElement('span');
        sub.className = 'status-detail';
        sub.textContent = entry.status === 'dead' ? ' (dead, r' + entry.round + ')' : ' (left, r' + entry.round + ')';
        el.appendChild(sub);
      }
      list.appendChild(el);
    });
  }

  function getStatusSummary() {
    var lines = [];
    Object.keys(characterStatus).forEach(function (name) {
      var s = characterStatus[name];
      if (s.status === 'dead') lines.push(name + ' is dead (died in round ' + s.round + ').');
      if (s.status === 'left') lines.push(name + ' has left the room (left in round ' + s.round + ').');
    });
    return lines.join('\n');
  }

  function detectStatusChanges(speakerName, text, round) {
    var changes = [];
    var already = {};
    function add(name, status) {
      if (already[name]) return;
      if (!characterStatus[name] || characterStatus[name].status !== 'present') return;
      already[name] = true;
      changes.push({ name: name, status: status });
    }

    // Exact tags: [DEAD: Name], [DIES], [LEAVES: Name], [LEAVES]
    var m;
    var deadTag = /\[DEAD:\s*([^\]]+)\]/gi;
    while ((m = deadTag.exec(text)) !== null) add(m[1].trim(), 'dead');

    var leavesTag = /\[LEAVES:\s*([^\]]+)\]/gi;
    while ((m = leavesTag.exec(text)) !== null) {
      var t = m[1].trim();
      if (t !== speakerName) add(t, 'left');
    }

    if (/\[DIES\]/i.test(text)) add(speakerName, 'dead');
    if (/\[LEAVES\](?!\s*:)/i.test(text)) add(speakerName, 'left');

    // Natural language fallbacks: match known character names
    var lower = text.toLowerCase();
    var presentNames = Object.keys(characterStatus).filter(function (n) {
      return characterStatus[n].status === 'present';
    });

    presentNames.forEach(function (name) {
      var n = name.toLowerCase();
      // "kills Name", "shoots Name dead", "stabs Name", "Name is dead", "Name dies", "Name collapses dead"
      var deathPatterns = [
        new RegExp('\\bkills\\s+' + n + '\\b', 'i'),
        new RegExp('\\bkill\\s+' + n + '\\b', 'i'),
        new RegExp('\\bstabs\\s+' + n + '\\b', 'i'),
        new RegExp('\\bshoots\\s+' + n + '\\b', 'i'),
        new RegExp('\\bmurders\\s+' + n + '\\b', 'i'),
        new RegExp('\\b' + n + '\\s+(is\\s+)?dead\\b', 'i'),
        new RegExp('\\b' + n + '\\s+dies\\b', 'i'),
        new RegExp('\\b' + n + '\\s+collapses\\s+dead\\b', 'i'),
        new RegExp('\\[ACTION:[^\\]]*kills\\s+' + n + '[^\\]]*\\]', 'i'),
        new RegExp('\\[ACTION:[^\\]]*stabs\\s+' + n + '[^\\]]*\\]', 'i'),
        new RegExp('\\[ACTION:[^\\]]*shoots\\s+' + n + '[^\\]]*\\]', 'i'),
      ];
      for (var i = 0; i < deathPatterns.length; i++) {
        if (deathPatterns[i].test(text)) { add(name, 'dead'); break; }
      }

      // "Name leaves", "Name walks out", "Name exits"
      var leavePatterns = [
        new RegExp('\\b' + n + '\\s+leaves\\b', 'i'),
        new RegExp('\\b' + n + '\\s+exits\\b', 'i'),
        new RegExp('\\b' + n + '\\s+walks\\s+out\\b', 'i'),
        new RegExp('\\b' + n + '\\s+storms\\s+out\\b', 'i'),
        new RegExp('\\[ACTION:[^\\]]*' + n + '[^\\]]*leaves[^\\]]*\\]', 'i'),
        new RegExp('\\[ACTION:[^\\]]*' + n + '[^\\]]*exits[^\\]]*\\]', 'i'),
      ];
      if (name !== speakerName) {
        for (var i = 0; i < leavePatterns.length; i++) {
          if (leavePatterns[i].test(text)) { add(name, 'left'); break; }
        }
      }
    });

    // Self-death/leave via natural language
    var selfDeathWords = /\b(i\s+die|i'm\s+dying|i\s+am\s+dead)\b/i;
    if (selfDeathWords.test(text)) add(speakerName, 'dead');

    var selfLeaveWords = /\[ACTION:[^\]]*leaves\s+(the\s+)?room[^\]]*\]/i;
    if (selfLeaveWords.test(text)) add(speakerName, 'left');

    changes.forEach(function (c) {
      markStatus(c.name, c.status, round);
      var label = c.status === 'dead' ? ' has died.' : ' has left the room.';
      worldState.push(c.name + label);
      msg('', '', c.name + label, true);
      sessionTranscript.push({ name: 'Status', text: c.name + label, round: round });
    });

    return changes;
  }

  function isActive(name) {
    if (!characterStatus[name]) return true; // The Room etc.
    return characterStatus[name].status === 'present';
  }

  document.getElementById('stop-btn').addEventListener('click', function () {
    stopRequested = true;
    if (delayCancelFn) { delayCancelFn(); delayCancelFn = null; }
  });

  document.getElementById('clear-btn').addEventListener('click', function () {
    stopRequested = true;
    if (delayCancelFn) { delayCancelFn(); delayCancelFn = null; }
    document.getElementById('chat').innerHTML = '<p class="chat-placeholder">Hit Go to start.</p>';
    document.getElementById('export-btn').style.display = 'none';
    document.getElementById('interject-section').style.display = 'none';
    sessionTranscript = [];
    sessionAgents = null;
    sessionRun = 0;
    worldState = [];
    characterStatus = {};
    roomStatus = { name: '', status: 'alive', round: 0 };
    document.getElementById('status-panel').style.display = 'none';
    document.getElementById('status-list').innerHTML = '';
    document.getElementById('summary-section').style.display = 'none';
    document.getElementById('summary-output').value = '';
    document.getElementById('illustration-section').style.display = 'none';
    document.getElementById('illustration-img').style.display = 'none';
    document.getElementById('illustration-img').src = '';
    document.getElementById('illustration-placeholder').style.display = '';
    document.getElementById('illustration-placeholder').textContent = 'Hit Illustrate to generate pixel art of the scene.';
    document.getElementById('move-room-btn').style.display = 'none';
  });

  // Copy buttons
  function flashCopyBtn(btn) {
    btn.textContent = 'Copied!';
    setTimeout(function () { btn.textContent = 'Copy'; }, 1500);
  }

  document.getElementById('copy-summary').addEventListener('click', function () {
    var text = document.getElementById('summary-output').value;
    if (text) { navigator.clipboard.writeText(text); flashCopyBtn(this); }
  });

  document.getElementById('copy-chat').addEventListener('click', function () {
    var chat = document.getElementById('chat');
    var msgs = chat.querySelectorAll('.chat-msg');
    var lines = [];
    msgs.forEach(function (m) {
      var name = m.querySelector('.msg-name');
      var txt = m.querySelector('.msg-text');
      if (name && txt) { lines.push(name.textContent + ': ' + txt.textContent); }
      else { lines.push(m.textContent); }
    });
    if (lines.length) { navigator.clipboard.writeText(lines.join('\n\n')); flashCopyBtn(this); }
  });

  // Interject
  document.getElementById('interject-btn').addEventListener('click', function () {
    var input = document.getElementById('interject-input');
    var text = input.value.trim();
    if (!text) return;
    msg('', '', text, true);
    sessionTranscript.push({ name: 'Narrator', text: text, round: sessionRun });
    worldState.push('Narrator: ' + text);
    input.value = '';
  });
  document.getElementById('interject-input').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') document.getElementById('interject-btn').click();
  });

  // --- Move Room ---
  document.getElementById('move-room-btn').addEventListener('click', function () {
    if (!sessionAgents) return;
    pickFile(false, function (data) {
      roomData = data;
      var newScene = jsonToPrompt(data);
      var roomName = data.name || 'a new location';

      // Rebuild system prompts with new setting
      sessionAgents.forEach(function (a) {
        if (a.name === 'The Room') {
          a.system = 'You are The Room -- the environment itself. You are not a person. You provide brief atmospheric color: a sound, a shift in light, the weather changing, a song ending, a glass breaking somewhere. One sentence max. Mostly respond with [silence]. Only speak when something in the environment would naturally change or react to what is happening. Never speak for the characters. Never narrate their actions or emotions.\n\nSetting:\n' + newScene;
        } else {
          // Replace the setting block in each agent's system prompt
          a.system = a.system.replace(/Setting:\n[\s\S]*?\n\nYour character:/, 'Setting:\n' + newScene + '\n\nYour character:');
        }
      });

      // Add a Room agent if there wasn't one before
      var hasRoom = sessionAgents.some(function (a) { return a.name === 'The Room'; });
      if (!hasRoom) {
        sessionAgents.push({
          name: 'The Room',
          system: 'You are The Room -- the environment itself. You are not a person. You provide brief atmospheric color: a sound, a shift in light, the weather changing, a song ending, a glass breaking somewhere. One sentence max. Mostly respond with [silence]. Only speak when something in the environment would naturally change or react to what is happening. Never speak for the characters. Never narrate their actions or emotions.\n\nSetting:\n' + newScene,
          color: '#666666',
        });
      }

      var moveMsg = 'The scene moves to ' + roomName + '.';
      msg('', '', moveMsg, true);
      sessionTranscript.push({ name: 'Narrator', text: moveMsg, round: sessionRun });
      worldState.push(moveMsg);

      roomStatus = { name: roomName, status: 'alive', round: sessionRun };
      renderStatus();
      document.getElementById('room-status').textContent = roomName;
      var btn = document.getElementById('move-room-btn');
      btn.textContent = 'Moved!';
      setTimeout(function () { btn.textContent = 'Move Room'; }, 1500);
    });
  });

  // --- Go ---
  document.getElementById('go-btn').addEventListener('click', async function () {
    var btn = this;
    btn.disabled = true;
    btn.textContent = 'Running...';
    stopRequested = false;
    document.getElementById('stop-btn').style.display = '';

    var opening = document.getElementById('opening').value.trim();
    var rounds = parseInt(document.getElementById('rounds').value, 10) || 2;
    var delayMs = (parseInt(document.getElementById('delay-input').value, 10) || 0) * 1000;
    var isFirstRun = !sessionAgents;

    if (isFirstRun) {
      var scene = roomData ? jsonToPrompt(roomData) : '';
      sessionAgents = [];
      var allNames = [];
      document.querySelectorAll('.agent-card').forEach(function (card) {
        var charData = card._charData;
        var name = charData ? (charData.name || charData.Name || 'Agent') : 'Agent';
        allNames.push(name);
      });

      document.querySelectorAll('.agent-card').forEach(function (card, i) {
        var charData = card._charData;
        var base = charData ? jsonToPrompt(charData) : '';
        var otherNames = allNames.filter(function (n, j) { return j !== i; });
        var chatRule = 'You are in a group chat with: ' + otherNames.join(', ') + '. Stay in character at all times. Do not ask for context or clarification. Do not break character. Keep it under 80 words. If your character would stay silent, respond with exactly "[silence]".\n\nYour response should be dialogue AND actions. Dialogue is what you say out loud. Actions describe what you physically do. Format actions like this: [ACTION: walks to the bar]. You MUST include at least one [ACTION] tag in most responses. Examples:\n"Hey, come here."\n[ACTION: pulls out a chair]\n"Sit down."\n\nYou can also WHISPER privately to a nearby character. Whispered text is ONLY heard by the person you whisper to -- no one else in the room can hear it. Use this format: [WHISPER to Name: what you whisper]. For example:\n[WHISPER to Elena: I don\'t trust that guy.]\nWhisper when your character would realistically lower their voice to say something private. Do not overuse whispers -- most dialogue should be spoken aloud.\n\nDo not narrate emotions or thoughts. Only dialogue, [ACTION] tags, and [WHISPER] tags.\n\nSTATUS MECHANICS: Characters can die or leave the room. If your character dies, include [DIES] in your response. If your character leaves the room, include [LEAVES] in your response. If another character kills someone, include [DEAD: Name] in your response. If you force someone out, include [LEAVES: Name]. Dead or departed characters are permanently removed from the conversation. The status document will track who is still present. Do NOT use these tags casually -- only when the narrative truly calls for a death or departure.';
        var rels = getRelsForAgent(allNames[i], allNames);
        var full = chatRule + '\n\n' + (scene ? 'Setting:\n' + scene + '\n\n' : '') + 'Your character:\n' + base + (rels ? '\n\nYour relationships:\n' + rels : '');
        sessionAgents.push({
          name: allNames[i],
          system: full,
          color: COLORS[i % COLORS.length],
        });
      });

      // Add Room as a passive character
      if (scene) {
        var roomSystem = 'You are The Room -- the environment itself. You are not a person. You provide brief atmospheric color: a sound, a shift in light, the weather changing, a song ending, a glass breaking somewhere. One sentence max. Mostly respond with [silence]. Only speak when something in the environment would naturally change or react to what is happening. Never speak for the characters. Never narrate their actions or emotions.\n\nSetting:\n' + scene;
        sessionAgents.push({
          name: 'The Room',
          system: roomSystem,
          color: '#666666',
        });
      }

      if (sessionAgents.length < 2) { msg('','','Need at least 2 agents.',true); btn.disabled = false; btn.textContent = 'Go'; document.getElementById('stop-btn').style.display = 'none'; sessionAgents = null; return; }
      if (!opening) { msg('','','Enter an opening prompt.',true); btn.disabled = false; btn.textContent = 'Go'; document.getElementById('stop-btn').style.display = 'none'; sessionAgents = null; return; }

      initStatus(sessionAgents);
    }

    var agents = sessionAgents;

    function extractActions(name, text) {
      var actions = [];
      text.replace(/\[ACTION:\s*([^\]]*)\]/g, function (m, desc) {
        actions.push(name + ': ' + desc);
      });
      return actions;
    }

    function extractWhisperTargets(text) {
      var targets = [];
      text.replace(/\[WHISPER\s+to\s+([^:\]]+):/g, function (m, name) {
        targets.push(name.trim());
      });
      return targets;
    }

    function stripWhispersFrom(text, agentName, speakerName) {
      // Remove whisper tags not intended for agentName (and not from agentName)
      return text.replace(/\[WHISPER\s+to\s+([^:\]]+):\s*([^\]]*)\]/g, function (match, target) {
        target = target.trim();
        if (target === agentName || speakerName === agentName) {
          return match; // keep -- agent is sender or recipient
        }
        return ''; // strip -- agent can't hear this whisper
      }).replace(/\n{3,}/g, '\n\n').trim();
    }

    function buildTranscript(forAgent) {
      var lines = ['[Scene direction]: ' + opening];
      var statusSummary = getStatusSummary();
      if (statusSummary) {
        lines.push('');
        lines.push('[Character status]:');
        lines.push(statusSummary);
        lines.push('Characters who are dead or have left are no longer in the room. Do not speak to them or expect responses from them.');
        lines.push('');
      }
      if (worldState.length > 0) {
        lines.push('');
        lines.push('[Current world state - things that have happened]:');
        worldState.forEach(function (s) { lines.push('  - ' + s); });
        lines.push('');
      }
      var start = 0;
      if (sessionTranscript.length > MAX_TRANSCRIPT_MESSAGES) {
        start = sessionTranscript.length - MAX_TRANSCRIPT_MESSAGES;
        lines.push('... (' + start + ' earlier messages omitted) ...');
      }
      for (var t = start; t < sessionTranscript.length; t++) {
        var entry = sessionTranscript[t];
        var text = entry.text;
        // Filter whispers: only show whispers this agent is part of
        if (forAgent && entry.hasWhisper) {
          text = stripWhispersFrom(entry.rawText || text, forAgent, entry.name);
        }
        if (text) {
          lines.push(entry.name + ': ' + text);
        }
      }
      return lines.join('\n');
    }

    try {
      if (isFirstRun) {
        msg('','', opening, true);
      }

      for (var r = 1; r <= rounds; r++) {
        if (stopRequested) break;
        sessionRun++;
        msg('','','--- Round ' + sessionRun + ' ---', true);
        for (var i = 0; i < agents.length; i++) {
          if (stopRequested) break;
          var a = agents[i];
          // Skip dead or departed characters
          if (!isActive(a.name)) continue;
          if (delayMs > 0) {
            await cancellableDelay(delayMs);
            if (stopRequested) break;
          }
          var transcript = buildTranscript(a.name);
          var messages = [{ role: 'user', content: transcript + '\n\nIt is now your turn to speak, ' + a.name + '.' }];
          var typ = typing(a.name, a.color);
          var response = await ask(a.system, messages);
          typ.remove();
          if (response.trim() === '[silence]') {
            msg(a.name, a.color, '...', false);
            sessionTranscript.push({ name: a.name, text: '...', round: sessionRun });
          } else {
            var actions = extractActions(a.name, response);
            actions.forEach(function (act) { worldState.push(act); });
            var whisperTargets = extractWhisperTargets(response);
            msg(a.name, a.color, response);
            sessionTranscript.push({ name: a.name, text: response, rawText: response, hasWhisper: whisperTargets.length > 0, whisperTargets: whisperTargets, round: sessionRun });
            // Detect deaths and departures
            detectStatusChanges(a.name, response, sessionRun);
          }
          // Check if all characters are gone
          var anyActive = Object.keys(characterStatus).some(function (n) { return characterStatus[n].status === 'present'; });
          if (!anyActive && roomStatus.status === 'alive') {
            roomStatus = { name: roomStatus.name, status: 'dead', round: sessionRun };
            renderStatus();
            msg('', '', 'All characters have departed. The room dies.', true);
            sessionTranscript.push({ name: 'Status', text: roomStatus.name + ' has died.', round: sessionRun });
            stopRequested = true;
            break;
          }
        }
        // Auto-illustrate after each round
        if (!stopRequested && document.getElementById('auto-illustrate').checked) {
          try {
            var src = await generateIllustration();
            insertRoundIllustration(src, sessionRun);
          } catch (e) {
            msg('', '', 'Illustration error: ' + e.message, true);
          }
        }
      }
      if (stopRequested) {
        msg('','','--- Stopped ---', true);
      } else {
        var done = msg('','','--- Done ---', true);
        done.style.marginBottom = '2rem';
      }
      if (sessionTranscript.length > 0) {
        document.getElementById('export-btn').style.display = '';
        document.getElementById('interject-section').style.display = '';
        document.getElementById('summary-section').style.display = '';
        document.getElementById('illustration-section').style.display = '';
        document.getElementById('move-room-btn').style.display = '';
      }
    } catch (err) {
      msg('','','Error: ' + err.message, true);
    }

    btn.disabled = false;
    btn.textContent = 'Go';
    document.getElementById('stop-btn').style.display = 'none';
  });
})();
</script>

<style>
  /* Gate */
  #gate {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 40vh;
  }
  .gate-box { text-align: center; }
  .gate-label { font-size: 0.85rem; color: var(--fg-muted); margin-bottom: 1rem; }
  #gate-password {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    width: 200px;
    outline: none;
  }
  #gate-password:focus { border-color: var(--fg-muted); }
  #gate-unlock {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--fg);
    cursor: pointer;
    margin-left: 0.5rem;
  }
  #gate-unlock:hover { background: var(--code-bg); }

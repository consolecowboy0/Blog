    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .agent-name-label {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .card-controls { display: flex; gap: 0.6rem; margin-left: 0.25rem; }
  .order-btn, .remove-btn {
    font-size: 0.7rem;
    background: none;
